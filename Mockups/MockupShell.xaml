<Window x:Class="TMM.Mockups.MockupShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TMM — Design Mockups (UI only)"
        Width="1180" Height="760" MinWidth="980" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Window.Resources>
        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="12,9">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource ControlBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="248"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Mockup picker -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}">
            <DockPanel Margin="14,18">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="TMM" FontSize="20" FontWeight="Black"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Design mockups" FontSize="12"
                               Foreground="{StaticResource SubTextBrush}" Margin="0,0,0,18"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" TextWrapping="Wrap" FontSize="10"
                           Foreground="{StaticResource SubTextBrush}" Opacity="0.7"
                           Text="UI-only. Nothing here is wired to a backend — buttons are for looks. Click an idea above to preview it."/>

                <StackPanel x:Name="navPanel">
                    <RadioButton Content="Settings · Dual Pane" GroupName="m" IsChecked="True" Checked="Nav_Checked" Tag="settings" Style="{StaticResource NavItem}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" ClipToBounds="True">
            <ContentControl x:Name="host"/>
        </Border>
    </Grid>
</Window>
