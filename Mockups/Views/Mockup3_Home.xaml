<UserControl x:Class="TMM.Mockups.Views.Mockup3_Home"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <!-- Spacing scale used throughout: 4 / 8 / 12 / 16 / 24 / 28.
         Section gap = 28, header→content = 12, card gutter = 16. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,26,32,32" MaxWidth="1040">

            <TextBlock Text="My Library" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="The library is the global home. Lead with where the user left off, not a wall of equal cards."
                       FontSize="12" Foreground="{StaticResource SubTextBrush}" Margin="0,4,0,24"/>

            <!-- ── Continue hero: the default / most-recent game ── -->
            <Border CornerRadius="12" Height="172" Margin="0,0,0,28">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.4">
                        <GradientStop Color="#1B3A1B" Offset="0"/>
                        <GradientStop Color="#0C1E0C" Offset="0.55"/>
                        <GradientStop Color="#202020" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="108" Height="108" CornerRadius="12"
                            Background="{StaticResource CoverGTA3}" VerticalAlignment="Center">
                        <TextBlock Text="III" FontWeight="Black" FontSize="36" Foreground="#9FE6A0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0">
                        <TextBlock Text="CONTINUE" FontSize="10" FontWeight="Bold" Foreground="#9FE6A0" Opacity="0.8"/>
                        <TextBlock Text="Grand Theft Auto III" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,3,0,0"/>
                        <TextBlock Text="12 mods · 9 enabled · Story Mode loadout · last deployed 2 days ago"
                                   FontSize="12.5" Foreground="#D8D8D8" Margin="0,8,0,0"/>
                        <Border Background="#22E0A020" CornerRadius="9" Padding="9,3" HorizontalAlignment="Left" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource NeedsFolderAmber}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="3 changes pending deploy" FontSize="11" Foreground="{StaticResource NeedsFolderAmber}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Width="172" VerticalAlignment="Center">
                        <Button Style="{StaticResource AccentBtn}" Padding="0,11" Margin="0,0,0,10" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,8,0"/>
                                <TextBlock Text="Play" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostBtn}" Padding="0,10" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Manage mods"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Quick stats strip — equal cells via -6 bleed + 6 per-card gutters ── -->
            <UniformGrid Rows="1" Columns="4" Margin="-6,0,-6,28">
                <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="20,16" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="3" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Games set up" FontSize="11" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="20,16" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="34" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Mods installed" FontSize="11" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="20,16" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="2.4 GB" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Backups used / 5 GB" FontSize="11" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="20,16" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="1" FontSize="24" FontWeight="Bold" Foreground="{StaticResource UpdateBlue}"/>
                        <TextBlock Text="Mod update available" FontSize="11" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Your games ── -->
            <DockPanel Margin="0,0,0,12">
                <Button DockPanel.Dock="Right" Style="{StaticResource GhostBtn}" Padding="12,6" FontSize="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                        <TextBlock Text="Add game"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="Your games" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- -8 bleed so a row of 224-wide cards with 8/side gutters lines up flush with the hero edges -->
            <WrapPanel Margin="-8,0,-8,0">
                <!-- Card A -->
                <Border Width="224" Height="150" CornerRadius="12" Margin="8,0,8,16" Background="{StaticResource CoverGTA3}">
                    <Grid Margin="16,14">
                        <TextBlock Text="GRAND THEFT&#x0a;AUTO III" FontWeight="Bold" FontSize="16" Foreground="White" VerticalAlignment="Top"/>
                        <StackPanel VerticalAlignment="Bottom">
                            <Border Background="#33000000" CornerRadius="8" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource ReadyGreen}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Ready · 12 mods" FontSize="10.5" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource AccentBtn}" Padding="14,5" FontSize="12" Margin="0,0,8,0" Content="▶ Play"/>
                                <Button Style="{StaticResource GhostBtn}" Padding="14,5" FontSize="12" Content="Manage"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Card B -->
                <Border Width="224" Height="150" CornerRadius="12" Margin="8,0,8,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3A1B2E" Offset="0"/><GradientStop Color="#1E0C16" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="16,14">
                        <TextBlock Text="VICE CITY" FontWeight="Bold" FontSize="16" Foreground="White" VerticalAlignment="Top"/>
                        <StackPanel VerticalAlignment="Bottom">
                            <Border Background="#33000000" CornerRadius="8" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="No mods yet" FontSize="10.5" Foreground="#D0D0D0"/>
                            </Border>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource AccentBtn}" Padding="14,5" FontSize="12" Margin="0,0,8,0" Content="▶ Play"/>
                                <Button Style="{StaticResource GhostBtn}" Padding="14,5" FontSize="12" Content="Manage"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Card C — needs folder -->
                <Border Width="224" Height="150" CornerRadius="12" Margin="8,0,8,16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#2A2A3A" Offset="0"/><GradientStop Color="#15151E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="16,14">
                        <TextBlock Text="SAN ANDREAS" FontWeight="Bold" FontSize="16" Foreground="White" VerticalAlignment="Top"/>
                        <StackPanel VerticalAlignment="Bottom">
                            <Border Background="#33E0A020" CornerRadius="8" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,10" Cursor="Hand">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource NeedsFolderAmber}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Needs folder" FontSize="10.5" Foreground="{StaticResource NeedsFolderAmber}"/>
                                </StackPanel>
                            </Border>
                            <Button Style="{StaticResource GhostBtn}" Padding="14,5" FontSize="12" Content="Set up →" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </WrapPanel>

            <!-- ── Recent activity ── -->
            <TextBlock Text="Recent activity" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,12,0,12"/>
            <Border Background="{StaticResource PanelBrush}" CornerRadius="10" Padding="6">
                <StackPanel>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource ReadyGreen}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Deployed 9 mods to Grand Theft Auto III" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="2 days ago" FontSize="11" Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource ControlBgBrush}" Opacity="0.5" Margin="38,0,14,0"/>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Installed SkyGFX" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="2 days ago" FontSize="11" Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource ControlBgBrush}" Opacity="0.5" Margin="38,0,14,0"/>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="38"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE777;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource SubTextBrush}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Backup created before deploy" FontSize="12" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="2 days ago" FontSize="11" Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
