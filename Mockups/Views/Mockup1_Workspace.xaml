<UserControl x:Class="TMM.Mockups.Views.Mockup1_Workspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="52"/>   <!-- app rail (GLOBAL only) -->
            <ColumnDefinition Width="*"/>    <!-- game workspace -->
        </Grid.ColumnDefinitions>

        <!-- ══ App rail: only truly-global destinations live here ══ -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="T" FontWeight="Black" FontSize="18"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center" Margin="0,14,0,16"/>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,10">
                    <Button Style="{StaticResource IconBtn}" Width="40" Height="40" FontSize="18"
                            Content="&#xE713;" ToolTip="Settings" Margin="6,3"/>
                </StackPanel>
                <StackPanel>
                    <Button Style="{StaticResource IconBtn}" Width="40" Height="40" FontSize="18"
                            Content="&#xE80F;" ToolTip="Library  (home)" Margin="6,3"/>
                    <Button Style="{StaticResource IconBtn}" Width="40" Height="40" FontSize="18"
                            Content="&#xEA8F;" ToolTip="Notifications" Margin="6,3"/>
                    <Button Style="{StaticResource IconBtn}" Width="40" Height="40" FontSize="18"
                            Content="&#xE897;" ToolTip="Help &amp; Troubleshooting" Margin="6,3"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══ Game workspace ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- game header -->
                <RowDefinition Height="Auto"/>  <!-- pending-changes banner -->
                <RowDefinition Height="Auto"/>  <!-- sub-tabs -->
                <RowDefinition Height="*"/>     <!-- tab content -->
            </Grid.RowDefinitions>

            <!-- ── Game header: identity + the 3 verbs that matter ── -->
            <Border Grid.Row="0" Height="104">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#16284A2A" Offset="0"/>
                        <GradientStop Color="#00202020" Offset="0.6"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cover -->
                    <Border Grid.Column="0" Width="64" Height="64" CornerRadius="10"
                            Background="{StaticResource CoverGTA3}" VerticalAlignment="Center">
                        <TextBlock Text="III" FontWeight="Black" FontSize="22" Foreground="#9FE6A0"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title + meta -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Grand Theft Auto III" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="9"
                                    Padding="8,2" Margin="12,2,0,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource ReadyGreen}"
                                             VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="Ready" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource ReadyGreen}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Rockstar · 2001 · 12 mods · C:\Games\GTA III"
                                   FontSize="12" Foreground="{StaticResource SubTextBrush}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Primary actions: Loadout switcher · Deploy · Play · overflow -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource ControlBgBrush}" CornerRadius="7"
                                Padding="12,7" Margin="0,0,10,0" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{StaticResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="LOADOUT" FontSize="8" Foreground="{StaticResource SubTextBrush}"/>
                                    <TextBlock Text="Story Mode  ▾" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource AccentBtn}" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,7,0"/>
                                <TextBlock Text="Deploy"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource GhostBtn}" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,7,0"/>
                                <TextBlock Text="Play"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource IconBtn}" Width="38" Height="38" FontSize="16" Content="&#xE712;"
                                ToolTip="More:  Edit Config · Import · Refresh · Open files · Rollback · Export profile"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Pending-changes banner (only when undeployed edits exist) ── -->
            <Border Grid.Row="1" Background="#22E0A020" Padding="20,8" Margin="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                               Foreground="{StaticResource NeedsFolderAmber}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextBrush}">
                        <Run Text="3 changes since last deploy"/>
                        <Run Text="— 2 enabled, 1 reordered." Foreground="{StaticResource SubTextBrush}"/>
                    </TextBlock>
                    <Button Content="Review &amp; Deploy →" Style="{StaticResource IconBtn}"
                            FontFamily="Segoe UI"
                            Foreground="{StaticResource NeedsFolderAmber}" Padding="10,3" Margin="12,0,0,0" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- ── Sub-tabs: game-scoped features become tabs, not ambiguous globals ── -->
            <Border Grid.Row="2" Background="{StaticResource HeaderBrush}" Padding="16,0">
                <DockPanel>
                    <!-- right tools -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource ControlBgBrush}" CornerRadius="5" Padding="8,0"
                                Height="26" Width="180" Margin="0,0,8,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource SubTextBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="Search mods" FontSize="12" Foreground="{StaticResource SubTextBrush}"/>
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource AccentBtn}" Padding="12,5" FontSize="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0"/>
                                <TextBlock Text="Install"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- tabs -->
                    <StackPanel Orientation="Horizontal">
                        <Border BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,2" Padding="4,12">
                            <TextBlock Text="Mods" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="6,0"/>
                        </Border>
                        <Border Padding="4,12" Margin="14,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Conflicts" FontSize="13" Foreground="{StaticResource SubTextBrush}" Margin="6,0,4,0"/>
                                <Border Background="{StaticResource ConflictRed}" CornerRadius="8" Padding="5,0" VerticalAlignment="Center">
                                    <TextBlock Text="2" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Backups"   FontSize="13" Foreground="{StaticResource SubTextBrush}" Margin="20,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Downloads" FontSize="13" Foreground="{StaticResource SubTextBrush}" Margin="20,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Config"    FontSize="13" Foreground="{StaticResource SubTextBrush}" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Mods tab content ── -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Padding="16,12">
                <StackPanel>
                    <!-- group header -->
                    <TextBlock Text="GAMEPLAY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentLabelBrush}" Margin="2,0,0,6"/>

                    <Border Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="0" Margin="0,0,0,6">
                        <Grid Height="46">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#7AA2F7" CornerRadius="6,0,0,6"/>
                            <CheckBox Grid.Column="1" IsChecked="True" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="SilentPatch III" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="Gameplay · v1.3 · nexusmods.com" FontSize="10.5" Foreground="{StaticResource SubTextBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Border Background="#22F0623E" CornerRadius="9" Padding="8,3" Margin="0,0,8,0" ToolTip="Overwrites files from 2 other mods">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource ConflictRed}" Margin="0,0,4,0"/>
                                        <TextBlock Text="Overwrites 2" FontSize="10.5" Foreground="{StaticResource ConflictRed}"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="1.2 MB" FontSize="11" Foreground="{StaticResource SubTextBrush}" Width="56" TextAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource PanelBrush}" CornerRadius="6" Margin="0,0,0,6">
                        <Grid Height="46">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#7AA2F7" CornerRadius="6,0,0,6"/>
                            <CheckBox Grid.Column="1" IsChecked="True" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="Widescreen Fix" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="Gameplay · v2.1" FontSize="10.5" Foreground="{StaticResource SubTextBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Border Background="#223B9EFF" CornerRadius="9" Padding="8,3" Margin="0,0,8,0" ToolTip="Update available: v2.3">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource UpdateBlue}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Update" FontSize="10.5" Foreground="{StaticResource UpdateBlue}"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="640 KB" FontSize="11" Foreground="{StaticResource SubTextBrush}" Width="56" TextAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="VISUAL" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentLabelBrush}" Margin="2,12,0,6"/>

                    <Border Background="{StaticResource PanelBrush}" CornerRadius="6" Margin="0,0,0,6" Opacity="0.55">
                        <Grid Height="46">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#C586C0" CornerRadius="6,0,0,6"/>
                            <CheckBox Grid.Column="1" IsChecked="False" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="HD Textures Pack  (disabled)" FontSize="13" Foreground="{StaticResource SubTextBrush}"/>
                                <TextBlock Text="Visual · v4.0" FontSize="10.5" Foreground="{StaticResource SubTextBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="3" Text="2.4 GB" FontSize="11" Foreground="{StaticResource SubTextBrush}" Width="56" TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        </Grid>
                    </Border>

                    <TextBlock Margin="2,14,0,0" FontSize="11" Foreground="{StaticResource SubTextBrush}"
                               Text="Row anatomy →  [category spine]  [enable]  name + source/version  ·  inline conflict / update badge  ·  size.   Hover reveals open-folder / properties / disable. Drag the row to reorder load order."/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
