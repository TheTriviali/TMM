<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════
         Palette lifted verbatim from TMM ThemeEngine.cs so the
         mockups read in the real app's skin. Default accent gradient
         is #0883FF → #00D9FF (AppSettings defaults).
         ════════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="BgBrush"          Color="#202020"/>
    <SolidColorBrush x:Key="TextBrush"        Color="#E5E5E5"/>
    <SolidColorBrush x:Key="SubTextBrush"     Color="#9B9B9B"/>
    <SolidColorBrush x:Key="PanelBrush"       Color="#2D2D30"/>
    <SolidColorBrush x:Key="ControlBgBrush"   Color="#3C3C43"/>
    <SolidColorBrush x:Key="HeaderBrush"      Color="#323236"/>

    <SolidColorBrush x:Key="AccentBrush"      Color="#0883FF"/>
    <SolidColorBrush x:Key="AccentBrush2"     Color="#00D9FF"/>
    <SolidColorBrush x:Key="AccentTextBrush"  Color="White"/>
    <SolidColorBrush x:Key="AccentLabelBrush" Color="#0883FF"/>
    <SolidColorBrush x:Key="AccentSoftBrush"  Color="#220883FF"/>

    <!-- Semantic state colours (proposed additions to UiColors) -->
    <SolidColorBrush x:Key="ReadyGreen"       Color="#3FB950"/>
    <SolidColorBrush x:Key="NeedsFolderAmber" Color="#E0A020"/>
    <SolidColorBrush x:Key="ConflictRed"      Color="#F0623E"/>
    <SolidColorBrush x:Key="UpdateBlue"       Color="#3B9EFF"/>
    <SolidColorBrush x:Key="MutedChip"        Color="#80FFFFFF"/>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0883FF" Offset="0"/>
        <GradientStop Color="#00D9FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WindowBorderBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0883FF" Offset="0"/>
        <GradientStop Color="#00D9FF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Sample game cover gradients (stand-ins for cover art) -->
    <LinearGradientBrush x:Key="CoverGTA3" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1B3A1B" Offset="0"/>
        <GradientStop Color="#0C1E0C" Offset="1"/>
    </LinearGradientBrush>

    <!-- ════════════════════════════════════════════════════════════
         Reusable control styles
         ════════════════════════════════════════════════════════════ -->

    <!-- Flat icon/tool button -->
    <Style x:Key="IconBtn" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ControlBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Accent (primary) pill button -->
    <Style x:Key="AccentBtn" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Subtle (secondary) pill button -->
    <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource AccentBtn}">
        <Setter Property="Background" Value="{StaticResource ControlBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

</ResourceDictionary>
