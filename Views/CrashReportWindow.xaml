<local:TmmWindow x:Class="TMM.CrashReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        Title="TMM — Unexpected Error"
        Height="340" Width="520"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Border CornerRadius="8" BorderThickness="1" BorderBrush="#FF5555">
        <Border.Background><SolidColorBrush Color="#1C1C1E"/></Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" Background="#2A1A1A" MouseDown="TitleBar_MouseDown">
                <TextBlock Text="TMM — Unexpected Error"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#FF8888" VerticalAlignment="Center" Margin="12,0"/>
                <Button Content="&#xE8BB;" HorizontalAlignment="Right"
                        Width="40" Height="34" BorderThickness="0"
                        Background="Transparent" Foreground="#888888"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="20,16">
                <TextBlock Text="TMM ran into a problem." FontSize="13" FontWeight="SemiBold"
                           Foreground="#FFFFFF" Margin="0,0,0,8"/>
                <TextBlock x:Name="txtMessage" TextWrapping="Wrap" FontSize="11"
                           Foreground="#BBBBBB" Margin="0,0,0,12"/>
                <Border Background="#0DFFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1"
                        CornerRadius="4" Padding="8,6">
                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="txtDetail" IsReadOnly="True" TextWrapping="Wrap"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#888888" FontFamily="Consolas, Courier New"
                                 FontSize="10" SelectionBrush="#44FF5555"/>
                    </ScrollViewer>
                </Border>
                <TextBlock Text="If this keeps happening, please report it on GitHub."
                           FontSize="10" Foreground="#666666" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#2A1A1A" CornerRadius="0,0,8,8" Padding="12,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCopy" Content="Copy Error to Clipboard"
                            Click="BtnCopy_Click"
                            Background="#333333" Foreground="#BBBBBB"
                            BorderBrush="#555555" BorderThickness="1"
                            Padding="10,5" FontSize="11" Cursor="Hand"
                            Margin="0,0,8,0"/>
                    <Button Content="Close" Width="70"
                            Click="BtnClose_Click"
                            Background="#FF5555" Foreground="#FFFFFF"
                            BorderThickness="0" Padding="10,5"
                            FontSize="11" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
