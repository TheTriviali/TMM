<UserControl x:Class="TMM.BackupsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:TMM.Helpers"
             Background="{DynamicResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title + game selector -->
        <StackPanel Grid.Row="0" Margin="28,24,28,12">
            <TextBlock Text="{helpers:Localization Backups_Title}" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>
            <ComboBox x:Name="cmbGame" Width="260" HorizontalAlignment="Left" Height="30"
                      SelectionChanged="CmbGame_SelectionChanged"/>
        </StackPanel>

        <!-- Backup rows (or empty state) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="backupRowsPanel" Margin="28,8,28,28"/>
        </ScrollViewer>

        <!-- Restore-in-progress overlay -->
        <Grid x:Name="restoreOverlay" Grid.RowSpan="2" Visibility="Collapsed"
              Background="#AA000000" Panel.ZIndex="10">
            <TextBlock Text="Restoring…" Foreground="White" FontSize="16"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
