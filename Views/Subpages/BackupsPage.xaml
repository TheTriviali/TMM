<UserControl x:Class="TMM.BackupsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:TMM.Helpers"
             Background="{DynamicResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title + game selector + size summary -->
        <StackPanel Grid.Row="0" Margin="28,24,28,12">
            <Grid Margin="0,0,0,12">
                <TextBlock Text="{helpers:Localization Backups_Title}" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="txtBackupSize" FontSize="12"
                               Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
                    <Border x:Name="warnBadge" Visibility="Collapsed" Margin="10,0,0,0"
                            Background="#553311" CornerRadius="3" Padding="8,3" VerticalAlignment="Center">
                        <TextBlock Text="Over quota" FontSize="11" Foreground="#FFAA66"/>
                    </Border>
                    <Button Content="Recent activity" Click="BtnActivity_Click" Margin="14,0,0,0"
                            Padding="12,4" Background="{DynamicResource ControlBgBrush}"
                            Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
            <ComboBox x:Name="cmbGame" Width="260" HorizontalAlignment="Left" Height="30"
                      SelectionChanged="CmbGame_SelectionChanged"/>
        </StackPanel>

        <!-- Backup rows (or empty state) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="backupRowsPanel" Margin="28,8,28,28"/>
        </ScrollViewer>

        <!-- Restore-in-progress overlay -->
        <Grid x:Name="restoreOverlay" Grid.RowSpan="2" Visibility="Collapsed"
              Background="#AA000000" Panel.ZIndex="10">
            <TextBlock Text="Restoring…" Foreground="White" FontSize="16"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
