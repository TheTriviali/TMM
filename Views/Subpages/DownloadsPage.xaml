<UserControl x:Class="TMM.DownloadsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{DynamicResource BgBrush}"
             IsVisibleChanged="Page_IsVisibleChanged">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>

        <!-- ── Archive sidebar ── -->
        <Border Grid.Column="1" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="1,0,0,0">
            <DockPanel>

                <!-- Header: game selector -->
                <Border DockPanel.Dock="Top" Padding="12,10,12,10"
                        BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Downloaded archives" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentLabelBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Save downloads to:" FontSize="11"
                                   Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="cmbGame" Height="26" FontSize="11"
                                  Background="{DynamicResource ControlBgBrush}"
                                  Foreground="{DynamicResource TextBrush}"
                                  BorderBrush="{DynamicResource WindowBorderBrush}"
                                  SelectionChanged="CmbGame_SelectionChanged"/>
                        <TextBlock x:Name="txtArchivePath" Text="" FontSize="10"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Open folder button -->
                <Button DockPanel.Dock="Bottom" x:Name="btnOpenArchiveFolder"
                        Height="32" Margin="8,6" Cursor="Hand"
                        Background="{DynamicResource ControlBgBrush}"
                        Foreground="{DynamicResource SubTextBrush}"
                        BorderThickness="0" FontSize="11"
                        Click="BtnOpenArchiveFolder_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,5,0"
                                               Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Text="Open Folder" FontSize="11" VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Archive file list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                    <StackPanel x:Name="archiveList" Margin="0,4,0,0"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Browser area ── -->
        <Grid Grid.Column="0" Background="{DynamicResource BgBrush}">
            <!-- WebView2 -->
            <wv2:WebView2 x:Name="webView" Visibility="Collapsed"/>

            <!-- Fallback -->
            <StackPanel x:Name="webViewFallback" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Opacity="0.5">
                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="52"
                           Foreground="{DynamicResource SubTextBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Browser unavailable" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextBrush}"
                           HorizontalAlignment="Center" Margin="0,14,0,6"/>
                <TextBlock x:Name="txtWebViewError"
                           Text="Install the Microsoft Edge WebView2 Runtime to use the built-in browser."
                           FontSize="12" Foreground="{DynamicResource SubTextBrush}"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="380"/>
            </StackPanel>

            <!-- Loading -->
            <StackPanel x:Name="webViewLoading" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Opacity="0.4">
                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                           Foreground="{DynamicResource SubTextBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Loading browser…" FontSize="12"
                           Foreground="{DynamicResource SubTextBrush}"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
