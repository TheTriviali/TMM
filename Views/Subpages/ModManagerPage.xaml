<UserControl x:Class="TMM.ModManagerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             xmlns:helpers="clr-namespace:TMM.Helpers"
             Background="{DynamicResource BgBrush}">

    <UserControl.Resources>

        <!-- ──────────────────────────────────────────────────────── -->
        <!-- Watermark template (shared by all mod lists)             -->
        <!-- ──────────────────────────────────────────────────────── -->
        <ControlTemplate x:Key="WatermarkCustom" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="{helpers:Localization ModManager_DropHere}" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>

        <!-- ──────────────────────────────────────────────────────── -->
        <!-- Context menus                                            -->
        <!-- ──────────────────────────────────────────────────────── -->
        <ContextMenu x:Key="ModContextMenu">
            <MenuItem Header="Toggle Favorite" Click="MenuToggleFavorite_Click"/>
            <Separator/>
            <MenuItem Header="{helpers:Localization ModManager_CtxRename}"        Click="MenuRename_Click"/>
            <MenuItem Header="Set Group" Click="MenuSetGroup_Click"/>
            <MenuItem Header="Clear Group" Click="MenuClearGroup_Click"/>
            <MenuItem Header="{helpers:Localization ModManager_CtxSetLoadOrder}"  Click="MenuSetLoadOrder_Click" FontWeight="Bold"/>
            <MenuItem Header="{helpers:Localization ModManager_CtxToggle}"        Click="MenuToggle_Click"/>
            <Separator/>
            <MenuItem Header="{helpers:Localization ModManager_CtxOpenModFolder}"    Click="MenuOpenFolder_Click"/>
            <MenuItem Header="{helpers:Localization ModManager_CtxOpenGameFolder}"   Click="MenuOpenGameFolder_Click"/>
            <MenuItem Header="{helpers:Localization ModManager_CtxOpenBackupFolder}" Click="MenuOpenBackupFolder_Click"/>
            <Separator/>
            <MenuItem Header="{helpers:Localization ModManager_CtxMoveUp}"   Click="MenuMoveUp_Click"/>
            <MenuItem Header="{helpers:Localization ModManager_CtxMoveDown}" Click="MenuMoveDown_Click"/>
            <Separator/>
            <MenuItem Header="{helpers:Localization ModManager_CtxProperties}" Click="MenuProperties_Click" Foreground="{DynamicResource AccentBrush}"/>
            <MenuItem Header="{helpers:Localization ModManager_CtxDelete}"     Click="MenuDelete_Click" Foreground="#FF5555"/>
        </ContextMenu>

        <ContextMenu x:Key="EmptyListContextMenu">
                    <MenuItem Header="{helpers:Localization ModManager_CtxInstallMods}"   Click="BtnInstallModCustom_Click"/>
            <MenuItem Header="Import from game folder" Click="BtnImportFromGame_Click"/>
            <MenuItem Header="{helpers:Localization ModManager_CtxRefreshList}"   Click="BtnRefreshCustom_Click"/>
            <Separator/>
            <MenuItem Header="{helpers:Localization ModManager_CtxOpenGameFolder}"   Click="MenuOpenGameFolder_Click"/>
            <MenuItem Header="{helpers:Localization ModManager_CtxOpenBackupFolder}" Click="MenuOpenBackupFolder_Click"/>
            <MenuItem Header="{helpers:Localization ModManager_CtxOpenModsFolder}"   Click="MenuOpenModsFolder_Click"/>
        </ContextMenu>

        <!-- ──────────────────────────────────────────────────────── -->
        <!-- ListView style                                           -->
        <!-- ──────────────────────────────────────────────────────── -->
        <Style x:Key="ModListStyle" TargetType="ListView">
            <Setter Property="Background"         Value="Transparent"/>
            <Setter Property="Foreground"         Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness"    Value="0"/>
            <Setter Property="AllowDrop"          Value="True"/>
            <Setter Property="AlternationCount"   Value="2"/>
            <Setter Property="Template"           Value="{StaticResource WatermarkCustom}"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DashboardListItemStyle}">
                        <Setter Property="ContextMenu" Value="{StaticResource ModContextMenu}"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar link button -->
        <Style x:Key="SidebarLinkBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentLabelBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="4,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ============================================================ -->
    <!-- Root: workspace header on top, body below                   -->
    <!-- ============================================================ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- game header -->
            <RowDefinition Height="*"/>     <!-- body -->
        </Grid.RowDefinitions>

        <!-- Game workspace header (shared by real + placeholder games) -->
        <local:WorkspaceHeader x:Name="Cust_Header" Grid.Row="0"/>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- BODY                                                       -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- GAME PANEL: tabbed workspace (all games)              -->
            <!-- ══════════════════════════════════════════════════════ -->
            <Grid x:Name="panelCustom" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- sub-tab bar -->
                    <RowDefinition Height="*"/>     <!-- active tab content -->
                </Grid.RowDefinitions>

                <!-- ── Sub-tab bar ─────────────────────────────────── -->
                <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="16,0">
                    <DockPanel LastChildFill="True">
                        <!-- tabs -->
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Cust_TabMods" BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="0,0,0,2" Padding="4,12" Cursor="Hand"
                                    Tag="Mods" MouseLeftButtonUp="Tab_Click">
                                <TextBlock x:Name="Cust_TabModsText" Text="{helpers:Localization Workspace_Tab_Mods}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" Margin="6,0"/>
                            </Border>
                            <Border x:Name="Cust_TabConflicts" BorderThickness="0,0,0,2"
                                    BorderBrush="Transparent" Padding="4,12" Margin="14,0,0,0" Cursor="Hand"
                                    Tag="Conflicts" MouseLeftButtonUp="Tab_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="Cust_TabConflictsText" Text="{helpers:Localization Workspace_Tab_Conflicts}"
                                               FontSize="13" Foreground="{DynamicResource SubTextBrush}" Margin="6,0,4,0"/>
                                    <Border x:Name="Cust_TabConflictsBadge" Background="{DynamicResource ConflictRedBrush}"
                                            CornerRadius="8" Padding="5,0" VerticalAlignment="Center" Visibility="Collapsed">
                                        <TextBlock x:Name="Cust_TabConflictsBadgeText" Text="0" FontSize="10"
                                                   FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Border x:Name="Cust_TabBackups" BorderThickness="0,0,0,2"
                                    BorderBrush="Transparent" Padding="4,12" Margin="14,0,0,0" Cursor="Hand"
                                    Tag="Backups" MouseLeftButtonUp="Tab_Click">
                                <TextBlock x:Name="Cust_TabBackupsText" Text="{helpers:Localization Workspace_Tab_Backups}"
                                           FontSize="13" Foreground="{DynamicResource SubTextBrush}" Margin="6,0"/>
                            </Border>
                            <Border x:Name="Cust_TabDownloads" BorderThickness="0,0,0,2"
                                    BorderBrush="Transparent" Padding="4,12" Margin="14,0,0,0" Cursor="Hand"
                                    Tag="Downloads" MouseLeftButtonUp="Tab_Click">
                                <TextBlock x:Name="Cust_TabDownloadsText" Text="{helpers:Localization Workspace_Tab_Downloads}"
                                           FontSize="13" Foreground="{DynamicResource SubTextBrush}" Margin="6,0"/>
                            </Border>
                            <Border x:Name="Cust_TabConfig" BorderThickness="0,0,0,2"
                                    BorderBrush="Transparent" Padding="4,12" Margin="14,0,0,0" Cursor="Hand"
                                    Tag="Config" MouseLeftButtonUp="Tab_Click">
                                <TextBlock x:Name="Cust_TabConfigText" Text="{helpers:Localization Workspace_Tab_Config}"
                                           FontSize="13" Foreground="{DynamicResource SubTextBrush}" Margin="6,0"/>
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ── Tab content host ────────────────────────────── -->
                <Grid Grid.Row="1">

                    <!-- ════════ MODS TAB ════════ -->
                    <Grid x:Name="Cust_TabBodyMods">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Sidebar (right) -->
                        <Border x:Name="Cust_SidebarBorder" Grid.Column="1"
                                Background="{DynamicResource PanelBrush}" Width="220">
                            <DockPanel Margin="10">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock x:Name="Cust_txtSidebarGameName" Text=""
                                               Foreground="{DynamicResource AccentLabelBrush}"
                                               FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"
                                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,4"/>
                                    <!-- Folder path: button if not set, clickable text if set -->
                                    <Button x:Name="Cust_btnSidebarDir" Click="BtnBrowseGameFolder_Click"
                                            Background="Transparent" BorderThickness="0" Padding="4,3"
                                            Cursor="Hand" Margin="0,0,0,12"
                                            ToolTip="Click to set or change the game folder">
                                        <TextBlock x:Name="Cust_txtSidebarDir" Text="—"
                                                   Foreground="{DynamicResource SubTextBrush}" FontSize="9"
                                                   TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7"/>
                                    </Button>

                                    <!-- Integrity status (hidden when profile has no integrity configured) -->
                                    <Border x:Name="Cust_IntegrityBorder" Visibility="Collapsed"
                                            CornerRadius="4" Padding="8,5" Margin="6,0,6,10"
                                            Background="{DynamicResource ControlBgBrush}">
                                        <StackPanel>
                                            <TextBlock x:Name="Cust_txtIntegrityState" FontSize="10"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="Cust_txtIntegrityDetail" FontSize="9"
                                                       Foreground="{DynamicResource SubTextBrush}"
                                                       HorizontalAlignment="Center" TextAlignment="Center"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            <Button x:Name="Cust_btnIntegrityLearnMore" Content="Learn more →" Click="BtnIntegrityLearnMore_Click"
                                                    FontSize="9" Padding="0,3" Margin="0,4,0,0"
                                                    Background="Transparent" Foreground="{DynamicResource AccentBrush}"
                                                    BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.3" Margin="10,0,10,12"/>

                                    <TextBlock Text="{helpers:Localization ModManager_LINKS}" Foreground="{DynamicResource AccentLabelBrush}"
                                               FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <Button x:Name="Cust_btnNexus" Content="NexusMods" Click="BtnLink_Click"
                                            Tag="https://www.nexusmods.com"
                                            Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                            HorizontalAlignment="Stretch" Margin="0,2"/>
                                    <Button Content="GitHub" Click="BtnLink_Click"
                                            Tag="https://github.com"
                                            Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                            HorizontalAlignment="Stretch" Margin="0,2"/>

                                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.3" Margin="10,15"/>
                                </StackPanel>

                                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                                    <TextBlock x:Name="Cust_txtDiskSpace" Text="{helpers:Localization ModManager_Calculating}"
                                               Foreground="{DynamicResource SubTextBrush}" FontSize="11"
                                               TextAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Single-column workspace -->
                        <Grid Grid.Column="0" Margin="10,8,10,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Set folder banner -->
                            <Border x:Name="Cust_SetFolderBanner" Grid.Row="0"
                                    Background="{DynamicResource AccentBrush}" CornerRadius="5"
                                    Padding="12,8" Margin="0,0,0,8" Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               x:Name="Cust_txtSetFolderMsg"
                                               Text="{helpers:Localization ModManager_SetGameFolder}"
                                               Foreground="{DynamicResource AccentTextBrush}" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="{helpers:Localization ModManager_Browse}" Click="BtnBrowseGameFolder_Click"
                                            Margin="12,0,0,0" Padding="10,4"
                                            Foreground="{DynamicResource AccentTextBrush}"
                                            Background="Transparent" BorderThickness="1"
                                            BorderBrush="{DynamicResource AccentTextBrush}"
                                            FontSize="10" FontWeight="SemiBold"
                                            Cursor="Hand"/>
                                </Grid>
                            </Border>

                            <!-- Chips + search (unified filter bar) + bulk bar + mod list -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- unified filter bar -->
                                    <RowDefinition Height="Auto"/>  <!-- bulk-action bar -->
                                    <RowDefinition Height="*"/>     <!-- list + empty state -->
                                </Grid.RowDefinitions>

                                <!-- ── Unified filter bar: chips left, search right ─────── -->
                                <DockPanel Grid.Row="0" x:Name="Cust_FilterChips" Margin="0,0,0,6">
                                    <!-- Search (right-docked) -->
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Background="{DynamicResource ControlBgBrush}"
                                                CornerRadius="13" Padding="8,4">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                           Foreground="{DynamicResource SubTextBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                <TextBox x:Name="Cust_txtSearch"
                                                         Background="Transparent" BorderThickness="0"
                                                         Foreground="{DynamicResource TextBrush}"
                                                         FontSize="12" Width="160" Padding="0"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="TxtSearchCustom_TextChanged"/>
                                                <Button Content="&#x2715;" Margin="4,0,0,0"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource SubTextBrush}"
                                                        Cursor="Hand" Padding="2,0"
                                                        Click="BtnClearSearchCustom_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <!-- Filter chips -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- All -->
                                        <Border x:Name="Cust_ChipAll" CornerRadius="13" Padding="12,5" Margin="0,0,6,0"
                                                Background="{DynamicResource AccentBrush}" Cursor="Hand"
                                                MouseLeftButtonUp="ChipAll_Click">
                                            <TextBlock x:Name="Cust_ChipAllText" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="White"/>
                                        </Border>
                                        <!-- Enabled -->
                                        <Border x:Name="Cust_ChipEnabled" CornerRadius="13" Padding="12,5" Margin="0,0,6,0"
                                                Background="{DynamicResource ControlBgBrush}" Cursor="Hand"
                                                MouseLeftButtonUp="ChipEnabled_Click">
                                            <TextBlock x:Name="Cust_ChipEnabledText" FontSize="12"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </Border>
                                        <!-- Conflicts -->
                                        <Border x:Name="Cust_ChipConflicts" CornerRadius="13" Padding="12,5" Margin="0,0,6,0"
                                                Background="{DynamicResource ControlBgBrush}" Cursor="Hand"
                                                MouseLeftButtonUp="ChipConflicts_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="7" Height="7" Fill="{DynamicResource ConflictRedBrush}"
                                                         Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="Cust_ChipConflictsText" FontSize="12"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Favorites -->
                                        <Border x:Name="Cust_ChipFavorites" CornerRadius="13" Padding="12,5" Margin="0,0,6,0"
                                                Background="{DynamicResource ControlBgBrush}" Cursor="Hand"
                                                MouseLeftButtonUp="ChipFavorites_Click">
                                            <TextBlock x:Name="Cust_ChipFavoritesText" FontSize="12"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </DockPanel>

                                <!-- ── Bulk-action bar (hidden until multi-select) ──── -->
                                <Border x:Name="Cust_BulkBar" Grid.Row="1"
                                        Background="{DynamicResource AccentSoftBrush}" CornerRadius="6"
                                        Padding="12,7" Margin="0,0,0,6" Visibility="Collapsed">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Content="{helpers:Localization ModManager_Bulk_Enable}"
                                                    Click="BulkEnable_Click" Cursor="Hand"
                                                    Background="{DynamicResource ControlBgBrush}"
                                                    Foreground="{DynamicResource TextBrush}"
                                                    BorderThickness="0" Padding="10,4" Margin="0,0,6,0" FontSize="12"/>
                                            <Button Content="{helpers:Localization ModManager_Bulk_Disable}"
                                                    Click="BulkDisable_Click" Cursor="Hand"
                                                    Background="{DynamicResource ControlBgBrush}"
                                                    Foreground="{DynamicResource TextBrush}"
                                                    BorderThickness="0" Padding="10,4" Margin="0,0,6,0" FontSize="12"/>
                                            <Button Content="{helpers:Localization ModManager_Bulk_SetGroup}"
                                                    Click="BulkSetGroup_Click" Cursor="Hand"
                                                    Background="{DynamicResource ControlBgBrush}"
                                                    Foreground="{DynamicResource TextBrush}"
                                                    BorderThickness="0" Padding="10,4" Margin="0,0,6,0" FontSize="12"/>
                                            <Button Content="{helpers:Localization ModManager_Bulk_Remove}"
                                                    Click="BulkRemove_Click" Cursor="Hand"
                                                    Background="{DynamicResource ControlBgBrush}"
                                                    Foreground="{DynamicResource ConflictRedBrush}"
                                                    BorderThickness="0" Padding="10,4" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock x:Name="Cust_BulkSelLabel" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>

                                <!-- ── Mod list: sort header + list ────────────────── -->
                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Sort header bar -->
                                    <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}"
                                            Padding="6,4" Margin="0,0,0,2" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>   <!-- spine spacer -->
                                                <ColumnDefinition Width="38"/>  <!-- order -->
                                                <ColumnDefinition Width="32"/>  <!-- enabled spacer -->
                                                <ColumnDefinition Width="32"/>  <!-- star spacer -->
                                                <ColumnDefinition Width="*"/>   <!-- name -->
                                                <ColumnDefinition Width="Auto"/><!-- actions spacer -->
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="1" Cursor="Hand" MouseLeftButtonUp="SortHeader_Click" Tag="LoadOrder">
                                                <TextBlock x:Name="sortHdrOrder" Text="#" FontSize="10"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="4" Cursor="Hand" MouseLeftButtonUp="SortHeader_Click" Tag="Name" Padding="4,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="sortHdrName" Text="Name" FontSize="10"
                                                               Foreground="{DynamicResource SubTextBrush}"/>
                                                    <TextBlock x:Name="sortHdrArrow" Text="" FontSize="9" Margin="4,0,0,0"
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1">
                                    <ListView x:Name="Cust_ModList" Style="{StaticResource ModListStyle}"
                                              Template="{StaticResource WatermarkCustom}"
                                              SelectionMode="Extended"
                                              ContextMenu="{StaticResource EmptyListContextMenu}"
                                              Drop="Cust_List_Drop" DragOver="Cust_List_DragOver" DragLeave="Cust_List_DragLeave"
                                              PreviewMouseLeftButtonDown="Cust_List_PreviewMouseLeftButtonDown"
                                              MouseMove="Cust_List_MouseMove"
                                              KeyDown="Cust_List_KeyDown"
                                              SelectionChanged="Cust_ModList_SelectionChanged">
                                        <!-- Custom DataTemplate: spine · order · check · star · name/conflict · actions -->
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="rowBorder" CornerRadius="6" Margin="0,2"
                                                        Background="{DynamicResource PanelBrush}"
                                                        MinHeight="46">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="4"/>    <!-- category spine -->
                                                            <ColumnDefinition Width="38"/>   <!-- order -->
                                                            <ColumnDefinition Width="32"/>   <!-- checkbox -->
                                                            <ColumnDefinition Width="32"/>   <!-- star -->
                                                            <ColumnDefinition Width="*"/>    <!-- name + conflict detail -->
                                                            <ColumnDefinition Width="Auto"/> <!-- badge + hover actions -->
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Category colour spine -->
                                                        <Border Grid.Column="0" CornerRadius="6,0,0,6"
                                                                Background="{Binding Category, Converter={StaticResource CategorySpineBrushConverter}}"/>

                                                        <!-- Load order (double-click to edit) -->
                                                        <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock x:Name="orderDisplay"
                                                                       Text="{Binding LoadOrder}"
                                                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                       MouseLeftButtonDown="OrderDisplay_MouseDown"
                                                                       Cursor="IBeam"/>
                                                            <TextBox x:Name="orderEdit"
                                                                     Text="{Binding LoadOrder, Mode=OneWay}"
                                                                     FontSize="11" Foreground="{DynamicResource TextBrush}"
                                                                     Background="{DynamicResource ControlBgBrush}"
                                                                     BorderThickness="1" BorderBrush="{DynamicResource AccentBrush}"
                                                                     Padding="2,1" Width="32"
                                                                     Visibility="Collapsed"
                                                                     LostFocus="OrderEdit_LostFocus"
                                                                     KeyDown="OrderEdit_KeyDown"/>
                                                        </Grid>

                                                        <!-- Enable toggle -->
                                                        <CheckBox Grid.Column="2"
                                                                  IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                  Checked="ModCheckBox_Changed" Unchecked="ModCheckBox_Changed"
                                                                  VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                        <!-- Favorite star -->
                                                        <Button Grid.Column="3"
                                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                                Click="StarButton_Click" Tag="{Binding}"
                                                                ToolTip="Toggle favorite"
                                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                                       Text="{Binding IsFavorite, Converter={StaticResource StarGlyphConverter}}"
                                                                       Foreground="{Binding IsFavorite, Converter={StaticResource StarColorConverter}}"/>
                                                        </Button>

                                                        <!-- Name + optional conflict expansion -->
                                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="4,6,4,6">
                                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                                       Foreground="{DynamicResource TextBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <!-- Conflict detail panel (expanded) -->
                                                            <ItemsControl x:Name="conflictDetail"
                                                                          ItemsSource="{Binding ConflictSummary.Clashes}"
                                                                          Visibility="{Binding IsConflictExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                          Margin="0,4,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock FontSize="10.5" TextWrapping="Wrap"
                                                                                   Foreground="{DynamicResource SubTextBrush}"
                                                                                   Margin="0,1">
                                                                            <Run Text="{Binding Destination, Mode=OneWay}"
                                                                                 Foreground="{DynamicResource TextBrush}"/>
                                                                            <Run Text=" — winner: "/>
                                                                            <Run Text="{Binding WinnerModName, Mode=OneWay}"
                                                                                 Foreground="#50C878"/>
                                                                        </TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>

                                                        <!-- Right side: conflict badge + entry controls -->
                                                        <StackPanel Grid.Column="5" Orientation="Horizontal"
                                                                    VerticalAlignment="Center" Margin="0,0,4,0">
                                                            <!-- Conflict badge (click to toggle detail) -->
                                                            <Border Visibility="{Binding ConflictSummary, Converter={StaticResource ConflictBadgeVisibilityConverter}}"
                                                                    Background="{DynamicResource ConflictSoftBrush}"
                                                                    CornerRadius="9" Padding="8,3" Margin="0,0,6,0"
                                                                    Cursor="Hand" Tag="{Binding}"
                                                                    MouseLeftButtonUp="ConflictBadge_Click">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="10" Foreground="{DynamicResource ConflictRedBrush}"
                                                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                                    <TextBlock FontSize="10.5"
                                                                               Foreground="{DynamicResource ConflictRedBrush}"
                                                                               Text="{Binding ConflictSummary.Clashes.Count, StringFormat='{}{0} conflict(s)'}"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- Always-visible: up/down arrows -->
                                                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,4,0">
                                                                <Button Width="18" Height="14"
                                                                        Background="Transparent" BorderThickness="0"
                                                                        Cursor="Hand" ToolTip="Move up"
                                                                        Click="EntryMoveUp_Click" Tag="{Binding}" Padding="0">
                                                                    <TextBlock Text="&#xE70E;" FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="9" Foreground="{DynamicResource SubTextBrush}"/>
                                                                </Button>
                                                                <Button Width="18" Height="14"
                                                                        Background="Transparent" BorderThickness="0"
                                                                        Cursor="Hand" ToolTip="Move down"
                                                                        Click="EntryMoveDown_Click" Tag="{Binding}" Padding="0">
                                                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="9" Foreground="{DynamicResource SubTextBrush}"/>
                                                                </Button>
                                                            </StackPanel>

                                                            <!-- Hover actions: folder + properties -->
                                                            <StackPanel x:Name="hoverActions" Orientation="Horizontal"
                                                                        Opacity="0">
                                                                <StackPanel.Style>
                                                                    <Style TargetType="StackPanel">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                                                <Setter Property="Opacity" Value="1"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </StackPanel.Style>
                                                                <Button Width="26" Height="26" Margin="0,0,2,0"
                                                                        Background="Transparent" BorderThickness="0"
                                                                        Cursor="Hand" ToolTip="Open folder"
                                                                        Click="MenuOpenFolder_Click" Tag="{Binding}">
                                                                    <TextBlock Text="&#xE8DA;" FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="13" Foreground="{DynamicResource SubTextBrush}"/>
                                                                </Button>
                                                                <Button Width="26" Height="26"
                                                                        Background="Transparent" BorderThickness="0"
                                                                        Cursor="Hand" ToolTip="Properties"
                                                                        Click="MenuProperties_Click" Tag="{Binding}">
                                                                    <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets"
                                                                               FontSize="13" Foreground="{DynamicResource SubTextBrush}"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                        <ListView.GroupStyle>
                                            <GroupStyle>
                                                <GroupStyle.HeaderTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource HeaderBrush}" Padding="8,4" Margin="0,8,0,2">
                                                            <TextBlock Text="{Binding Name, Converter={StaticResource GroupNameDisplayConverter}}"
                                                                       Foreground="{DynamicResource AccentLabelBrush}"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </GroupStyle.HeaderTemplate>
                                            </GroupStyle>
                                        </ListView.GroupStyle>
                                    </ListView>
                                    <Canvas IsHitTestVisible="False">
                                        <Rectangle x:Name="Cust_DropLine" Height="2" Fill="{DynamicResource AccentBrush}"
                                                   Visibility="Collapsed" Width="400"/>
                                    </Canvas>

                                    <!-- Empty mod list state -->
                                    <Border x:Name="Cust_EmptyState"
                                            Background="{DynamicResource PanelBrush}"
                                            CornerRadius="5" Visibility="Collapsed"
                                            Panel.ZIndex="10">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="📦" FontSize="40" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{helpers:Localization ModManager_Empty_Title}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                            <TextBlock Text="{helpers:Localization ModManager_Empty_Subtitle}"
                                                       Foreground="{DynamicResource SubTextBrush}"
                                                       FontSize="11" HorizontalAlignment="Center"
                                                       TextAlignment="Center" TextWrapping="Wrap"
                                                       MaxWidth="280" Margin="0,0,0,20"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="{helpers:Localization ModManager_Install}"
                                                        Click="BtnInstallModCustom_Click"
                                                        Height="30" Padding="14,0" Margin="0,0,8,0"
                                                        Background="{DynamicResource AccentBrush}"
                                                        Foreground="Black" FontWeight="Bold"
                                                        FontSize="12" BorderThickness="0" Cursor="Hand"/>
                                                <Button Content="{helpers:Localization ModManager_Empty_Import}"
                                                        Click="BtnImportFromGame_Click"
                                                        Height="30" Padding="14,0"
                                                        Background="{DynamicResource ControlBgBrush}"
                                                        Foreground="{DynamicResource TextBrush}"
                                                        FontSize="12" BorderThickness="0" Cursor="Hand"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    </Grid><!-- closes Grid Grid.Row="1" wrapping ListView + empty state -->
                                </Grid><!-- closes outer sort Grid -->
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- ════════ CONFLICTS TAB ════════ -->
                    <Grid x:Name="Cust_TabBodyConflicts" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                            <StackPanel>
                                <TextBlock Text="{helpers:Localization Workspace_Conflicts_Title}"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{helpers:Localization Workspace_Conflicts_Subtitle}"
                                           FontSize="12" Foreground="{DynamicResource SubTextBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,14"/>
                                <StackPanel x:Name="Cust_ConflictsList"/>
                                <!-- Empty state -->
                                <Border x:Name="Cust_ConflictsEmpty" Margin="0,40,0,0" Visibility="Collapsed">
                                    <StackPanel HorizontalAlignment="Center" Opacity="0.6">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                                                   Foreground="#50C878"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{helpers:Localization Workspace_Conflicts_None}"
                                                   Foreground="{DynamicResource SubTextBrush}" FontSize="13"
                                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ════════ BACKUPS TAB ════════ -->
                    <ContentControl x:Name="Cust_BackupsHost" Visibility="Collapsed"/>

                    <!-- ════════ DOWNLOADS TAB ════════ -->
                    <Grid x:Name="Cust_TabBodyDownloads" Visibility="Collapsed">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBrush}" Padding="20,12">
                                <Grid>
                                    <TextBlock Text="{helpers:Localization ModManager_Downloads}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                    <Button Content="{helpers:Localization ModManager_Downloads_OpenFolder}"
                                            Click="BtnOpenDownloadFolder_Click"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            FontSize="11" Padding="10,5"
                                            Background="{DynamicResource ControlBgBrush}"
                                            Foreground="{DynamicResource TextBrush}"
                                            BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                            </Border>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                          Padding="16,10">
                                <StackPanel x:Name="Cust_DownloadsArchiveList"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Grid>

                    <!-- ════════ CONFIG TAB ════════ -->
                    <Grid x:Name="Cust_TabBodyConfig" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16">
                            <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                                <Grid Margin="0,0,0,14">
                                    <TextBlock Text="{helpers:Localization Workspace_Tab_Config}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                    <Button Content="Advanced Config →"
                                            Click="BtnEditConfigCustom_Click"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Background="{DynamicResource ControlBgBrush}"
                                            Foreground="{DynamicResource AccentBrush}"
                                            BorderThickness="0" Padding="14,6" FontSize="12" FontWeight="SemiBold"
                                            Cursor="Hand"/>
                                </Grid>

                                <!-- Quick path-setting control -->
                                <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Game Folder" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="Cust_ConfigPathDisplay" Text="—"
                                                       Foreground="{DynamicResource SubTextBrush}" FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Browse…"
                                                Click="BtnBrowseGameFolder_Click"
                                                Margin="12,0,0,0" Padding="12,6"
                                                Background="{DynamicResource AccentBrush}"
                                                Foreground="{DynamicResource AccentTextBrush}"
                                                BorderThickness="0" FontSize="11" FontWeight="SemiBold"
                                                Cursor="Hand" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="18,14">
                                    <StackPanel x:Name="Cust_ConfigSummary"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════ -->
            <!-- PLACEHOLDER: Game not yet supported                       -->
            <!-- ══════════════════════════════════════════════════════════ -->
            <Grid x:Name="panelPlaceholder" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5">
                    <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="64"
                               Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="Placeholder_txtName" Text="{helpers:Localization ModManager_ComingSoon}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                    <TextBlock Text="{helpers:Localization ModManager_NotSupported}"
                               FontSize="13" Foreground="{DynamicResource SubTextBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>
                </StackPanel>
            </Grid>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- Shared overlays (on top of all panels)                   -->
        <!-- ══════════════════════════════════════════════════════════ -->

        <!-- Dark backdrop during deploy -->
        <Grid x:Name="deployOverlay" Grid.RowSpan="2" Background="Black" Opacity="0.6"
              Visibility="Collapsed" Panel.ZIndex="100" IsHitTestVisible="True"/>

        <!-- Deploy progress card -->
        <Grid x:Name="deployProgressPanel" Grid.RowSpan="2" Visibility="Collapsed" Panel.ZIndex="101"
              HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="10"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2"
                    Padding="36,28" MinWidth="360">
                <StackPanel>
                    <TextBlock Text="{helpers:Localization ModManager_Deploying}" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <TextBlock x:Name="txtDeployStage" Text="{helpers:Localization ModManager_DeployPreparing}" FontSize="13"
                               Foreground="{DynamicResource SubTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <ProgressBar x:Name="pbDeploy" Height="9" Minimum="0" Maximum="100"
                                 IsIndeterminate="True" Margin="0,0,0,10"
                                 Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>
                    <TextBlock x:Name="txtDeployCount" Text="" FontSize="11"
                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
