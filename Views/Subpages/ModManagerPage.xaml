<UserControl x:Class="TMM.ModManagerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             Background="{DynamicResource BgBrush}">

    <UserControl.Resources>

        <!-- ──────────────────────────────────────────────────────── -->
        <!-- Watermark templates                                      -->
        <!-- ──────────────────────────────────────────────────────── -->
        <ControlTemplate x:Key="WatermarkIII" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="Drop III Mods Here" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bottom overrides Top  (0 loads first)" Foreground="{DynamicResource TextBrush}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>
        <ControlTemplate x:Key="WatermarkVC" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="Drop VC Mods Here" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bottom overrides Top  (0 loads first)" Foreground="{DynamicResource TextBrush}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>
        <ControlTemplate x:Key="WatermarkSA" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="Drop SA Mods Here" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bottom overrides Top  (0 loads first)" Foreground="{DynamicResource TextBrush}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>
        <ControlTemplate x:Key="WatermarkIV" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="Drop IV Mods Here" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>
        <ControlTemplate x:Key="WatermarkTLaD" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="Drop TLaD Mods Here" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>
        <ControlTemplate x:Key="WatermarkTBoGT" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="Drop TBoGT Mods Here" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>
        <ControlTemplate x:Key="WatermarkCustom" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="Drop Mods Here" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>

        <!-- ──────────────────────────────────────────────────────── -->
        <!-- Context menus                                            -->
        <!-- ──────────────────────────────────────────────────────── -->
        <ContextMenu x:Key="ModContextMenu">
            <MenuItem Header="Rename (F2)"            Click="MenuRename_Click"/>
            <MenuItem Header="Set Load Order..."      Click="MenuSetLoadOrder_Click" FontWeight="Bold"/>
            <MenuItem Header="Toggle Disable (Space)" Click="MenuToggle_Click"/>
            <Separator/>
            <MenuItem Header="Open Mod Folder"        Click="MenuOpenFolder_Click"/>
            <MenuItem Header="Open Game Folder"       Click="MenuOpenGameFolder_Click"/>
            <MenuItem Header="Open Backup Folder"     Click="MenuOpenBackupFolder_Click"/>
            <Separator/>
            <MenuItem Header="Move Up (Ctrl+Up)"      Click="MenuMoveUp_Click"/>
            <MenuItem Header="Move Down (Ctrl+Down)"  Click="MenuMoveDown_Click"/>
            <Separator/>
            <MenuItem Header="Properties..."          Click="MenuProperties_Click" Foreground="{DynamicResource AccentBrush}"/>
            <MenuItem Header="Delete Mod(s) (Del)"    Click="MenuDelete_Click" Foreground="#FF5555"/>
        </ContextMenu>

        <ContextMenu x:Key="EmptyListContextMenu">
            <MenuItem Header="Install Mod(s)..."   Click="BtnInstallMod_Click"/>
            <MenuItem Header="Refresh List"        Click="BtnRefresh_Click"/>
            <Separator/>
            <MenuItem Header="Open Game Folder"   Click="MenuOpenGameFolder_Click"/>
            <MenuItem Header="Open Backup Folder" Click="MenuOpenBackupFolder_Click"/>
            <MenuItem Header="Open Mods Folder"   Click="MenuOpenModsFolder_Click"/>
        </ContextMenu>

        <!-- ──────────────────────────────────────────────────────── -->
        <!-- ListView style                                           -->
        <!-- ──────────────────────────────────────────────────────── -->
        <Style x:Key="ModListStyle" TargetType="ListView">
            <Setter Property="Background"         Value="Transparent"/>
            <Setter Property="Foreground"         Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness"    Value="0"/>
            <Setter Property="AllowDrop"          Value="True"/>
            <Setter Property="AlternationCount"   Value="2"/>
            <Setter Property="Template"           Value="{StaticResource WatermarkCustom}"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DashboardListItemStyle}">
                        <Setter Property="ContextMenu" Value="{StaticResource ModContextMenu}"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ──────────────────────────────────────────────────────── -->
        <!-- Column action button (Deploy/Rollback per column)        -->
        <!-- ──────────────────────────────────────────────────────── -->
        <Style x:Key="ColActionBtn" TargetType="Button">
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar link button -->
        <Style x:Key="SidebarLinkBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentLabelBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="4,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ============================================================ -->
    <!-- Root: panels stacked, only one visible at a time            -->
    <!-- ============================================================ -->
    <Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- PANEL A: GTA III Series  (III / VC / SA)                 -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="panelIIISeries" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Opacity="0.98" Padding="8,6">
                <DockPanel LastChildFill="True">

                    <!-- Right: Deploy | Rollback | Play III | Play VC | Play SA -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button x:Name="III_btnDeploy" Click="BtnDeployIII_Click" ToolTip="Deploy All (F5)"
                                    Width="42" Height="42" Background="{DynamicResource AccentBrush}"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="20" Foreground="{DynamicResource AccentTextBrush}"/>
                            </Button>
                            <TextBlock Text="Deploy" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="4,0,0,0" VerticalAlignment="Center">
                            <Button Click="BtnRollbackIII_Click" ToolTip="Rollback Last Deploy"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="16" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Content="&#xE777;"/>
                            <TextBlock Text="Rollback" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="6,6,6,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button x:Name="III_btnPlayIII" Click="BtnLaunchIII_Click" Tag="III"
                                    ToolTip="Play GTA III" Width="42" Height="42" BorderThickness="0" Cursor="Hand"
                                    Background="{DynamicResource AccentBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="III" Foreground="{DynamicResource AccentTextBrush}"
                                           FontSize="14" FontWeight="Bold" FontFamily="Times New Roman"/>
                            </Button>
                            <TextBlock Text="Play III" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button x:Name="III_btnPlayVC" Click="BtnLaunchIII_Click" Tag="VC"
                                    ToolTip="Play GTA Vice City" Width="42" Height="42" BorderThickness="0" Cursor="Hand"
                                    Background="{DynamicResource AccentBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="VC" Foreground="{DynamicResource AccentTextBrush}"
                                           FontSize="13" FontWeight="Bold"/>
                            </Button>
                            <TextBlock Text="Play VC" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button x:Name="III_btnPlaySA" Click="BtnLaunchIII_Click" Tag="SA"
                                    ToolTip="Play GTA San Andreas" Width="42" Height="42" BorderThickness="0" Cursor="Hand"
                                    Background="{DynamicResource AccentBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="SA" Foreground="{DynamicResource AccentTextBrush}"
                                           FontSize="13" FontWeight="Bold"/>
                            </Button>
                            <TextBlock Text="Play SA" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Left: Back | Sidebar | Help | About -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE72B;" Click="BtnBack_Click" ToolTip="Back to Library"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="16" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Back" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="0,6,8,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE700;" Click="BtnToggleSidebarIII_Click" ToolTip="Toggle Sidebar"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="20" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Sidebar" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="0,6,8,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Click="BtnHelp_Click" ToolTip="Help" Width="38" Height="38"
                                    Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{DynamicResource ControlBgBrush}" CornerRadius="5">
                                            <TextBlock x:Name="glyph" Text="?" FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="glyph" Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBlock Text="Help" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,4,0">
                            <Button Content="&#xE946;" Click="BtnAbout_Click" ToolTip="About TMM"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="About" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Center: Install | Widescreen | SilentPatch | ASI | 2DFX | CLEO | Refresh | Files -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE710;" Click="BtnInstallMod_Click" ToolTip="Install Mod (Ctrl+O)"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Install" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="4,6,4,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Click="BtnWidescreen_Click" ToolTip="Install Widescreen Fix"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="10" Content="WS"/>
                            <TextBlock Text="Widescreen" FontSize="9" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Click="BtnSilentPatch_Click" ToolTip="Install SilentPatch"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="10" Content="SP"/>
                            <TextBlock Text="SilentPatch" FontSize="9" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Click="BtnASILoader_Click" ToolTip="Install ASI Loader"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="10" Content="ASI"/>
                            <TextBlock Text="ASI" FontSize="9" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Click="Btn2DFX_Click" ToolTip="Install Project2DFX"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="10" Content="2DFX"/>
                            <TextBlock Text="2DFX" FontSize="9" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Click="BtnCleo_Click" ToolTip="Install CLEO Library"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="10" Content="CLEO"/>
                            <TextBlock Text="CLEO" FontSize="9" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="4,6,4,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE72C;" Click="BtnRefresh_Click" ToolTip="Refresh Mod Lists"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Refresh" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE8B7;" Click="BtnOpenAppData_Click" ToolTip="Open Mod Directory"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Files" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- III Series Content: Sidebar + 3-column workspace -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- III Sidebar -->
                <Border x:Name="III_SidebarBorder" Grid.Column="0"
                        Background="{DynamicResource PanelBrush}" Width="220">
                    <DockPanel Margin="10">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="GAME PATHS" Foreground="{DynamicResource AccentLabelBrush}"
                                       FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"
                                       Margin="0,10,0,10"/>

                            <!-- GTA III path row -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="III_dotIII" Width="8" Height="8" Grid.Column="0" VerticalAlignment="Center">
                                    <Ellipse.Fill><SolidColorBrush Color="#A03C3C"/></Ellipse.Fill>
                                </Ellipse>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="GTA III" Foreground="{DynamicResource AccentLabelBrush}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="III_txtPathIII" Foreground="{DynamicResource SubTextBrush}"
                                               FontSize="9" TextTrimming="CharacterEllipsis" Opacity="0.7" Text="—"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="&#xE838;" ToolTip="Browse for GTA III directory"
                                        Style="{StaticResource IconButtonStyle}" FontSize="11" Padding="4,2"
                                        Click="BtnBrowseIII_Click" Tag="III"/>
                            </Grid>

                            <!-- VC path row -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="III_dotVC" Width="8" Height="8" Grid.Column="0" VerticalAlignment="Center">
                                    <Ellipse.Fill><SolidColorBrush Color="#A03C3C"/></Ellipse.Fill>
                                </Ellipse>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Vice City" Foreground="{DynamicResource AccentLabelBrush}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="III_txtPathVC" Foreground="{DynamicResource SubTextBrush}"
                                               FontSize="9" TextTrimming="CharacterEllipsis" Opacity="0.7" Text="—"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="&#xE838;" ToolTip="Browse for Vice City directory"
                                        Style="{StaticResource IconButtonStyle}" FontSize="11" Padding="4,2"
                                        Click="BtnBrowseIII_Click" Tag="VC"/>
                            </Grid>

                            <!-- SA path row -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="III_dotSA" Width="8" Height="8" Grid.Column="0" VerticalAlignment="Center">
                                    <Ellipse.Fill><SolidColorBrush Color="#A03C3C"/></Ellipse.Fill>
                                </Ellipse>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="San Andreas" Foreground="{DynamicResource AccentLabelBrush}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="III_txtPathSA" Foreground="{DynamicResource SubTextBrush}"
                                               FontSize="9" TextTrimming="CharacterEllipsis" Opacity="0.7" Text="—"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="&#xE838;" ToolTip="Browse for San Andreas directory"
                                        Style="{StaticResource IconButtonStyle}" FontSize="11" Padding="4,2"
                                        Click="BtnBrowseIII_Click" Tag="SA"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.3" Margin="10,12"/>

                            <TextBlock Text="III SERIES LINKS" Foreground="{DynamicResource AccentLabelBrush}"
                                       FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <Button Content="NexusMods — GTA III" Click="BtnLink_Click"
                                    Tag="https://www.nexusmods.com/gtaiii"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>
                            <Button Content="NexusMods — Vice City" Click="BtnLink_Click"
                                    Tag="https://www.nexusmods.com/gtavicecity"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>
                            <Button Content="NexusMods — San Andreas" Click="BtnLink_Click"
                                    Tag="https://www.nexusmods.com/gtasanandreas"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>
                            <Button Content="GTAForums" Click="BtnLink_Click"
                                    Tag="https://gtaforums.com"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>
                            <Button Content="SilentPatch (III/VC/SA)" Click="BtnLink_Click"
                                    Tag="https://cookieplmonster.github.io/mods/gta3/"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>

                            <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.3" Margin="10,15"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                            <TextBlock x:Name="III_txtDiskSpace" Text="Calculating space..."
                                       Foreground="{DynamicResource SubTextBrush}" FontSize="11"
                                       TextAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- III 3-column workspace -->
                <Grid Grid.Column="1" Margin="10">
                    <UniformGrid Columns="3">

                        <!-- ═══ GTA III column ═══ -->
                        <Border BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="1"
                                Margin="5" Background="{DynamicResource PanelBrush}" CornerRadius="5" Opacity="0.95">
                            <DockPanel Margin="5">
                                <TextBlock DockPanel.Dock="Top" Text="GTA III"
                                           Foreground="{DynamicResource AccentLabelBrush}"
                                           FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5"/>
                                <TextBox DockPanel.Dock="Top" x:Name="III_txtSearchIII" Height="25"
                                         Margin="5,0,5,5" Padding="5,3"
                                         Background="{DynamicResource ControlBgBrush}"
                                         Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                         TextChanged="TxtSearch_TextChanged" Tag="III" Opacity="0.9"/>
                                <Grid DockPanel.Dock="Bottom" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="III_btnDeployIII" Content="Deploy III" Grid.Column="0"
                                            Style="{StaticResource ColActionBtn}"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="{DynamicResource AccentTextBrush}"
                                            Click="BtnDeployCol_Click" Tag="III"/>
                                    <Button Content="&#xE777;" Grid.Column="1"
                                            ToolTip="Rollback III" Style="{StaticResource IconButtonStyle}"
                                            FontSize="12" Padding="6,0" Margin="3,0,0,0"
                                            Click="BtnRollbackCol_Click" Tag="III"/>
                                </Grid>
                                <Grid>
                                    <ListView x:Name="III_listIII" Style="{StaticResource ModListStyle}"
                                              Template="{StaticResource WatermarkIII}"
                                              SelectionMode="Extended" Tag="III"
                                              ContextMenu="{StaticResource EmptyListContextMenu}"
                                              Drop="List_Drop" DragOver="List_DragOver" DragLeave="List_DragLeave"
                                              PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                                              MouseMove="List_MouseMove" KeyDown="List_KeyDown"
                                              GotFocus="List_GotFocus">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="#"  Width="28" DisplayMemberBinding="{Binding LoadOrder}"/>
                                                <GridViewColumn Header="On" Width="28">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                      Checked="ModCheckBox_Changed" Unchecked="ModCheckBox_Changed"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Mod Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                                <GridViewColumn Header="Size" Width="60" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Canvas IsHitTestVisible="False">
                                        <Rectangle x:Name="III_DropLineIII" Height="2" Fill="{DynamicResource AccentBrush}"
                                                   Visibility="Collapsed" Width="300"/>
                                    </Canvas>
                                </Grid>
                            </DockPanel>
                        </Border>

                        <!-- ═══ Vice City column ═══ -->
                        <Border BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="1"
                                Margin="5" Background="{DynamicResource PanelBrush}" CornerRadius="5" Opacity="0.95">
                            <DockPanel Margin="5">
                                <TextBlock DockPanel.Dock="Top" Text="Vice City"
                                           Foreground="{DynamicResource AccentLabelBrush}"
                                           FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5"/>
                                <TextBox DockPanel.Dock="Top" x:Name="III_txtSearchVC" Height="25"
                                         Margin="5,0,5,5" Padding="5,3"
                                         Background="{DynamicResource ControlBgBrush}"
                                         Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                         TextChanged="TxtSearch_TextChanged" Tag="VC" Opacity="0.9"/>
                                <Grid DockPanel.Dock="Bottom" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="III_btnDeployVC" Content="Deploy VC" Grid.Column="0"
                                            Style="{StaticResource ColActionBtn}"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="{DynamicResource AccentTextBrush}"
                                            Click="BtnDeployCol_Click" Tag="VC"/>
                                    <Button Content="&#xE777;" Grid.Column="1"
                                            ToolTip="Rollback VC" Style="{StaticResource IconButtonStyle}"
                                            FontSize="12" Padding="6,0" Margin="3,0,0,0"
                                            Click="BtnRollbackCol_Click" Tag="VC"/>
                                </Grid>
                                <Grid>
                                    <ListView x:Name="III_listVC" Style="{StaticResource ModListStyle}"
                                              Template="{StaticResource WatermarkVC}"
                                              SelectionMode="Extended" Tag="VC"
                                              ContextMenu="{StaticResource EmptyListContextMenu}"
                                              Drop="List_Drop" DragOver="List_DragOver" DragLeave="List_DragLeave"
                                              PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                                              MouseMove="List_MouseMove" KeyDown="List_KeyDown"
                                              GotFocus="List_GotFocus">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="#"  Width="28" DisplayMemberBinding="{Binding LoadOrder}"/>
                                                <GridViewColumn Header="On" Width="28">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                      Checked="ModCheckBox_Changed" Unchecked="ModCheckBox_Changed"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Mod Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                                <GridViewColumn Header="Size" Width="60" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Canvas IsHitTestVisible="False">
                                        <Rectangle x:Name="III_DropLineVC" Height="2" Fill="{DynamicResource AccentBrush}"
                                                   Visibility="Collapsed" Width="300"/>
                                    </Canvas>
                                </Grid>
                            </DockPanel>
                        </Border>

                        <!-- ═══ San Andreas column ═══ -->
                        <Border BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="1"
                                Margin="5" Background="{DynamicResource PanelBrush}" CornerRadius="5" Opacity="0.95">
                            <DockPanel Margin="5">
                                <TextBlock DockPanel.Dock="Top" Text="San Andreas"
                                           Foreground="{DynamicResource AccentLabelBrush}"
                                           FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5"/>
                                <TextBox DockPanel.Dock="Top" x:Name="III_txtSearchSA" Height="25"
                                         Margin="5,0,5,5" Padding="5,3"
                                         Background="{DynamicResource ControlBgBrush}"
                                         Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                         TextChanged="TxtSearch_TextChanged" Tag="SA" Opacity="0.9"/>
                                <Grid DockPanel.Dock="Bottom" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="III_btnDeploySA" Content="Deploy SA" Grid.Column="0"
                                            Style="{StaticResource ColActionBtn}"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="{DynamicResource AccentTextBrush}"
                                            Click="BtnDeployCol_Click" Tag="SA"/>
                                    <Button Content="&#xE777;" Grid.Column="1"
                                            ToolTip="Rollback SA" Style="{StaticResource IconButtonStyle}"
                                            FontSize="12" Padding="6,0" Margin="3,0,0,0"
                                            Click="BtnRollbackCol_Click" Tag="SA"/>
                                </Grid>
                                <Grid>
                                    <ListView x:Name="III_listSA" Style="{StaticResource ModListStyle}"
                                              Template="{StaticResource WatermarkSA}"
                                              SelectionMode="Extended" Tag="SA"
                                              ContextMenu="{StaticResource EmptyListContextMenu}"
                                              Drop="List_Drop" DragOver="List_DragOver" DragLeave="List_DragLeave"
                                              PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                                              MouseMove="List_MouseMove" KeyDown="List_KeyDown"
                                              GotFocus="List_GotFocus">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="#"  Width="28" DisplayMemberBinding="{Binding LoadOrder}"/>
                                                <GridViewColumn Header="On" Width="28">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                      Checked="ModCheckBox_Changed" Unchecked="ModCheckBox_Changed"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Mod Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                                <GridViewColumn Header="Size" Width="60" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Canvas IsHitTestVisible="False">
                                        <Rectangle x:Name="III_DropLineSA" Height="2" Fill="{DynamicResource AccentBrush}"
                                                   Visibility="Collapsed" Width="300"/>
                                    </Canvas>
                                </Grid>
                            </DockPanel>
                        </Border>

                    </UniformGrid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- PANEL B: GTA IV Series  (IV / TLaD / TBoGT)             -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="panelIVSeries" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Opacity="0.98" Padding="8,6">
                <DockPanel LastChildFill="True">

                    <!-- Right: Deploy All | Rollback Active | Play IV | Play TLaD | Play TBoGT -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button x:Name="IV_btnDeployAll" Click="BtnDeployAllIV_Click" ToolTip="Deploy All Episodes (F5)"
                                    Width="42" Height="42" Background="{DynamicResource AccentBrush}"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="20" Foreground="{DynamicResource AccentTextBrush}"/>
                            </Button>
                            <TextBlock Text="Deploy All" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="4,0,0,0" VerticalAlignment="Center">
                            <Button Click="BtnRollbackActiveIV_Click" ToolTip="Rollback Active Episode"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="16" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Content="&#xE777;"/>
                            <TextBlock Text="Rollback" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="6,6,6,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button x:Name="IV_btnPlayIV" Click="BtnLaunchIV_Click" Tag="IV"
                                    ToolTip="Launch GTA IV" Width="42" Height="42" BorderThickness="0" Cursor="Hand"
                                    Background="{DynamicResource AccentBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="IV" Foreground="{DynamicResource AccentTextBrush}"
                                           FontSize="16" FontWeight="Bold"/>
                            </Button>
                            <TextBlock Text="Play IV" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button x:Name="IV_btnPlayTLaD" Click="BtnLaunchIV_Click" Tag="TLaD"
                                    ToolTip="Launch The Lost and Damned" Width="42" Height="42" BorderThickness="0" Cursor="Hand"
                                    Background="{DynamicResource AccentBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="TLaD" Foreground="{DynamicResource AccentTextBrush}"
                                           FontSize="12" FontWeight="Bold"/>
                            </Button>
                            <TextBlock Text="Play TLaD" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button x:Name="IV_btnPlayTBoGT" Click="BtnLaunchIV_Click" Tag="TBoGT"
                                    ToolTip="Launch The Ballad of Gay Tony" Width="42" Height="42" BorderThickness="0" Cursor="Hand"
                                    Background="{DynamicResource AccentBrush}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="TBoGT" Foreground="{DynamicResource AccentTextBrush}"
                                           FontSize="10" FontWeight="Bold"/>
                            </Button>
                            <TextBlock Text="Play TBoGT" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Left: Back | Sidebar | Help | About -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE72B;" Click="BtnBack_Click" ToolTip="Back to Library"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="16" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Back" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="0,6,8,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE700;" Click="BtnToggleSidebarIV_Click" ToolTip="Toggle Sidebar"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="20" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Sidebar" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="0,6,8,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Click="BtnHelp_Click" ToolTip="Help" Width="38" Height="38"
                                    Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{DynamicResource ControlBgBrush}" CornerRadius="5">
                                            <TextBlock x:Name="glyph" Text="?" FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="glyph" Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBlock Text="Help" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,4,0">
                            <Button Content="&#xE946;" Click="BtnAbout_Click" ToolTip="About TMM"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="About" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Center: Install | Refresh | Files -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE710;" Click="BtnInstallModIV_Click" ToolTip="Install Mod"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Install" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="4,6,4,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE72C;" Click="BtnRefreshIV_Click" ToolTip="Refresh Mod Lists"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Refresh" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE8B7;" Click="BtnOpenAppData_Click" ToolTip="Open Mod Directory"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Files" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- IV Series Content: Sidebar + 3-column workspace -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- IV Sidebar -->
                <Border x:Name="IV_SidebarBorder" Grid.Column="0"
                        Background="{DynamicResource PanelBrush}" Width="220">
                    <DockPanel Margin="10">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="EPISODES" Foreground="{DynamicResource AccentLabelBrush}"
                                       FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,10"/>

                            <!-- IV row -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="IV_dotIV" Width="8" Height="8" Grid.Column="0" VerticalAlignment="Center">
                                    <Ellipse.Fill><SolidColorBrush Color="#A03C3C"/></Ellipse.Fill>
                                </Ellipse>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="GTA IV" Foreground="{DynamicResource AccentLabelBrush}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="IV_txtPathIV" Foreground="{DynamicResource SubTextBrush}"
                                               FontSize="9" TextTrimming="CharacterEllipsis" Opacity="0.7" Text="—"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="&#xE838;" ToolTip="Browse for GTA IV directory"
                                        Style="{StaticResource IconButtonStyle}" FontSize="11" Padding="4,2"
                                        Click="BtnBrowseIV_Click" Tag="IV"/>
                            </Grid>

                            <!-- TLaD row -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="IV_dotTLaD" Width="8" Height="8" Grid.Column="0" VerticalAlignment="Center">
                                    <Ellipse.Fill><SolidColorBrush Color="#A03C3C"/></Ellipse.Fill>
                                </Ellipse>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="The Lost and Damned" Foreground="{DynamicResource AccentLabelBrush}"
                                               FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="IV_txtPathTLaD" Foreground="{DynamicResource SubTextBrush}"
                                               FontSize="9" TextTrimming="CharacterEllipsis" Opacity="0.7" Text="—"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="&#xE838;" ToolTip="Browse for TLaD directory"
                                        Style="{StaticResource IconButtonStyle}" FontSize="11" Padding="4,2"
                                        Click="BtnBrowseIV_Click" Tag="TLaD"/>
                            </Grid>

                            <!-- TBoGT row -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="IV_dotTBoGT" Width="8" Height="8" Grid.Column="0" VerticalAlignment="Center">
                                    <Ellipse.Fill><SolidColorBrush Color="#A03C3C"/></Ellipse.Fill>
                                </Ellipse>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="The Ballad of Gay Tony" Foreground="{DynamicResource AccentLabelBrush}"
                                               FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="IV_txtPathTBoGT" Foreground="{DynamicResource SubTextBrush}"
                                               FontSize="9" TextTrimming="CharacterEllipsis" Opacity="0.7" Text="—"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="&#xE838;" ToolTip="Browse for TBoGT directory"
                                        Style="{StaticResource IconButtonStyle}" FontSize="11" Padding="4,2"
                                        Click="BtnBrowseIV_Click" Tag="TBoGT"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.3" Margin="10,12"/>

                            <TextBlock Text="IV LINKS" Foreground="{DynamicResource AccentLabelBrush}"
                                       FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <Button Content="NexusMods — GTA IV" Click="BtnLink_Click"
                                    Tag="https://www.nexusmods.com/gta4"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>
                            <Button Content="GTAForums" Click="BtnLink_Click"
                                    Tag="https://gtaforums.com/forum/335-gtaiv/"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>
                            <Button Content="OpenIV" Click="BtnLink_Click"
                                    Tag="https://openiv.com"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>

                            <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.3" Margin="10,15"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                            <TextBlock x:Name="IV_txtDiskSpace" Text="Calculating space..."
                                       Foreground="{DynamicResource SubTextBrush}" FontSize="11"
                                       TextAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- IV 3-column workspace -->
                <Grid Grid.Column="1" Margin="10">
                    <UniformGrid Columns="3">

                        <!-- ═══ GTA IV column ═══ -->
                        <Border BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="1"
                                Margin="5" Background="{DynamicResource PanelBrush}" CornerRadius="5" Opacity="0.95">
                            <DockPanel Margin="5">
                                <TextBlock DockPanel.Dock="Top" Text="GTA IV"
                                           Foreground="{DynamicResource AccentLabelBrush}"
                                           FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5"/>
                                <TextBox DockPanel.Dock="Top" x:Name="IV_txtSearchIV" Height="25"
                                         Margin="5,0,5,5" Padding="5,3"
                                         Background="{DynamicResource ControlBgBrush}"
                                         Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                         TextChanged="TxtSearch_TextChanged" Tag="IV" Opacity="0.9"/>
                                <Grid DockPanel.Dock="Bottom" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="IV_btnDeployIV" Content="Deploy IV" Grid.Column="0"
                                            Style="{StaticResource ColActionBtn}"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="{DynamicResource AccentTextBrush}"
                                            Click="BtnDeployCol_Click" Tag="IV"/>
                                    <Button Content="&#xE777;" Grid.Column="1"
                                            ToolTip="Rollback IV" Style="{StaticResource IconButtonStyle}"
                                            FontSize="12" Padding="6,0" Margin="3,0,0,0"
                                            Click="BtnRollbackCol_Click" Tag="IV"/>
                                </Grid>
                                <Grid>
                                    <ListView x:Name="IV_listIV" Style="{StaticResource ModListStyle}"
                                              Template="{StaticResource WatermarkIV}"
                                              SelectionMode="Extended" Tag="IV"
                                              ContextMenu="{StaticResource EmptyListContextMenu}"
                                              Drop="List_Drop" DragOver="List_DragOver" DragLeave="List_DragLeave"
                                              PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                                              MouseMove="List_MouseMove" KeyDown="List_KeyDown"
                                              GotFocus="List_GotFocus">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="#"  Width="28" DisplayMemberBinding="{Binding LoadOrder}"/>
                                                <GridViewColumn Header="On" Width="28">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                      Checked="ModCheckBox_Changed" Unchecked="ModCheckBox_Changed"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Mod Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                                <GridViewColumn Header="Size" Width="60" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Canvas IsHitTestVisible="False">
                                        <Rectangle x:Name="IV_DropLineIV" Height="2" Fill="{DynamicResource AccentBrush}"
                                                   Visibility="Collapsed" Width="300"/>
                                    </Canvas>
                                </Grid>
                            </DockPanel>
                        </Border>

                        <!-- ═══ TLaD column ═══ -->
                        <Border BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="1"
                                Margin="5" Background="{DynamicResource PanelBrush}" CornerRadius="5" Opacity="0.95">
                            <DockPanel Margin="5">
                                <TextBlock DockPanel.Dock="Top" Text="The Lost and Damned"
                                           Foreground="{DynamicResource AccentLabelBrush}"
                                           FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,5"/>
                                <TextBox DockPanel.Dock="Top" x:Name="IV_txtSearchTLaD" Height="25"
                                         Margin="5,0,5,5" Padding="5,3"
                                         Background="{DynamicResource ControlBgBrush}"
                                         Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                         TextChanged="TxtSearch_TextChanged" Tag="TLaD" Opacity="0.9"/>
                                <Grid DockPanel.Dock="Bottom" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="IV_btnDeployTLaD" Content="Deploy TLaD" Grid.Column="0"
                                            Style="{StaticResource ColActionBtn}"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="{DynamicResource AccentTextBrush}"
                                            Click="BtnDeployCol_Click" Tag="TLaD"/>
                                    <Button Content="&#xE777;" Grid.Column="1"
                                            ToolTip="Rollback TLaD" Style="{StaticResource IconButtonStyle}"
                                            FontSize="12" Padding="6,0" Margin="3,0,0,0"
                                            Click="BtnRollbackCol_Click" Tag="TLaD"/>
                                </Grid>
                                <Grid>
                                    <ListView x:Name="IV_listTLaD" Style="{StaticResource ModListStyle}"
                                              Template="{StaticResource WatermarkTLaD}"
                                              SelectionMode="Extended" Tag="TLaD"
                                              ContextMenu="{StaticResource EmptyListContextMenu}"
                                              Drop="List_Drop" DragOver="List_DragOver" DragLeave="List_DragLeave"
                                              PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                                              MouseMove="List_MouseMove" KeyDown="List_KeyDown"
                                              GotFocus="List_GotFocus">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="#"  Width="28" DisplayMemberBinding="{Binding LoadOrder}"/>
                                                <GridViewColumn Header="On" Width="28">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                      Checked="ModCheckBox_Changed" Unchecked="ModCheckBox_Changed"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Mod Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                                <GridViewColumn Header="Size" Width="60" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Canvas IsHitTestVisible="False">
                                        <Rectangle x:Name="IV_DropLineTLaD" Height="2" Fill="{DynamicResource AccentBrush}"
                                                   Visibility="Collapsed" Width="300"/>
                                    </Canvas>
                                </Grid>
                            </DockPanel>
                        </Border>

                        <!-- ═══ TBoGT column ═══ -->
                        <Border BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="1"
                                Margin="5" Background="{DynamicResource PanelBrush}" CornerRadius="5" Opacity="0.95">
                            <DockPanel Margin="5">
                                <TextBlock DockPanel.Dock="Top" Text="The Ballad of Gay Tony"
                                           Foreground="{DynamicResource AccentLabelBrush}"
                                           FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,5"/>
                                <TextBox DockPanel.Dock="Top" x:Name="IV_txtSearchTBoGT" Height="25"
                                         Margin="5,0,5,5" Padding="5,3"
                                         Background="{DynamicResource ControlBgBrush}"
                                         Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                         TextChanged="TxtSearch_TextChanged" Tag="TBoGT" Opacity="0.9"/>
                                <Grid DockPanel.Dock="Bottom" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="IV_btnDeployTBoGT" Content="Deploy TBoGT" Grid.Column="0"
                                            Style="{StaticResource ColActionBtn}"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="{DynamicResource AccentTextBrush}"
                                            Click="BtnDeployCol_Click" Tag="TBoGT"/>
                                    <Button Content="&#xE777;" Grid.Column="1"
                                            ToolTip="Rollback TBoGT" Style="{StaticResource IconButtonStyle}"
                                            FontSize="12" Padding="6,0" Margin="3,0,0,0"
                                            Click="BtnRollbackCol_Click" Tag="TBoGT"/>
                                </Grid>
                                <Grid>
                                    <ListView x:Name="IV_listTBoGT" Style="{StaticResource ModListStyle}"
                                              Template="{StaticResource WatermarkTBoGT}"
                                              SelectionMode="Extended" Tag="TBoGT"
                                              ContextMenu="{StaticResource EmptyListContextMenu}"
                                              Drop="List_Drop" DragOver="List_DragOver" DragLeave="List_DragLeave"
                                              PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                                              MouseMove="List_MouseMove" KeyDown="List_KeyDown"
                                              GotFocus="List_GotFocus">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="#"  Width="28" DisplayMemberBinding="{Binding LoadOrder}"/>
                                                <GridViewColumn Header="On" Width="28">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                      Checked="ModCheckBox_Changed" Unchecked="ModCheckBox_Changed"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="Mod Name" Width="200" DisplayMemberBinding="{Binding Name}"/>
                                                <GridViewColumn Header="Size" Width="60" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                    <Canvas IsHitTestVisible="False">
                                        <Rectangle x:Name="IV_DropLineTBoGT" Height="2" Fill="{DynamicResource AccentBrush}"
                                                   Visibility="Collapsed" Width="300"/>
                                    </Canvas>
                                </Grid>
                            </DockPanel>
                        </Border>

                    </UniformGrid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- PANEL C: Custom Game  (single-column)                    -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="panelCustom" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Opacity="0.98" Padding="8,6">
                <DockPanel LastChildFill="True">

                    <!-- Right: Deploy | Rollback | Launch (conditional) -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button x:Name="Cust_btnDeploy" Click="BtnDeployCustom_Click" ToolTip="Deploy Mods (F5)"
                                    Width="42" Height="42" Background="{DynamicResource AccentBrush}"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#xE74B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="20" Foreground="{DynamicResource AccentTextBrush}"/>
                            </Button>
                            <TextBlock Text="Deploy" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="4,0,0,0" VerticalAlignment="Center">
                            <Button Click="BtnRollbackCustom_Click" ToolTip="Rollback Last Deploy"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="16" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Content="&#xE777;"/>
                            <TextBlock Text="Rollback" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel x:Name="Cust_pnlLaunch" Margin="4,0,0,0" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <Button Click="BtnLaunchCustom_Click" ToolTip="Launch Game"
                                    Width="42" Height="42" Background="{DynamicResource AccentBrush}"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#xE7B5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="20" Foreground="{DynamicResource AccentTextBrush}"/>
                            </Button>
                            <TextBlock Text="Play" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Left: Back | Sidebar | Help | About -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE72B;" Click="BtnBack_Click" ToolTip="Back to Library"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="16" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Back" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="0,6,8,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE700;" Click="BtnToggleSidebarCustom_Click" ToolTip="Toggle Sidebar"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="20" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Sidebar" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="0,6,8,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Click="BtnHelp_Click" ToolTip="Help" Width="38" Height="38"
                                    Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Background="{DynamicResource ControlBgBrush}" CornerRadius="5">
                                            <TextBlock x:Name="glyph" Text="?" FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="glyph" Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBlock Text="Help" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,4,0">
                            <Button Content="&#xE946;" Click="BtnAbout_Click" ToolTip="About TMM"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="About" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Center: Install | Edit Config | Refresh | Files -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE710;" Click="BtnInstallModCustom_Click" ToolTip="Install Mod"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Install" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE70F;" Click="BtnEditConfigCustom_Click" ToolTip="Edit game configuration"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Edit Config" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="4,6,4,6" Opacity="0.3"/>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE72C;" Click="BtnRefreshCustom_Click" ToolTip="Refresh Mod List"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Refresh" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                            <Button Content="&#xE8B7;" Click="BtnOpenAppData_Click" ToolTip="Open Mod Directory"
                                    Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                    FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                            <TextBlock Text="Files" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                </DockPanel>
            </Border>

            <!-- Custom Content: Sidebar + single-column workspace -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Custom Sidebar -->
                <Border x:Name="Cust_SidebarBorder" Grid.Column="0"
                        Background="{DynamicResource PanelBrush}" Width="220">
                    <DockPanel Margin="10">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock x:Name="Cust_txtSidebarGameName" Text="Custom Game"
                                       Foreground="{DynamicResource AccentLabelBrush}"
                                       FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,4"/>
                            <TextBlock x:Name="Cust_txtSidebarDir" Text="—"
                                       Foreground="{DynamicResource SubTextBrush}" FontSize="9"
                                       TextWrapping="Wrap" TextAlignment="Center" Opacity="0.7" Margin="0,0,0,12"/>

                            <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.3" Margin="10,0,10,12"/>

                            <TextBlock Text="LINKS" Foreground="{DynamicResource AccentLabelBrush}"
                                       FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <Button Content="NexusMods" Click="BtnLink_Click"
                                    Tag="https://www.nexusmods.com"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>
                            <Button Content="ModDB" Click="BtnLink_Click"
                                    Tag="https://www.moddb.com"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>
                            <Button Content="GitHub" Click="BtnLink_Click"
                                    Tag="https://github.com"
                                    Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                    HorizontalAlignment="Stretch" Margin="0,2"/>

                            <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.3" Margin="10,15"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                            <TextBlock x:Name="Cust_txtDiskSpace" Text="Calculating space..."
                                       Foreground="{DynamicResource SubTextBrush}" FontSize="11"
                                       TextAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Custom single-column workspace -->
                <Grid Grid.Column="1" Margin="10,8,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="Cust_txtSearch" Grid.Column="0"
                                 Background="{DynamicResource ControlBgBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1"
                                 Padding="8,4" FontSize="12"
                                 TextChanged="TxtSearchCustom_TextChanged"/>
                        <Button Grid.Column="1" Content="&#x2715;" Margin="4,0,0,0"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource SubTextBrush}"
                                Cursor="Hand" Padding="6,4"
                                Click="BtnClearSearchCustom_Click"/>
                    </Grid>

                    <!-- Mod ListView -->
                    <Grid Grid.Row="1">
                        <ListView x:Name="Cust_ModList" Style="{StaticResource ModListStyle}"
                                  Template="{StaticResource WatermarkCustom}"
                                  SelectionMode="Extended"
                                  ContextMenu="{StaticResource EmptyListContextMenu}"
                                  Drop="Cust_List_Drop" DragOver="Cust_List_DragOver" DragLeave="Cust_List_DragLeave"
                                  PreviewMouseLeftButtonDown="Cust_List_PreviewMouseLeftButtonDown"
                                  MouseMove="Cust_List_MouseMove"
                                  KeyDown="Cust_List_KeyDown"
                                  GotFocus="List_GotFocus">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Order" Width="50" DisplayMemberBinding="{Binding LoadOrder}"/>
                                    <GridViewColumn Header="" Width="28">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                          Checked="ModCheckBox_Changed" Unchecked="ModCheckBox_Changed"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Mod Name" Width="340" DisplayMemberBinding="{Binding Name}"/>
                                    <GridViewColumn Header="Size" Width="80" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                    <GridViewColumn Header="Status" Width="90">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <Canvas IsHitTestVisible="False">
                            <Rectangle x:Name="Cust_DropLine" Height="2" Fill="{DynamicResource AccentBrush}"
                                       Visibility="Collapsed" Width="400"/>
                        </Canvas>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- PANEL D: Placeholder / Coming Soon                       -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Grid x:Name="panelPlaceholder" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Minimal toolbar with Back only -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Opacity="0.98" Padding="8,6">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                        <Button Content="&#xE72B;" Click="BtnBack_Click" ToolTip="Back to Library"
                                Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                FontSize="16" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                        <TextBlock Text="Back" FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Coming Soon content -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5">
                <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="64"
                           Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="Placeholder_txtName" Text="Coming Soon" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                <TextBlock Text="Mod management support for this game is not yet available."
                           FontSize="13" Foreground="{DynamicResource SubTextBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400"/>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- Shared overlays (on top of all panels)                   -->
        <!-- ══════════════════════════════════════════════════════════ -->

        <!-- Dark backdrop during deploy -->
        <Grid x:Name="deployOverlay" Background="Black" Opacity="0.6"
              Visibility="Collapsed" Panel.ZIndex="100" IsHitTestVisible="True"/>

        <!-- Deploy progress card -->
        <Grid x:Name="deployProgressPanel" Visibility="Collapsed" Panel.ZIndex="101"
              HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Background="{DynamicResource PanelBrush}" CornerRadius="10"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2"
                    Padding="36,28" MinWidth="360">
                <StackPanel>
                    <TextBlock Text="Deploying Mods" FontSize="17" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <TextBlock x:Name="txtDeployStage" Text="Preparing..." FontSize="13"
                               Foreground="{DynamicResource SubTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <ProgressBar x:Name="pbDeploy" Height="9" Minimum="0" Maximum="100"
                                 IsIndeterminate="True" Margin="0,0,0,10"
                                 Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>
                    <TextBlock x:Name="txtDeployCount" Text="" FontSize="11"
                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Notification toasts -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Margin="0,0,16,16" Width="360" Panel.ZIndex="99" IsHitTestVisible="False">
            <ItemsControl ItemsSource="{Binding Source={x:Static local:NotificationService.Queue}}"
                          IsHitTestVisible="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="6"
                                BorderThickness="1" BorderBrush="{DynamicResource AccentBrush}"
                                Padding="12,10" Margin="0,0,0,8" MinHeight="40"
                                IsHitTestVisible="True" MouseLeftButtonUp="Toast_Close">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Type, Converter={StaticResource NotificationTypeIconConverter}}"
                                           FontSize="14" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AccentLabelBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Message}"
                                           Foreground="{DynamicResource TextBrush}" FontSize="12"
                                           TextWrapping="Wrap" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Button Grid.Column="2" Content="x" Width="20" Height="20"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{DynamicResource SubTextBrush}" FontSize="10"
                                        Click="Toast_CloseBtn" Cursor="Hand"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

    </Grid>
</UserControl>
