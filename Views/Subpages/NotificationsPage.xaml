<UserControl x:Class="TMM.NotificationsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             xmlns:helpers="clr-namespace:TMM.Helpers"
             Background="{DynamicResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header row: title + filter + clear -->
        <Grid Grid.Row="0" Margin="28,24,28,12">
            <TextBlock Text="{helpers:Localization Notifications_Title}" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ComboBox x:Name="cmbFilter" Width="130" Height="28" Margin="0,0,8,0"
                          SelectedIndex="0" SelectionChanged="CmbFilter_SelectionChanged"
                          Background="{DynamicResource ControlBgBrush}"
                          Foreground="{DynamicResource TextBrush}"
                          BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1">
                    <ComboBoxItem Tag="" Content="{helpers:Localization Notifications_FilterAll}"/>
                    <ComboBoxItem Tag="Info"    Content="Info"/>
                    <ComboBoxItem Tag="Success" Content="Success"/>
                    <ComboBoxItem Tag="Warning" Content="Warning"/>
                    <ComboBoxItem Tag="Error"   Content="Error"/>
                </ComboBox>
                <Button x:Name="btnClearHistory" Content="{helpers:Localization Notifications_ClearHistory}"
                        Height="28" Padding="12,0" Click="BtnClearHistory_Click"
                        Background="{DynamicResource ControlBgBrush}"
                        Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- Content area: list or empty state -->
        <Grid Grid.Row="1">

            <!-- Notification rows -->
            <ScrollViewer x:Name="notifScrollViewer" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="notifList" Margin="28,0,28,28">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:NotificationItem}">
                            <Border BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="0,0,0,1"
                                    Padding="4,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>   <!-- level icon -->
                                        <ColumnDefinition Width="*"/>    <!-- message + source -->
                                        <ColumnDefinition Width="Auto"/> <!-- timestamp -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Level icon (Segoe MDL2 glyph + color via DataTriggers) -->
                                    <TextBlock Grid.Column="0"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="14" VerticalAlignment="Top" Margin="0,1,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="&#xE946;"/>
                                                <Setter Property="Foreground" Value="#409CFF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static local:NotificationType.Success}">
                                                        <Setter Property="Text"       Value="&#xE73E;"/>
                                                        <Setter Property="Foreground" Value="#5CBB5C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static local:NotificationType.Warning}">
                                                        <Setter Property="Text"       Value="&#xE7BA;"/>
                                                        <Setter Property="Foreground" Value="#FFAA00"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="{x:Static local:NotificationType.Error}">
                                                        <Setter Property="Text"       Value="&#xE711;"/>
                                                        <Setter Property="Foreground" Value="#FF5555"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Message + source -->
                                    <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                        <TextBlock Text="{Binding Message}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Source}"
                                                   Foreground="{DynamicResource SubTextBrush}"
                                                   FontSize="10" Margin="0,2,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Source}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Timestamp (local) -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding LocalTimeDisplay}"
                                               Foreground="{DynamicResource SubTextBrush}"
                                               FontSize="10" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel x:Name="emptyState" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{helpers:Localization Notifications_Empty_Title}"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource SubTextBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="{helpers:Localization Notifications_Empty_Subtitle}"
                           FontSize="12" Foreground="{DynamicResource SubTextBrush}"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           MaxWidth="360" TextWrapping="Wrap"/>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
