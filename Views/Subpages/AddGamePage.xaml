<UserControl x:Class="TMM.AddGamePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             Background="{DynamicResource BgBrush}">

    <UserControl.Resources>
        <Style x:Key="JumpRailBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"         Value="0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="8,5">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionDivider" TargetType="Border">
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Opacity"         Value="0.15"/>
            <Setter Property="Margin"          Value="0,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    <!-- jump-rail + scroll -->
            <RowDefinition Height="Auto"/> <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- CONTENT AREA                                                -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="96"/>  <!-- jump-rail -->
                <ColumnDefinition Width="*"/>   <!-- scrolling form -->
            </Grid.ColumnDefinitions>

            <!-- Jump-rail -->
            <Border Grid.Column="0" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="0,0,1,0"
                    Opacity="0.8">
                <StackPanel Margin="6,16,6,16">
                    <!-- Essentials -->
                    <Button Style="{StaticResource JumpRailBtnStyle}"
                            Click="JumpToEssentials_Click" ToolTip="Jump to Essentials">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="dotEssentials" Width="8" Height="8"
                                     Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text="Essentials" FontSize="11"
                                       Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </Button>

                    <!-- Mod Types -->
                    <Button Style="{StaticResource JumpRailBtnStyle}"
                            Click="JumpToModTypes_Click" ToolTip="Jump to Mod Types">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource SubTextBrush}" Opacity="0.4"/>
                            <TextBlock Text="Mod Types" FontSize="11"
                                       Foreground="{DynamicResource SubTextBrush}"/>
                        </StackPanel>
                    </Button>

                    <!-- Routing -->
                    <Button Style="{StaticResource JumpRailBtnStyle}"
                            Click="JumpToRouting_Click" ToolTip="Jump to Routing Rules">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource SubTextBrush}" Opacity="0.4"/>
                            <TextBlock Text="Routing" FontSize="11"
                                       Foreground="{DynamicResource SubTextBrush}"/>
                        </StackPanel>
                    </Button>

                    <!-- Review -->
                    <Button Style="{StaticResource JumpRailBtnStyle}"
                            Click="JumpToReview_Click" ToolTip="Jump to Review (refreshes summary)">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource SubTextBrush}" Opacity="0.4"/>
                            <TextBlock Text="Review" FontSize="11"
                                       Foreground="{DynamicResource SubTextBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Scrolling form -->
            <ScrollViewer Grid.Column="1" x:Name="formScroller"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- ── Page header ── -->
                    <Border Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="0,0,0,1"
                            Padding="28,18" Opacity="0.9">
                        <Grid>
                            <StackPanel>
                                <TextBlock x:Name="txtPageMode" Text="Add a Game"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock x:Name="txtEditLabel" Text=""
                                           FontSize="12" Foreground="{DynamicResource SubTextBrush}"
                                           Margin="0,4,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── ESSENTIALS section ── -->
                    <Border x:Name="sectionEssentials" Padding="28,20,28,8">
                        <StackPanel>
                            <TextBlock Text="ESSENTIALS" Style="{StaticResource SectionHeader}"/>
                            <local:Step1_GameDetailsPage x:Name="_step1"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionDivider}" Margin="28,0"/>

                    <!-- ── MOD TYPES section ── -->
                    <Border x:Name="sectionModTypes" Padding="28,20,28,8">
                        <StackPanel>
                            <TextBlock Text="MOD TYPES" Style="{StaticResource SectionHeader}"/>
                            <local:Step2_ModTypesPage x:Name="_step2"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionDivider}" Margin="28,0"/>

                    <!-- ── ROUTING RULES section ── -->
                    <Border x:Name="sectionRouting" Padding="28,20,28,8">
                        <StackPanel>
                            <TextBlock Text="ROUTING RULES" Style="{StaticResource SectionHeader}"/>
                            <local:Step3_RoutingRulesPage x:Name="_step3"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionDivider}" Margin="28,0"/>

                    <!-- ── REVIEW section ── -->
                    <Border x:Name="sectionReview" Padding="28,20,28,24">
                        <StackPanel>
                            <TextBlock Text="REVIEW" Style="{StaticResource SectionHeader}"/>
                            <local:Step4_ReviewPage x:Name="_step4"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- FOOTER                                                       -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <TextBlock x:Name="txtLiveSummary" FontSize="12"
                           Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="btnCancel" Content="Cancel"
                            Height="32" Width="80" Margin="0,0,8,0"
                            Background="{DynamicResource ControlBgBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="btnCreate" Content="Create"
                            Height="32" Width="96" IsEnabled="False"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource AccentTextBrush}"
                            BorderThickness="0" Cursor="Hand"
                            Click="BtnCreate_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>
