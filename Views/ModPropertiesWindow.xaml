<Window x:Class="TMM.ModPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mod Properties" Height="460" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}" WindowStyle="None" AllowsTransparency="True">
    <Border BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#1A000000">
                <TextBlock Text="Mod Properties" Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="45" VerticalAlignment="Stretch" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,10,0,0">
                                <TextBlock Text="x" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="16,12,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Foreground="{DynamicResource SubTextBrush}" Margin="0,4,12,4" FontSize="12"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Status:" Foreground="{DynamicResource SubTextBrush}" Margin="0,4,12,4" FontSize="12"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Load Order:" Foreground="{DynamicResource SubTextBrush}" Margin="0,4,12,4" FontSize="12"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Archive Source:" Foreground="{DynamicResource SubTextBrush}" Margin="0,4,12,4" FontSize="12"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Extract Folder:" Foreground="{DynamicResource SubTextBrush}" Margin="0,4,12,4" FontSize="12"/>

                    <TextBox x:Name="txtName"   Grid.Row="0" Grid.Column="1" Background="{DynamicResource ControlBgBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" IsReadOnly="True" Margin="0,2" FontSize="12" Padding="4,2"/>
                    <TextBox x:Name="txtStatus" Grid.Row="1" Grid.Column="1" Background="{DynamicResource ControlBgBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" IsReadOnly="True" Margin="0,2" FontSize="12" Padding="4,2"/>
                    <TextBox x:Name="txtOrder"  Grid.Row="2" Grid.Column="1" Background="{DynamicResource ControlBgBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" IsReadOnly="True" Margin="0,2" FontSize="12" Padding="4,2"/>
                    <TextBox x:Name="txtSource" Grid.Row="3" Grid.Column="1" Background="{DynamicResource ControlBgBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" IsReadOnly="True" Margin="0,2" FontSize="12" Padding="4,2"/>
                    <TextBox x:Name="txtFolder" Grid.Row="4" Grid.Column="1" Background="{DynamicResource ControlBgBrush}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" IsReadOnly="True" Margin="0,2" FontSize="12" Padding="4,2"/>
                </Grid>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="Folder Contents:" Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                    <TreeView x:Name="treeFiles" Background="{DynamicResource ControlBgBrush}"
                              Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                              MinHeight="100" MaxHeight="160"/>
                </StackPanel>
            </Grid>

            <!-- Bottom close -->
            <Border Grid.Row="2" Padding="16,10" Background="#0A000000">
                <Button Content="Close" Click="BtnClose_Click" Height="28"
                        Background="{DynamicResource AccentBrush}" Foreground="Black"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </Border>
        </Grid>
    </Border>
</Window>
