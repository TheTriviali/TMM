<Window x:Class="TMM.CustomGameConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Custom Game"
        Height="800" Width="800"
        MinHeight="620" MinWidth="580"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
            <Setter Property="Foreground"  Value="{DynamicResource SubTextBrush}"/>
        </Style>

        <Style x:Key="FieldBoxStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="Margin"          Value="0,0,0,12"/>
            <Setter Property="FontSize"        Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BrowseBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="6,0,0,12"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <Style x:Key="CancelBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <Style x:Key="SaveBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <!-- Inline TextBox that sits inside a sentence — accent-colored, underline-only border -->
        <Style x:Key="SentenceBoxStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"         Value="4,1"/>
            <Setter Property="Margin"          Value="3,0"/>
            <Setter Property="FontFamily"      Value="Consolas, Courier New"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid cell/row/header shared styles -->
        <Style x:Key="DgCellStyle" TargetType="DataGridCell">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"    Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding"       Value="6,3"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3D3D3D"/>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected"  Value="True">  <Setter Property="Background" Value="#3D3D3D"/></Trigger>
                <Trigger Property="IsMouseOver" Value="True">  <Setter Property="Background" Value="#1AFFFFFF"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="#22FFFFFF"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource AccentBrush}">
        <Border.Background><SolidColorBrush Color="#1C1C1E"/></Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" Background="{DynamicResource HeaderBrush}" MouseDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock x:Name="txtWindowTitle" Text="Add Custom Game"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
                <Button Content="&#xE8BB;" HorizontalAlignment="Right"
                        Width="40" Height="34" BorderThickness="0"
                        Background="Transparent" Foreground="{DynamicResource SubTextBrush}"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,16,22,0">
                <StackPanel>

                    <!-- Info banner -->
                    <Border Background="#1A0883FF" BorderBrush="#330883FF" BorderThickness="1"
                            CornerRadius="5" Padding="10,8" Margin="0,0,0,16">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#88BBFF"
                                   Text="TMM copies mods from its internal storage into your game directory at deploy time. Keep a backup of your original game folder. File routing below tells TMM where each file type should land — if unsure, leave everything as . (game root)."/>
                    </Border>

                    <!-- ── Basic info ───────────────────────────────────────────── -->
                    <TextBlock Text="Game Name *" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="txtGameName" Style="{StaticResource FieldBoxStyle}"/>

                    <TextBlock Text="Game Directory *" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtGameDir" Grid.Column="0"
                                 Style="{StaticResource FieldBoxStyle}" Margin="0"
                                 ToolTip="The root folder of your game installation"/>
                        <Button Grid.Column="1" Content="Browse..."
                                Style="{StaticResource BrowseBtnStyle}"
                                Click="BtnBrowseDir_Click"/>
                    </Grid>

                    <TextBlock Text="Game Executable (optional)" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Opacity="0.6" Margin="0,-2,0,4"
                               Foreground="{DynamicResource SubTextBrush}"
                               Text="Relative to game directory, e.g.  hl2.exe  or  bin\launcher.exe"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtExePath" Grid.Column="0"
                                 Style="{StaticResource FieldBoxStyle}" Margin="0"/>
                        <Button Grid.Column="1" Content="Browse..."
                                Style="{StaticResource BrowseBtnStyle}"
                                Click="BtnBrowseExe_Click"/>
                    </Grid>

                    <TextBlock Text="Supported Mod File Types *" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Opacity="0.6" Margin="0,-2,0,4"
                               Foreground="{DynamicResource SubTextBrush}"
                               Text="Comma-separated extensions. Archives (.zip .rar .7z) are extracted automatically."/>
                    <TextBox x:Name="txtFileTypes" Style="{StaticResource FieldBoxStyle}"/>

                    <TextBlock Text="Steam App ID (optional)" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Opacity="0.6" Margin="0,-2,0,4"
                               Foreground="{DynamicResource SubTextBrush}"
                               Text="Numeric Steam ID for Launch via Steam (e.g. 12210 for GTA IV). Leave empty to launch the exe directly."/>
                    <TextBox x:Name="txtSteamAppId" Style="{StaticResource FieldBoxStyle}"/>

                    <!-- ── Output Directory Mapping ─────────────────────────────── -->
                    <TextBlock Text="Output Directory Mapping" Style="{StaticResource FieldLabelStyle}" Margin="0,6,0,4"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Opacity="0.6" Margin="0,-2,0,8"
                               Foreground="{DynamicResource SubTextBrush}"
                               Text="Which subfolder each file type lands in on deploy. Use  .  for the game root.  Example: .vpk → custom"/>

                    <Border Background="{DynamicResource ControlBgBrush}" CornerRadius="4"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1" Margin="0,0,0,4">
                        <DataGrid x:Name="dgMappings"
                                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserSortColumns="False" CanUserResizeRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0" BorderThickness="0"
                                  Background="Transparent" RowBackground="Transparent"
                                  AlternatingRowBackground="#0DFFFFFF"
                                  Foreground="{DynamicResource TextBrush}"
                                  HorizontalGridLinesBrush="#1AFFFFFF"
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  CellStyle="{StaticResource DgCellStyle}"
                                  RowStyle="{StaticResource DgRowStyle}"
                                  MinHeight="64" MaxHeight="140">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource DgHeaderStyle}"/>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Extension" Width="130"
                                                    Binding="{Binding Extension, UpdateSourceTrigger=LostFocus}">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding"     Value="6,3"/>
                                            <Setter Property="FontFamily"  Value="Consolas, Courier New"/>
                                            <Setter Property="FontSize"    Value="12"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Output Folder  (. = game root)" Width="*"
                                                    Binding="{Binding OutputFolder, UpdateSourceTrigger=LostFocus}">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding"     Value="6,3"/>
                                            <Setter Property="FontFamily"  Value="Consolas, Courier New"/>
                                            <Setter Property="FontSize"    Value="12"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Button Content="+ Add Row"          Click="BtnAddMapping_Click"
                                Style="{StaticResource BrowseBtnStyle}" Margin="0,0,8,0" Padding="8,4"/>
                        <Button Content="&#x2212; Remove Selected" Click="BtnRemoveMapping_Click"
                                Style="{StaticResource BrowseBtnStyle}" Padding="8,4"/>
                    </StackPanel>

                    <!-- ── Conditional Routing Rules ────────────────────────────── -->
                    <TextBlock Text="Conditional Routing Rules" Style="{StaticResource FieldLabelStyle}" Margin="0,4,0,4"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Opacity="0.7" Margin="0,-2,0,10"
                               Foreground="{DynamicResource SubTextBrush}"
                               Text="Smart routing at deploy time — TMM checks whether a subfolder exists and places files accordingly. Useful for games where mods go in plugins\ only when a mod loader is installed, otherwise the game root."/>

                    <!-- Preset templates strip -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Load preset:" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmbPresets" Grid.Column="1"
                                  Padding="8,5" FontSize="11">
                            <ComboBoxItem Tag="asi"    Content="ASI Loader  (GTA IV, GTA V, LA Noire, etc.)"/>
                            <ComboBoxItem Tag="source" Content="Source Engine  (Half-Life 2, Portal, TF2)"/>
                            <ComboBoxItem Tag="skse"   Content="Script Extender  (Skyrim / Fallout 4)"/>
                            <ComboBoxItem Tag="cleo"   Content="CLEO  (GTA San Andreas)"/>
                            <ComboBoxItem Tag="clear"  Content="— Clear all rules —"/>
                        </ComboBox>
                        <Button Grid.Column="2" Content="Apply"
                                Style="{StaticResource BrowseBtnStyle}" Margin="6,0,0,0" Padding="12,5"
                                Click="BtnApplyPreset_Click"/>
                    </Grid>

                    <!-- Sentence-builder rule cards -->
                    <ItemsControl x:Name="icCondRoutes" Margin="0,0,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource HeaderBrush}"
                                        BorderBrush="{DynamicResource SubTextBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="12,10" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Sentence -->
                                        <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Put " VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubTextBrush}" FontSize="12"/>
                                            <TextBox Text="{Binding Extension, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SentenceBoxStyle}" Width="68"
                                                     ToolTip="File extension to match, e.g.  .asi"/>
                                            <TextBlock Text=" files into " VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubTextBrush}" FontSize="12"/>
                                            <TextBox Text="{Binding RouteIfExists, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SentenceBoxStyle}" Width="90"
                                                     ToolTip="Subfolder to use when the check folder exists  (. = game root)"/>
                                            <TextBlock Text=" if " VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubTextBrush}" FontSize="12"/>
                                            <TextBox Text="{Binding CheckSubdir, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SentenceBoxStyle}" Width="90"
                                                     ToolTip="Subfolder to check for existence in the game directory"/>
                                            <TextBlock Text="\ exists, otherwise " VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SubTextBrush}" FontSize="12"/>
                                            <TextBox Text="{Binding RouteIfMissing, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource SentenceBoxStyle}" Width="58"
                                                     ToolTip="Subfolder to use when the check folder does NOT exist  (. = game root)"/>
                                        </WrapPanel>

                                        <!-- Remove button -->
                                        <Button Grid.Column="1" Content="&#xE8BB;"
                                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                FontSize="9" Width="26" Height="26"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SubTextBrush}"
                                                Cursor="Hand" Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                ToolTip="Remove this rule"
                                                Click="BtnRemoveCondRouteItem_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state hint -->
                    <Border x:Name="pnlRoutingEmpty" Background="#0AFFFFFF" CornerRadius="5"
                            Padding="12,10" Margin="0,0,0,6" Visibility="Visible">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.55"
                                   Foreground="{DynamicResource TextBrush}" TextAlignment="Center"
                                   Text="No routing rules yet. Click '+ Add Rule' or pick a preset above.&#x0A;Most games don't need any rules — leave blank and mods go to the game root."/>
                    </Border>

                    <Button Content="+ Add Rule" Click="BtnAddCondRoute_Click"
                            Style="{StaticResource BrowseBtnStyle}" Margin="0,0,0,14" Padding="8,4"/>

                    <!-- Footer note -->
                    <Border Background="#1AFF8800" BorderBrush="#33FF8800" BorderThickness="1"
                            CornerRadius="5" Padding="10,8" Margin="0,0,0,10">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FFCC66"
                                   Text="Note: TMM does not restructure mod archives automatically. If a downloaded archive uses a nested folder layout, you may need to reorganize files after installing so they land in the right place on deploy."/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="{DynamicResource HeaderBrush}"
                    CornerRadius="0,0,8,8" Padding="16,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="80" Margin="0,0,8,0"
                            Style="{StaticResource CancelBtnStyle}"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="btnSave" Content="Save" Width="80"
                            Style="{StaticResource SaveBtnStyle}"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
