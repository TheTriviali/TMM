<local:TmmWindow x:Class="TMM.CustomGameConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        Title="Configure Custom Game"
        Height="860" Width="820"
        MinHeight="640" MinWidth="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">

    <Window.Resources>

        <!-- ── Field labels (Game Name *, Game Directory *, etc.) ─────────────── -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
            <Setter Property="Foreground"  Value="{DynamicResource TextBrush}"/>
        </Style>

        <!-- Dim helper text beneath labels -->
        <Style x:Key="FieldHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="Opacity"     Value="0.55"/>
            <Setter Property="Margin"      Value="0,-2,0,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground"  Value="{DynamicResource SubTextBrush}"/>
        </Style>

        <!-- Standard text field -->
        <Style x:Key="FieldBoxStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="Margin"          Value="0,0,0,12"/>
            <Setter Property="FontSize"        Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Browse / action buttons -->
        <Style x:Key="BrowseBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="6,0,0,12"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <Style x:Key="CancelBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <Style x:Key="SaveBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <!-- Inline text boxes inside rule sentence builder -->
        <Style x:Key="SentenceBoxStyle" TargetType="TextBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"         Value="4,1"/>
            <Setter Property="Margin"          Value="3,0"/>
            <Setter Property="FontFamily"      Value="Consolas, Courier New"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- WHEN / IF / THEN / ELSE keyword labels on rule cards -->
        <Style x:Key="RuleKeywordStyle" TargetType="TextBlock">
            <Setter Property="FontFamily"        Value="Consolas, Courier New"/>
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="FontWeight"        Value="Bold"/>
            <Setter Property="Foreground"        Value="{DynamicResource AccentBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width"             Value="44"/>
            <Setter Property="Margin"            Value="0,0,2,0"/>
        </Style>

        <!-- Prose text between keywords and boxes on rule cards -->
        <Style x:Key="RuleProseStyle" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="Foreground"        Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,0,2,0"/>
        </Style>

        <!-- Small inline "+add" buttons on rule cards -->
        <Style x:Key="RuleAddBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Setter Property="Margin"          Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource WindowBorderBrush}">
        <Border.Background><SolidColorBrush Color="#1C1C1E"/></Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" Background="{DynamicResource HeaderBrush}" MouseDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock x:Name="txtWindowTitle" Text="Add Custom Game"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
                <Button Content="&#xE8BB;" HorizontalAlignment="Right"
                        Width="40" Height="34" BorderThickness="0"
                        Background="Transparent" Foreground="{DynamicResource SubTextBrush}"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="22,16,22,0">
                <StackPanel>

                    <!-- Info banner -->
                    <Border Background="#1A0883FF" BorderBrush="#330883FF" BorderThickness="1"
                            CornerRadius="5" Padding="10,8" Margin="0,0,0,16">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#88BBFF"
                                   Text="TMM copies mods from its internal storage into your game directory at deploy time. Keep a backup of your original game folder. Routing rules below tell TMM where each file type should land — if unsure, leave everything as . (game root)."/>
                    </Border>

                    <!-- ── Basic info ──────────────────────────────────────────────────── -->
                    <TextBlock Text="Game Name *" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="txtGameName" Style="{StaticResource FieldBoxStyle}"/>

                    <TextBlock Text="Description (optional)" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox x:Name="txtDescription" Style="{StaticResource FieldBoxStyle}"
                             TextWrapping="Wrap" Height="56" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="Optional description shown as tooltip on launcher card"/>

                    <TextBlock Text="Game Directory *" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtGameDir" Grid.Column="0"
                                 Style="{StaticResource FieldBoxStyle}" Margin="0"
                                 ToolTip="The root folder of your game installation"/>
                        <Button Grid.Column="1" Content="&#xE8B7;"
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                Width="34" Height="34" Margin="6,0,0,0"
                                Style="{StaticResource BrowseBtnStyle}" Padding="0"
                                ToolTip="Open game directory in Explorer"
                                Click="BtnOpenGameDir_Click"/>
                        <Button Grid.Column="2" Content="Browse..."
                                Style="{StaticResource BrowseBtnStyle}" Margin="6,0,0,0"
                                Click="BtnBrowseDir_Click"/>
                    </Grid>

                    <TextBlock Text="Game Executable (optional)" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock Style="{StaticResource FieldHintStyle}"
                               Text="Relative to game directory, e.g.  hl2.exe  or  bin\launcher.exe"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtExePath" Grid.Column="0"
                                 Style="{StaticResource FieldBoxStyle}" Margin="0"/>
                        <Button Grid.Column="1" Content="Browse..."
                                Style="{StaticResource BrowseBtnStyle}"
                                Click="BtnBrowseExe_Click"/>
                    </Grid>

                    <TextBlock Text="Steam App ID (optional)" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBlock Style="{StaticResource FieldHintStyle}"
                               Text="Numeric Steam ID for Launch via Steam (e.g. 12210 for GTA IV). Leave empty to launch the exe directly."/>
                    <TextBox x:Name="txtSteamAppId" Style="{StaticResource FieldBoxStyle}"/>

                    <!-- Metadata expander -->
                    <Expander Background="{DynamicResource HeaderBrush}" Foreground="{DynamicResource TextBrush}"
                              Margin="0,0,0,12" IsExpanded="False">
                        <Expander.Header>
                            <TextBlock Text="Metadata (optional)" FontSize="11" FontWeight="SemiBold"/>
                        </Expander.Header>
                        <StackPanel Margin="8,8,0,4">
                            <TextBlock Text="Author" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtAuthor" Style="{StaticResource FieldBoxStyle}"/>
                            <TextBlock Text="Version" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="txtVersion" Style="{StaticResource FieldBoxStyle}"/>
                        </StackPanel>
                    </Expander>

                    <!-- ── Routing Rules ───────────────────────────────────────────────── -->
                    <TextBlock Text="Routing Rules" Style="{StaticResource FieldLabelStyle}" Margin="0,6,0,4"/>
                    <TextBlock Style="{StaticResource FieldHintStyle}"
                               Text="Rules are evaluated in order — first match wins. Use * as the extension to create a catch-all. Files that match no rule go to the game root by default."/>

                    <!-- Preset templates strip -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Load preset:" VerticalAlignment="Center"
                                   FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="cmbPresets" Grid.Column="1" Padding="8,5" FontSize="11">
                            <ComboBoxItem Tag="asi"    Content="ASI Loader  (GTA IV, GTA V, LA Noire, etc.)"/>
                            <ComboBoxItem Tag="source" Content="Source Engine  (Half-Life 2, Portal, TF2)"/>
                            <ComboBoxItem Tag="skse"   Content="Script Extender  (Skyrim / Fallout 4)"/>
                            <ComboBoxItem Tag="cleo"   Content="CLEO  (GTA San Andreas)"/>
                            <ComboBoxItem Tag="clear"  Content="— Clear all rules —"/>
                        </ComboBox>
                        <Button Grid.Column="2" Content="Apply"
                                Style="{StaticResource BrowseBtnStyle}" Margin="6,0,0,0" Padding="12,5"
                                Click="BtnApplyPreset_Click"/>
                    </Grid>

                    <!-- Rule cards -->
                    <ItemsControl x:Name="icRules" Margin="0,0,0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:RoutingRule}">
                                <Border Padding="12,10" Margin="0,0,0,6" CornerRadius="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"      Value="{DynamicResource HeaderBrush}"/>
                                            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasConflict}" Value="True">
                                                    <Setter Property="BorderBrush"     Value="#FF5555"/>
                                                    <Setter Property="BorderThickness" Value="1.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Rule content -->
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">

                                            <!-- WHEN row -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                <TextBlock Text="WHEN" Style="{StaticResource RuleKeywordStyle}"/>
                                                <TextBlock Text="ext = " Style="{StaticResource RuleProseStyle}"/>
                                                <TextBox Text="{Binding ExtensionPattern, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentenceBoxStyle}" Width="68"
                                                         ToolTip="Extension to match: .dll   .esp   *  (any extension)"/>
                                                <Button Content="+ name filter" Click="BtnAddNameFilter_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource RuleAddBtnStyle}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasNameFilter}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>

                                            <!-- AND name filter row (HasNameFilter) -->
                                            <StackPanel Orientation="Horizontal" Margin="44,0,0,3">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasNameFilter}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="AND" Style="{StaticResource RuleKeywordStyle}"/>
                                                <TextBlock Text="name contains " Style="{StaticResource RuleProseStyle}"/>
                                                <TextBox Text="{Binding NameContains, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentenceBoxStyle}" Width="110"
                                                         ToolTip="Filename must contain this text (case-insensitive)"/>
                                                <Button Content="&#xE8BB;"
                                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="8"
                                                        Width="20" Height="20"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource SubTextBrush}"
                                                        Cursor="Hand" Margin="4,0,0,0" VerticalAlignment="Center"
                                                        ToolTip="Remove name filter"
                                                        Click="BtnRemoveNameFilter_Click"/>
                                            </StackPanel>

                                            <!-- Separator (HasCondition only) -->
                                            <Rectangle Height="1" Fill="{DynamicResource SubTextBrush}"
                                                       Opacity="0.15" Margin="0,5,0,5">
                                                <Rectangle.Style>
                                                    <Style TargetType="Rectangle">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCondition}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Rectangle.Style>
                                            </Rectangle>

                                            <!-- IF row (HasCondition) -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCondition}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="IF" Style="{StaticResource RuleKeywordStyle}"/>
                                                <TextBox Text="{Binding CheckSubdir, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentenceBoxStyle}" Width="130"
                                                         ToolTip="Subfolder to check for existence in the game directory, e.g.  Data\SKSE"/>
                                                <TextBlock Text=" exists in game dir" Style="{StaticResource RuleProseStyle}"/>
                                                <Button Content="&#xE8BB;"
                                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="8"
                                                        Width="20" Height="20"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource SubTextBrush}"
                                                        Cursor="Hand" Margin="6,0,0,0" VerticalAlignment="Center"
                                                        ToolTip="Remove condition"
                                                        Click="BtnRemoveCondition_Click"/>
                                            </StackPanel>

                                            <!-- + add condition (no condition set) -->
                                            <Button Content="+ add IF condition" Click="BtnAddCondition_Click"
                                                    HorizontalAlignment="Left" Margin="44,0,0,3">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource RuleAddBtnStyle}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCondition}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <!-- Separator before THEN -->
                                            <Rectangle Height="1" Fill="{DynamicResource SubTextBrush}"
                                                       Opacity="0.15" Margin="0,5,0,5"/>

                                            <!-- THEN row -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                                <TextBlock Text="THEN" Style="{StaticResource RuleKeywordStyle}"/>
                                                <TextBlock Text="route to " Style="{StaticResource RuleProseStyle}"/>
                                                <TextBox Text="{Binding Destination, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentenceBoxStyle}" Width="180"
                                                         ToolTip="Output subfolder relative to game root. Use . for game root."/>
                                            </StackPanel>

                                            <!-- ELSE row (HasCondition) -->
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasCondition}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="ELSE" Style="{StaticResource RuleKeywordStyle}"/>
                                                <TextBlock Text="route to " Style="{StaticResource RuleProseStyle}"/>
                                                <TextBox Text="{Binding FallbackDestination, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource SentenceBoxStyle}" Width="180"
                                                         ToolTip="Fallback destination when IF condition is false. Leave empty for game root."/>
                                            </StackPanel>

                                        </StackPanel>

                                        <!-- Move / Remove buttons -->
                                        <StackPanel Grid.Column="1" Orientation="Vertical"
                                                    VerticalAlignment="Top" Margin="4,0,0,0">
                                            <Button Content="&#xE70E;"
                                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                    FontSize="9" Width="26" Height="26"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{DynamicResource SubTextBrush}"
                                                    Cursor="Hand" Margin="0,0,0,3"
                                                    ToolTip="Move rule up"
                                                    Click="BtnMoveRuleUp_Click"/>
                                            <Button Content="&#xE70D;"
                                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                    FontSize="9" Width="26" Height="26"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{DynamicResource SubTextBrush}"
                                                    Cursor="Hand" Margin="0,0,0,3"
                                                    ToolTip="Move rule down"
                                                    Click="BtnMoveRuleDown_Click"/>
                                            <Button Content="&#xE8BB;"
                                                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                    FontSize="9" Width="26" Height="26"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{DynamicResource SubTextBrush}"
                                                    Cursor="Hand"
                                                    ToolTip="Remove this rule"
                                                    Click="BtnRemoveRule_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state hint -->
                    <Border x:Name="pnlRoutingEmpty" Background="#0AFFFFFF" CornerRadius="5"
                            Padding="12,10" Margin="0,0,0,6" Visibility="Visible">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.55"
                                   Foreground="{DynamicResource TextBrush}" TextAlignment="Center"
                                   Text="No routing rules yet. Click '+ Add Rule' or pick a preset above.&#x0A;Without any rules, all mod files are deployed to the game root by default."/>
                    </Border>

                    <!-- Default catch-all note -->
                    <Border Background="#0AFFFFFF" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Consolas, Courier New" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource SubTextBrush}" Margin="0,0,6,0"
                                       VerticalAlignment="Center" Text="default"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                       VerticalAlignment="Center"
                                       Text="→ any file not matched by a rule above goes to the game root  (.)"/>
                        </StackPanel>
                    </Border>

                    <!-- Add Rule / Test Routing buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Button Content="+ Add Rule"      Click="BtnAddRule_Click"
                                Style="{StaticResource BrowseBtnStyle}" Margin="0,0,8,0" Padding="8,4"/>
                        <Button Content="Test Routing..." Click="BtnTestRouting_Click"
                                Style="{StaticResource BrowseBtnStyle}" Padding="8,4"/>
                    </StackPanel>

                    <!-- Archive note -->
                    <Border Background="#1AFF8800" BorderBrush="#33FF8800" BorderThickness="1"
                            CornerRadius="5" Padding="10,8" Margin="0,0,0,10">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FFCC66"
                                   Text="Archives (.zip .rar .7z) are always auto-extracted — routing rules apply to the files inside, not the archive itself. Nested directories within an archive are preserved unless rules redirect them."/>
                    </Border>

                    <!-- Test Routing Panel (initially collapsed) -->
                    <Border x:Name="pnlTestRouting" Visibility="Collapsed"
                            Background="{DynamicResource ControlBgBrush}" CornerRadius="4"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1"
                            Padding="12,10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Test Routing" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txtTestFile" Grid.Column="0"
                                         Style="{StaticResource FieldBoxStyle}" Margin="0"
                                         ToolTip="Enter or browse a filename to simulate routing"/>
                                <Button Grid.Column="1" Content="Browse..."
                                        Style="{StaticResource BrowseBtnStyle}" Padding="8,4"
                                        Click="BtnTestRoutingBrowse_Click"/>
                            </Grid>
                            <TextBlock x:Name="txtTestResult" Text="→ (nothing yet)"
                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                       FontFamily="Consolas, Courier New" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="{DynamicResource HeaderBrush}"
                    CornerRadius="0,0,8,8" Padding="16,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Import .tmmgame" Margin="0,0,8,0"
                                Style="{StaticResource BrowseBtnStyle}" Padding="10,5"
                                Click="BtnImportConfig_Click"/>
                        <Button Content="Export .tmmgame"
                                Style="{StaticResource BrowseBtnStyle}" Padding="10,5"
                                Click="BtnExportConfig_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Width="80" Margin="0,0,8,0"
                                Style="{StaticResource CancelBtnStyle}"
                                Click="BtnCancel_Click"/>
                        <Button x:Name="btnSave" Content="Save" Width="80"
                                Style="{StaticResource SaveBtnStyle}"
                                Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
