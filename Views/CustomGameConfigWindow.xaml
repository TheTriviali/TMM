<Window x:Class="TMM.CustomGameConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Custom Game"
        Height="560" Width="520"
        MinHeight="480" MinWidth="460"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">

    <Border CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource AccentBrush}">
        <Border.Background>
            <SolidColorBrush Color="#1C1C1E"/>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" Background="{DynamicResource HeaderBrush}" MouseDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <TextBlock x:Name="txtWindowTitle" Text="Add Custom Game"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
                <Button Content="&#xE8BB;" HorizontalAlignment="Right"
                        Width="40" Height="34" BorderThickness="0"
                        Background="Transparent" Foreground="{DynamicResource SubTextBrush}"
                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                        Click="BtnClose_Click"/>
            </Grid>

            <!-- Form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,14,20,0">
                <StackPanel>

                    <!-- Disclaimer banner -->
                    <Border Background="#1A0883FF" BorderBrush="#330883FF" BorderThickness="1"
                            CornerRadius="5" Padding="10,8" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock FontSize="11" FontWeight="Bold" Margin="0,0,0,4"
                                       Foreground="#88BBFF" Text="Before you start"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#88BBFF"
                                       Text="TMM stores mods separately and copies them to your game directory on deploy. You should keep a backup of your original game folder. File type &#x2192; output folder mappings tell TMM where each mod file type goes &#x2014; if unsure, leave everything as '.' (game root)."/>
                        </StackPanel>
                    </Border>

                    <!-- Game Name -->
                    <TextBlock Text="Game Name *" Style="{DynamicResource FieldLabelStyle}"/>
                    <TextBox x:Name="txtGameName" Style="{DynamicResource FieldBoxStyle}"/>

                    <!-- Game Directory -->
                    <TextBlock Text="Game Directory *" Style="{DynamicResource FieldLabelStyle}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtGameDir" Grid.Column="0"
                                 Style="{DynamicResource FieldBoxStyle}" Margin="0"
                                 ToolTip="The root folder of your game installation"/>
                        <Button Grid.Column="1" Content="Browse..."
                                Style="{DynamicResource BrowseBtnStyle}"
                                Click="BtnBrowseDir_Click"/>
                    </Grid>

                    <!-- Exe Path (optional) -->
                    <TextBlock Text="Game Executable (optional)" Style="{DynamicResource FieldLabelStyle}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Opacity="0.6" Margin="0,-2,0,4"
                               Foreground="{DynamicResource SubTextBrush}"
                               Text="Relative to game directory, e.g. hl2.exe or bin\launcher.exe"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtExePath" Grid.Column="0"
                                 Style="{DynamicResource FieldBoxStyle}" Margin="0"
                                 ToolTip="Relative path to the game executable inside the game directory"/>
                        <Button Grid.Column="1" Content="Browse..."
                                Style="{DynamicResource BrowseBtnStyle}"
                                Click="BtnBrowseExe_Click"/>
                    </Grid>

                    <!-- Mod File Types -->
                    <TextBlock Text="Supported Mod File Types *" Style="{DynamicResource FieldLabelStyle}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Opacity="0.6" Margin="0,-2,0,4"
                               Foreground="{DynamicResource SubTextBrush}"
                               Text="Comma-separated extensions. Archives (.zip, .rar, .7z) are extracted on install."/>
                    <TextBox x:Name="txtFileTypes" Style="{DynamicResource FieldBoxStyle}"/>

                    <!-- Output Directory Mapping -->
                    <TextBlock Text="Output Directory Mapping" Style="{DynamicResource FieldLabelStyle}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Opacity="0.6" Margin="0,-2,0,6"
                               Foreground="{DynamicResource SubTextBrush}"
                               Text="Map file extensions to subfolders inside the game directory. Use . for the game root (e.g. .asi &#x2192; .)."/>

                    <Border Background="{DynamicResource ControlBgBrush}" CornerRadius="4"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1" Margin="0,0,0,4">
                        <DataGrid x:Name="dgMappings"
                                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserSortColumns="False" CanUserResizeRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0" BorderThickness="0"
                                  Background="Transparent" RowBackground="Transparent"
                                  AlternatingRowBackground="#0DFFFFFF"
                                  Foreground="{DynamicResource TextBrush}"
                                  HorizontalGridLinesBrush="#1AFFFFFF"
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  MinHeight="72" MaxHeight="152">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Setter Property="Padding" Value="6,3"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3D3D3D"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3D3D3D"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1AFFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource HeaderBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#22FFFFFF"/>
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Extension" Width="120"
                                                    Binding="{Binding Extension, UpdateSourceTrigger=LostFocus}">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="6,3"/>
                                            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
                                            <Setter Property="FontSize" Value="12"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Output Folder" Width="*"
                                                    Binding="{Binding OutputFolder, UpdateSourceTrigger=LostFocus}">
                                    <DataGridTextColumn.EditingElementStyle>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="4,2"/>
                                            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
                                        </Style>
                                    </DataGridTextColumn.EditingElementStyle>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding" Value="6,3"/>
                                            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
                                            <Setter Property="FontSize" Value="12"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="+ Add Row" Click="BtnAddMapping_Click"
                                Style="{DynamicResource BrowseBtnStyle}" Margin="0,0,8,0" Padding="8,4"/>
                        <Button Content="&#x2212; Remove Selected" Click="BtnRemoveMapping_Click"
                                Style="{DynamicResource BrowseBtnStyle}" Padding="8,4"/>
                    </StackPanel>

                    <!-- Conditional Routing Rules -->
                    <TextBlock Text="Conditional Routing Rules" Style="{DynamicResource FieldLabelStyle}" Margin="0,8,0,4"/>
                    <TextBlock TextWrapping="Wrap" FontSize="10" Opacity="0.6" Margin="0,-2,0,6"
                               Foreground="{DynamicResource SubTextBrush}"
                               Text="Evaluated at deploy-time: if a sub-folder exists, route the file extension there. Takes priority over Output Directory Mapping. Example: .asi + plugins + plugins + . puts .asi in 'plugins\' when that folder exists, otherwise the game root."/>

                    <Border Background="{DynamicResource ControlBgBrush}" CornerRadius="4"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1" Margin="0,0,0,4">
                        <DataGrid x:Name="dgCondRoutes"
                                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserSortColumns="False" CanUserResizeRows="False"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0" BorderThickness="0"
                                  Background="Transparent" RowBackground="Transparent"
                                  AlternatingRowBackground="#0DFFFFFF"
                                  Foreground="{DynamicResource TextBrush}"
                                  HorizontalGridLinesBrush="#1AFFFFFF"
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  MinHeight="60" MaxHeight="120">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Setter Property="Padding" Value="6,3"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3D3D3D"/>
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected"   Value="True">
                                            <Setter Property="Background" Value="#3D3D3D"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1AFFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"     Value="{DynamicResource HeaderBrush}"/>
                                    <Setter Property="Foreground"     Value="{DynamicResource SubTextBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush"    Value="#22FFFFFF"/>
                                    <Setter Property="Padding"        Value="8,4"/>
                                    <Setter Property="FontSize"       Value="11"/>
                                    <Setter Property="FontWeight"     Value="SemiBold"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Extension" Width="80"
                                                    Binding="{Binding Extension, UpdateSourceTrigger=LostFocus}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding"     Value="6,3"/>
                                            <Setter Property="FontFamily"  Value="Consolas, Courier New"/>
                                            <Setter Property="FontSize"    Value="12"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Check Subfolder" Width="*"
                                                    Binding="{Binding CheckSubdir, UpdateSourceTrigger=LostFocus}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding"     Value="6,3"/>
                                            <Setter Property="FontFamily"  Value="Consolas, Courier New"/>
                                            <Setter Property="FontSize"    Value="12"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="If Exists" Width="80"
                                                    Binding="{Binding RouteIfExists, UpdateSourceTrigger=LostFocus}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding"     Value="6,3"/>
                                            <Setter Property="FontFamily"  Value="Consolas, Courier New"/>
                                            <Setter Property="FontSize"    Value="12"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="If Missing" Width="80"
                                                    Binding="{Binding RouteIfMissing, UpdateSourceTrigger=LostFocus}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Padding"     Value="6,3"/>
                                            <Setter Property="FontFamily"  Value="Consolas, Courier New"/>
                                            <Setter Property="FontSize"    Value="12"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="+ Add Rule" Click="BtnAddCondRoute_Click"
                                Style="{DynamicResource BrowseBtnStyle}" Margin="0,0,8,0" Padding="8,4"/>
                        <Button Content="&#x2212; Remove Selected" Click="BtnRemoveCondRoute_Click"
                                Style="{DynamicResource BrowseBtnStyle}" Padding="8,4"/>
                    </StackPanel>

                    <!-- Folder structure note -->
                    <Border Background="#1AFF8800" BorderBrush="#33FF8800" BorderThickness="1"
                            CornerRadius="5" Padding="10,8" Margin="0,0,0,6">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#FFCC66"
                                   Text="Note: TMM does not restructure your mods automatically. If a mod archive has a nested folder structure, you may need to reorganize it after installing so files land in the right output directory on deploy."/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="{DynamicResource HeaderBrush}" CornerRadius="0,0,8,8" Padding="16,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Width="80" Margin="0,0,8,0"
                                Style="{DynamicResource CancelBtnStyle}"
                                Click="BtnCancel_Click"/>
                        <Button x:Name="btnSave" Content="Save" Width="80"
                                Style="{DynamicResource SaveBtnStyle}"
                                Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>

    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
            <Setter Property="Foreground"  Value="{DynamicResource SubTextBrush}"/>
        </Style>

        <Style x:Key="FieldBoxStyle" TargetType="TextBox">
            <Setter Property="Background"    Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground"    Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="8,5"/>
            <Setter Property="Margin"        Value="0,0,0,12"/>
            <Setter Property="FontSize"      Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BrowseBtnStyle" TargetType="Button">
            <Setter Property="Background"    Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"    Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Padding"       Value="10,5"/>
            <Setter Property="Margin"        Value="6,0,0,12"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="Cursor"        Value="Hand"/>
        </Style>

        <Style x:Key="CancelBtnStyle" TargetType="Button">
            <Setter Property="Background"    Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"    Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"   Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Padding"       Value="10,5"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FontSize"      Value="12"/>
        </Style>

        <Style x:Key="SaveBtnStyle" TargetType="Button">
            <Setter Property="Background"    Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"    Value="{DynamicResource AccentTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="10,5"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FontSize"      Value="12"/>
        </Style>
    </Window.Resources>
</Window>
