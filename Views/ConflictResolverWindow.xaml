<local:TmmWindow x:Class="TMM.ConflictResolverWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:local="clr-namespace:TMM"
                 Title="Resolve Conflicts" Width="780" Height="540"
                 Background="{DynamicResource BgBrush}"
                 WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Pick a winner for each overlapping file"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock x:Name="txtHint" Margin="0,4,0,0" FontSize="11"
                       Foreground="{DynamicResource SubTextBrush}"
                       Text="By default, the highest-load-order mod wins. Override below if needed."/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icConflicts">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Padding="14" CornerRadius="6"
                                Background="{DynamicResource PanelBrush}">
                            <StackPanel>
                                <TextBlock Text="{Binding RelativePath}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource TextBrush}"
                                           Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding ParticipantLabels}"
                                          SelectedIndex="{Binding ChosenIndex}"
                                          Width="420" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding ParticipantSummary}"
                                           FontSize="10" Opacity="0.7"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Button Content="Reset to defaults" Click="BtnReset_Click" HorizontalAlignment="Left"
                    Padding="14,6" Background="{DynamicResource ControlBgBrush}"
                    Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"/>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Content="Cancel" Click="BtnCancel_Click" Margin="0,0,8,0"
                        Padding="20,6" Background="{DynamicResource ControlBgBrush}"
                        Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Apply" Click="BtnApply_Click"
                        Padding="20,6" Background="{DynamicResource AccentBrush}"
                        Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</local:TmmWindow>
