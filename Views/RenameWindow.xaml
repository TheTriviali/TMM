<local:TmmWindow x:Class="TMM.RenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        Title="Rename Mod" SizeToContent="Height" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border CornerRadius="10" Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#18000000" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock x:Name="lblTitle" Text="Rename Mod" Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="40" VerticalAlignment="Stretch" Click="BtnCancel_Click"
                        ToolTip="Cancel - no rename">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,8,0,0">
                                <TextBlock Text="x" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Input -->
            <StackPanel Grid.Row="1" Margin="16,14,16,0">
                <TextBlock x:Name="lblPrompt" Text="New name:" Foreground="{DynamicResource SubTextBrush}"
                           FontSize="11" Margin="0,0,0,5"/>
                <TextBox x:Name="txtName" Height="28" Background="{DynamicResource ControlBgBrush}"
                         Foreground="{DynamicResource TextBrush}" BorderThickness="0" Padding="6,4"
                         FontSize="13" KeyDown="TxtName_KeyDown"/>
            </StackPanel>

            <!-- Bottom buttons -->
            <Border Grid.Row="2" Padding="16,10" Background="#0A000000">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Save" Click="BtnSave_Click" Height="30"
                            Background="{DynamicResource AccentBrush}" Foreground="Black"
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand" FontSize="13"/>
                    <Button Grid.Column="2" Content="Cancel" Click="BtnCancel_Click" Height="30" Width="70"
                            Background="{DynamicResource PanelBrush}" Foreground="{DynamicResource TextBrush}"
                            BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
