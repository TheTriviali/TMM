<local:TmmWindow x:Class="TMM.PlanEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        Title="Plan Editor"
        Width="980" Height="640"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Left-pane node template (GameDirNode) -->
        <HierarchicalDataTemplate DataType="{x:Type local:GameDirNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock x:Name="iconGlyph"
                           Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                           FontSize="11" Margin="0,0,5,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SubTextBrush}"/>
                <TextBlock x:Name="nameTb" Text="{Binding Name}" FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock x:Name="newTag" Text="  [new]" FontSize="10"
                           Margin="4,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource AccentBrush}"
                           Visibility="{Binding IsNewFolder, Converter={StaticResource BoolVis}}"/>
                <TextBlock x:Name="conflictTb"
                           Text="{Binding ConflictText}" FontSize="10"
                           Margin="8,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource ConflictRedBrush}"
                           Visibility="{Binding HasConflict, Converter={StaticResource BoolVis}}"/>
            </StackPanel>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                    <Setter TargetName="iconGlyph" Property="Text" Value="&#xE8A5;"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <!-- Right-pane node template (ModSourceNode) -->
        <HierarchicalDataTemplate DataType="{x:Type local:ModSourceNode}"
                                  ItemsSource="{Binding Children}">
            <StackPanel x:Name="rowPanel" Orientation="Horizontal" Margin="0,2">
                <TextBlock x:Name="iconGlyph2"
                           Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                           FontSize="11" Margin="0,0,5,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SubTextBrush}"/>
                <TextBlock x:Name="nameTb2" Text="{Binding Name}" FontSize="12"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}"/>
                <!-- Destination annotation — files only -->
                <TextBlock x:Name="destTb"
                           FontSize="10" Margin="8,0,4,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource SubTextBrush}"
                           Visibility="Collapsed">
                    <Run Text="&#x2192; "/>
                    <Run Text="{Binding DestinationDisplay}"/>
                </TextBlock>
                <TextBlock x:Name="statusGlyph"
                           Text="{Binding StatusGlyph}" FontSize="11"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </StackPanel>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsDirectory}" Value="False">
                    <Setter TargetName="iconGlyph2" Property="Text" Value="&#xE8A5;"/>
                    <Setter TargetName="destTb" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="statusGlyph" Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasConflict}" Value="True">
                    <Setter TargetName="statusGlyph" Property="Foreground" Value="{DynamicResource ConflictRedBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasConflict}" Value="False">
                    <Setter TargetName="statusGlyph" Property="Foreground" Value="#5ACC77"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsExcluded}" Value="True">
                    <Setter TargetName="rowPanel" Property="Opacity" Value="0.38"/>
                    <Setter TargetName="nameTb2" Property="TextDecorations" Value="Strikethrough"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <!-- Shared TreeViewItem style -->
        <Style x:Key="PlanTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="itemBd" Background="Transparent"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Expander toggle -->
                                    <ToggleButton x:Name="expander" Grid.Column="0"
                                                  Width="16" Height="16"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Visibility="Collapsed"
                                                  Style="{x:Null}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <TextBlock x:Name="arrow" Text="&#x25B6;"
                                                           FontSize="8"
                                                           Foreground="{DynamicResource SubTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="arrow" Property="Text" Value="&#x25BC;"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="items" Margin="16,0,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="expander" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="items" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBd" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#1A000000" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock x:Name="txtTitle"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" Margin="14,0,50,0"
                           FontSize="12" FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <Button HorizontalAlignment="Right" Width="45" VerticalAlignment="Stretch"
                        Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,10,0,0">
                                <TextBlock Text="&#x2715;"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Pane headers -->
            <Grid Grid.Row="1" Background="{DynamicResource PanelBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="leftCol" Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="&#x1F4C2; Open"
                                Click="BtnOpenGameDir_Click"
                                Padding="8,3" Height="24" Margin="0,0,0,0"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="GAME DIRECTORY" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1"
                        BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="0,0,0,1"
                        Background="{DynamicResource HeaderBrush}"/>

                <Border Grid.Column="2"
                        BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="&#x1F4C2; Open"
                                Click="BtnOpenModDir_Click"
                                Padding="8,3" Height="24"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Text="MOD FILES (source)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- Pane content -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MinWidth="200" Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition MinWidth="200" Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: game directory tree -->
                <DockPanel Grid.Column="0">
                    <!-- New-folder inline input (hidden by default) -->
                    <Border x:Name="pnlNewFolder" DockPanel.Dock="Bottom"
                            Visibility="Collapsed"
                            Background="{DynamicResource ControlBgBrush}"
                            BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="0,1,0,0"
                            Padding="8,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="New folder:" FontSize="11"
                                       Foreground="{DynamicResource SubTextBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="txtNewFolderName" Width="200" Height="24"
                                     FontSize="11" Padding="4,2"
                                     Background="{DynamicResource BgBrush}"
                                     Foreground="{DynamicResource TextBrush}"
                                     BorderBrush="{DynamicResource SubTextBrush}"
                                     KeyDown="TxtNewFolderName_KeyDown"/>
                            <Button Content="Add" Width="40" Height="24" Margin="5,0,0,0"
                                    FontSize="11" Click="BtnAddFolderConfirm_Click"
                                    Background="{DynamicResource AccentBrush}"
                                    Foreground="{DynamicResource AccentTextBrush}"
                                    BorderThickness="0"/>
                            <Button Content="&#x2715;" Width="24" Height="24" Margin="3,0,0,0"
                                    FontSize="11" Click="BtnCancelNewFolder_Click"
                                    Background="Transparent"
                                    Foreground="{DynamicResource SubTextBrush}"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <Button DockPanel.Dock="Bottom" Content="＋  New Folder"
                            x:Name="btnNewFolder"
                            Click="BtnNewFolder_Click"
                            Margin="8,5" Height="26" HorizontalAlignment="Left"
                            Padding="10,0"
                            Background="{DynamicResource ControlBgBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            BorderThickness="0" FontSize="11"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TreeView x:Name="tvGameDir"
                                  Background="Transparent" BorderThickness="0"
                                  Padding="4"
                                  AllowDrop="True"
                                  ItemContainerStyle="{StaticResource PlanTreeItemStyle}"
                                  DragOver="TvGameDir_DragOver"
                                  Drop="TvGameDir_Drop"
                                  Foreground="{DynamicResource TextBrush}"/>
                    </ScrollViewer>
                </DockPanel>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                              Background="{DynamicResource HeaderBrush}"/>

                <!-- Right: mod source files -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <TreeView x:Name="tvModFiles"
                              Background="Transparent" BorderThickness="0"
                              Padding="4"
                              ItemContainerStyle="{StaticResource PlanTreeItemStyle}"
                              PreviewMouseLeftButtonDown="TvModFiles_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="TvModFiles_PreviewMouseMove"
                              ContextMenuOpening="TvModFiles_ContextMenuOpening"
                              Foreground="{DynamicResource TextBrush}">
                        <TreeView.ContextMenu>
                            <ContextMenu Background="{DynamicResource PanelBrush}"
                                         BorderBrush="{DynamicResource HeaderBrush}">
                                <MenuItem x:Name="menuExclude"
                                          Header="Exclude from plan"
                                          Click="MenuExclude_Click"
                                          Foreground="{DynamicResource TextBrush}"/>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                </ScrollViewer>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="3" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <TextBlock x:Name="txtFooter"
                               VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource SubTextBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,0,0">
                        <Button Content="Cancel" Width="82" Height="30"
                                Margin="0,0,8,0" Click="BtnCancel_Click"
                                Background="{DynamicResource ControlBgBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                BorderThickness="0"/>
                        <Button Content="Confirm" Width="100" Height="30"
                                Click="BtnConfirm_Click"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="{DynamicResource AccentTextBrush}"
                                BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
