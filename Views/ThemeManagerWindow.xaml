<local:TmmWindow x:Class="TMM.ThemeManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        Title="Look &amp; Feel" Height="560" Width="430"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>
        <!-- Fixed dark colors for ComboBox popup - always visible regardless of accent/bg settings. -->
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"        Color="#2A2A2E"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"     Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"      Color="#3D6B60"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"  Color="White"/>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Background"      Value="#2A2A2E"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#555"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll"              Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <!-- Full-width toggle that opens the dropdown -->
                            <ToggleButton x:Name="ToggleButton" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="bd" Background="#2A2A2E"
                                                BorderBrush="#555" BorderThickness="1" CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"/>
                                                <Path Grid.Column="1" Data="M0,0 L4,5 L8,0 Z"
                                                      Fill="#AAAAAA"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#3A3A3E"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#1E1E22"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- Selected item display -->
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,3,24,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextElement.Foreground="White"/>
                            <!-- Editable text box (hidden for non-editable combos) -->
                            <TextBox x:Name="PART_EditableTextBox"
                                     Style="{x:Null}" Focusable="True"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Margin="8,3,24,3"
                                     Background="Transparent" Foreground="White" CaretBrush="White"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <!-- Dropdown popup -->
                            <Popup x:Name="PART_Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#2A2A2E" BorderBrush="#555" BorderThickness="1">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite"            Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="PART_EditableTextBox"   Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background"  Value="#2A2A2E"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Padding"     Value="8,5"/>
            <Setter Property="FontSize"    Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3D36"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#3D6B60"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            Margin="6" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar - drag target only; NOT the outer Border to avoid hijacking canvas mouse events -->
            <Grid Grid.Row="0" Background="#1A000000" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="Look &amp; Feel Preferences" Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="15,0,0,0" FontSize="13" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="45" VerticalAlignment="Stretch" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,10,0,0">
                                <TextBlock x:Name="closeGlyph" Text="x" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                    <Setter TargetName="closeGlyph" Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Two-column body - no scrolling required -->
            <Grid Grid.Row="1" Margin="16,12,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- LEFT COLUMN: Settings                                     -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Presets -->
                    <TextBlock Text="Presets" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbPresets" SelectionChanged="CmbPresets_Changed"
                              Margin="0,0,0,6"/>

                    <!-- Advanced toggle -->
                    <Button x:Name="btnAdvanced" Content="Custom Colors  v" Click="BtnAdvanced_Click"
                            Height="28" BorderThickness="1" Cursor="Hand" Margin="0,0,0,10"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Background="{DynamicResource ControlBgBrush}"
                            Foreground="{DynamicResource AccentLabelBrush}" FontSize="12" FontWeight="SemiBold"/>

                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.2" Margin="0,0,0,10"/>

                    <!-- Titlebar -->
                    <TextBlock Text="Titlebar &amp; Window" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Control Style" Foreground="{DynamicResource SubTextBrush}" FontSize="12" Margin="0,0,0,3"/>
                    <ComboBox x:Name="cmbTheme" SelectionChanged="ModularSetting_Changed"
                              Margin="0,0,0,8">
                        <ComboBoxItem Content="Vanilla (W11)" Tag="Vanilla"/>
                        <ComboBoxItem Content="Compact / Inline" Tag="Compact"/>
                    </ComboBox>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Color Palette" Foreground="{DynamicResource SubTextBrush}" FontSize="12" Margin="0,0,0,3"/>
                        <ComboBox x:Name="cmbColor" SelectionChanged="ModularSetting_Changed">
                            <ComboBoxItem Content="Dark Mode" Tag="Dark"/>
                            <ComboBoxItem Content="Light Mode" Tag="Light"/>
                        </ComboBox>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.2" Margin="0,0,0,10"/>

                    <!-- Typography -->
                    <TextBlock Text="Typography" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Font Family" Foreground="{DynamicResource SubTextBrush}" FontSize="12" Margin="0,0,0,3"/>
                            <ComboBox x:Name="cmbFont" SelectionChanged="ModularSetting_Changed">
                                <ComboBoxItem Content="Bahnschrift (Default)" Tag="Bahnschrift"/>
                                <ComboBoxItem Content="Segoe UI" Tag="Segoe UI"/>
                                <ComboBoxItem Content="Segoe UI Light" Tag="Segoe UI Light"/>
                                <ComboBoxItem Content="Segoe UI Semibold" Tag="Segoe UI Semibold"/>
                                <ComboBoxItem Content="Calibri" Tag="Calibri"/>
                                <ComboBoxItem Content="Cambria" Tag="Cambria"/>
                                <ComboBoxItem Content="Consolas" Tag="Consolas"/>
                                <ComboBoxItem Content="Trebuchet MS" Tag="Trebuchet MS"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Text Contrast Algorithm" Foreground="{DynamicResource SubTextBrush}" FontSize="12" Margin="0,0,0,3"/>
                            <ComboBox x:Name="cmbTextColor" SelectionChanged="ModularSetting_Changed">
                                <ComboBoxItem Content="WCAG (Accessible)" Tag="WCAG"/>
                                <ComboBoxItem Content="YIQ (Perceptual)" Tag="YIQ"/>
                                <ComboBoxItem Content="Invert Snap" Tag="Invert"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.2" Margin="0,0,0,10"/>

                    <!-- Mica -->
                    <TextBlock Text="Backdrop Effects" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
                    <CheckBox x:Name="chkMica" Content="Mica / Acrylic  (Win11 native, approximated on Win10)"
                              Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,6"
                              Checked="ModularSetting_Changed" Unchecked="ModularSetting_Changed"/>
                    <CheckBox x:Name="chkAccentBorder" Content="Accent-colored window border"
                              Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,6"
                              Checked="ModularSetting_Changed" Unchecked="ModularSetting_Changed"/>

                </StackPanel>
                </ScrollViewer>

                <!-- gap column - only visible when right panel is shown -->
                <Border x:Name="RightGapBorder" Grid.Column="1" Width="14" Visibility="Collapsed"/>

                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <!-- RIGHT COLUMN: HSV Color Pickers (hidden by default)      -->
                <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                <ScrollViewer x:Name="RightPickerPanel" Grid.Column="2" Width="350" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- .mmtheme import / export (advanced) -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Import .mmtheme" Click="BtnImportPreset_Click"
                                Height="26" BorderThickness="0" Cursor="Hand"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="{DynamicResource AccentTextBrush}" FontSize="11"/>
                        <Button Grid.Column="2" Content="Export .mmtheme" Click="BtnExportPreset_Click"
                                Height="26" BorderThickness="0" Cursor="Hand"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="{DynamicResource AccentTextBrush}" FontSize="11" FontWeight="SemiBold"/>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.2" Margin="0,0,0,10"/>

                    <TextBlock Text="Colors" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"/>

                    <!-- Accent -->
                    <Border BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1.5" CornerRadius="6"
                            Padding="8" Background="{DynamicResource PanelBrush}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="ACCENT COLOR" Foreground="{DynamicResource SubTextBrush}"
                                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid Height="148" Margin="0,0,0,5">
                                <Rectangle RadiusX="4" RadiusY="4">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="White" Offset="0"/>
                                            <GradientStop x:Name="accentHueStop" Color="#FF0000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Rectangle RadiusX="4" RadiusY="4">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="Black" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Canvas x:Name="accentSpecCanvas" Background="Transparent"
                                        MouseLeftButtonDown="AccentSpec_MouseDown"
                                        MouseMove="AccentSpec_MouseMove"
                                        MouseLeftButtonUp="AccentSpec_MouseUp">
                                    <Ellipse x:Name="accentCursor" Width="12" Height="12" Stroke="White"
                                             StrokeThickness="2" Fill="Transparent"
                                             Canvas.Left="-6" Canvas.Top="-6" IsHitTestVisible="False">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.6" Color="Black"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Canvas>
                            </Grid>
                            <Grid Height="14" Margin="0,0,0,6">
                                <Rectangle RadiusX="3" RadiusY="3">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF0000" Offset="0"/>
                                            <GradientStop Color="#FFFF00" Offset="0.167"/>
                                            <GradientStop Color="#00FF00" Offset="0.333"/>
                                            <GradientStop Color="#00FFFF" Offset="0.5"/>
                                            <GradientStop Color="#0000FF" Offset="0.667"/>
                                            <GradientStop Color="#FF00FF" Offset="0.833"/>
                                            <GradientStop Color="#FF0000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Canvas x:Name="accentHueCanvas" Background="Transparent"
                                        MouseLeftButtonDown="AccentHue_MouseDown"
                                        MouseMove="AccentHue_MouseMove"
                                        MouseLeftButtonUp="AccentHue_MouseUp">
                                    <Rectangle x:Name="accentHueCursor" Width="4" Height="14"
                                               Fill="White" Stroke="Black" StrokeThickness="0.5"
                                               Canvas.Left="0" Canvas.Top="0" IsHitTestVisible="False"/>
                                </Canvas>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle x:Name="accentPreview" Width="26" Height="28" RadiusX="4" RadiusY="4"
                                           Fill="#4EC9B0" Margin="0,0,6,0">
                                    <Rectangle.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.35" Color="Black"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                                <TextBox x:Name="txtAccent" Grid.Column="1"
                                         Background="{DynamicResource ControlBgBrush}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderThickness="1" BorderBrush="{DynamicResource SubTextBrush}"
                                         Padding="6,5" Height="28" VerticalContentAlignment="Center"
                                         FontSize="13" FontFamily="Consolas"
                                         TextChanged="TxtAccentHex_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Background -->
                    <Border BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1.5" CornerRadius="6"
                            Padding="8" Background="{DynamicResource PanelBrush}">
                        <StackPanel>
                            <TextBlock Text="BACKGROUND COLOR" Foreground="{DynamicResource SubTextBrush}"
                                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid Height="148" Margin="0,0,0,5">
                                <Rectangle RadiusX="4" RadiusY="4">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="White" Offset="0"/>
                                            <GradientStop x:Name="bgHueStop" Color="#FF0000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Rectangle RadiusX="4" RadiusY="4">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="Black" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Canvas x:Name="bgSpecCanvas" Background="Transparent"
                                        MouseLeftButtonDown="BgSpec_MouseDown"
                                        MouseMove="BgSpec_MouseMove"
                                        MouseLeftButtonUp="BgSpec_MouseUp">
                                    <Ellipse x:Name="bgCursor" Width="12" Height="12" Stroke="White"
                                             StrokeThickness="2" Fill="Transparent"
                                             Canvas.Left="-6" Canvas.Top="-6" IsHitTestVisible="False">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.6" Color="Black"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Canvas>
                            </Grid>
                            <Grid Height="14" Margin="0,0,0,6">
                                <Rectangle RadiusX="3" RadiusY="3">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FF0000" Offset="0"/>
                                            <GradientStop Color="#FFFF00" Offset="0.167"/>
                                            <GradientStop Color="#00FF00" Offset="0.333"/>
                                            <GradientStop Color="#00FFFF" Offset="0.5"/>
                                            <GradientStop Color="#0000FF" Offset="0.667"/>
                                            <GradientStop Color="#FF00FF" Offset="0.833"/>
                                            <GradientStop Color="#FF0000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <Canvas x:Name="bgHueCanvas" Background="Transparent"
                                        MouseLeftButtonDown="BgHue_MouseDown"
                                        MouseMove="BgHue_MouseMove"
                                        MouseLeftButtonUp="BgHue_MouseUp">
                                    <Rectangle x:Name="bgHueCursor" Width="4" Height="14"
                                               Fill="White" Stroke="Black" StrokeThickness="0.5"
                                               Canvas.Left="0" Canvas.Top="0" IsHitTestVisible="False"/>
                                </Canvas>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle x:Name="bgPreview" Width="26" Height="28" RadiusX="4" RadiusY="4"
                                           Fill="#1E1E1E" Margin="0,0,6,0">
                                    <Rectangle.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.35" Color="Black"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                                <TextBox x:Name="txtBg" Grid.Column="1"
                                         Background="{DynamicResource ControlBgBrush}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderThickness="1" BorderBrush="{DynamicResource SubTextBrush}"
                                         Padding="6,5" Height="28" VerticalContentAlignment="Center"
                                         FontSize="13" FontFamily="Consolas"
                                         TextChanged="TxtBgHex_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <!-- Complement Colour Palette -->
                    <Border Margin="0,10,0,0" BorderBrush="{DynamicResource SubTextBrush}"
                            BorderThickness="1.5" CornerRadius="6" Padding="8"
                            Background="{DynamicResource PanelBrush}">
                        <StackPanel>
                            <TextBlock Text="COMPANION COLORS" Foreground="{DynamicResource SubTextBrush}"
                                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="cmbComplementMode" FontSize="11">
                                    <ComboBoxItem Content="Complementary"  Tag="Complementary" IsSelected="True"/>
                                    <ComboBoxItem Content="Split-Comp"     Tag="SplitComp"/>
                                    <ComboBoxItem Content="Triadic"        Tag="Triadic"/>
                                    <ComboBoxItem Content="Tetradic"       Tag="Tetradic"/>
                                    <ComboBoxItem Content="Analogous"      Tag="Analogous"/>
                                </ComboBox>
                                <Button Grid.Column="2" Content="Generate" Height="28"
                                        Click="BtnComplementPalette_Click"
                                        Background="{DynamicResource PanelBrush}"
                                        Foreground="{DynamicResource TextBrush}"
                                        BorderThickness="0" Cursor="Hand" Padding="10,0" FontSize="11"/>
                                <Button Grid.Column="4" Content="âœ¨ Suggest Accent" Height="28"
                                        Click="BtnSuggestAccent_Click"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="{DynamicResource AccentTextBrush}" FontWeight="SemiBold"
                                        BorderThickness="0" Cursor="Hand" Padding="10,0" FontSize="11"
                                        ToolTip="Auto-pick the best accent colour for this background"/>
                            </Grid>
                            <!-- Swatch row - populated at runtime -->
                            <StackPanel x:Name="lstComplement" Orientation="Horizontal" MinHeight="38"/>
                            <TextBlock Text="Click a swatch to apply it as your accent colour."
                                       Foreground="{DynamicResource SubTextBrush}"
                                       FontSize="10" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Bottom Save & Close -->
            <Border Grid.Row="2" Padding="16,10" Background="#14000000" CornerRadius="0,0,10,10">
                <Button Content="Save &amp; Close" Click="BtnClose_Click" Height="32"
                        Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentTextBrush}"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand" FontSize="13"/>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
