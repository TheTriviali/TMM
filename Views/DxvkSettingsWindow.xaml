<Window x:Class="TGTAMM.DxvkSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DXVK Configurator" Height="380" Width="420"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource BgBrush}"
        WindowStyle="None" AllowsTransparency="True">
    <Border BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2"
            CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#1A000000">
                <TextBlock Text="DXVK Configurator" Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="45" VerticalAlignment="Stretch" Click="BtnClose_Click_Header">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,10,0,0">
                                <TextBlock Text="✕" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="18,12,18,0">
                <TextBlock Text="Target Game:" Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbGame" Margin="0,0,0,12" BorderThickness="0" Padding="6,4"
                          Background="{DynamicResource ControlBgBrush}" Foreground="{DynamicResource TextBrush}"
                          SelectionChanged="CmbGame_SelectionChanged">
                    <ComboBoxItem Content="GTA III" Tag="III"/>
                    <ComboBoxItem Content="GTA Vice City" Tag="VC"/>
                    <ComboBoxItem Content="GTA San Andreas" Tag="SA"/>
                    <ComboBoxItem Content="Global (Apply to All)" Tag="ALL"/>
                </ComboBox>

                <CheckBox x:Name="chkHud" Content="Enable DXVK HUD (Framerate/Compiling)"
                          Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,8"/>
                <CheckBox x:Name="chkFramerate" Content="Limit Framerate to 60 FPS (Fixes physics bugs)"
                          Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,8"/>
                <CheckBox x:Name="chkVsync" Content="Force V-Sync (d3d9.presentInterval = 1)"
                          Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,12"/>

                <TextBlock Text="Custom Resolution (e.g. 1920x1080):"
                           Foreground="{DynamicResource SubTextBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="txtRes" Height="26" Background="{DynamicResource ControlBgBrush}"
                         Foreground="{DynamicResource TextBrush}" BorderThickness="0" Padding="6,3"/>
            </StackPanel>

            <!-- Bottom: Save + Close -->
            <Border Grid.Row="2" Padding="18,10" Background="#0A000000">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Save Configuration" Click="BtnSave_Click" Height="30"
                            Background="{DynamicResource AccentBrush}" Foreground="Black"
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                    <Button Grid.Column="2" Content="Cancel" Click="BtnClose_Click_Header"
                            Height="30" Width="70" Background="{DynamicResource PanelBrush}"
                            Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
