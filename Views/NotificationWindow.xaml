<Window x:Class="TGTAMM.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TGTAMM"
        Title="Notifications" ShowInTaskbar="False"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        IsHitTestVisible="False" Topmost="True" SizeToContent="WidthAndHeight"
        Loaded="Window_Loaded" LocationChanged="Window_LocationChanged">

    <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                Margin="0,0,16,16" Width="360">
        <ItemsControl ItemsSource="{Binding Source={x:Static local:NotificationService.Queue}}"
                      IsHitTestVisible="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource PanelBrush}" CornerRadius="6"
                            BorderThickness="1" BorderBrush="{DynamicResource AccentBrush}"
                            Padding="12,10" Margin="0,0,0,8" MinHeight="40"
                            IsHitTestVisible="True" MouseLeftButtonUp="Toast_Close">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Type, Converter={StaticResource NotificationTypeIconConverter}}"
                                       FontSize="14" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentLabelBrush}"/>

                            <!-- Message -->
                            <TextBlock Grid.Column="1" Text="{Binding Message}"
                                       Foreground="{DynamicResource TextBrush}" FontSize="12"
                                       TextWrapping="Wrap" VerticalAlignment="Center" Margin="10,0,0,0"/>

                            <!-- Close Button -->
                            <Button Grid.Column="2" Content="✕" Width="20" Height="20"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource SubTextBrush}" FontSize="10"
                                    Click="CloseButton_Click" Cursor="Hand"
                                    VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</Window>
