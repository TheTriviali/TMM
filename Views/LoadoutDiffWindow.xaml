<local:TmmWindow x:Class="TMM.LoadoutDiffWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:local="clr-namespace:TMM"
                 Title="Compare Loadouts" Width="780" Height="540"
                 Background="{DynamicResource BgBrush}"
                 WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Compare two loadouts"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="A (left)" FontSize="11"
                           Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbA" SelectionChanged="OnSelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="B (right)" FontSize="11"
                           Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                <ComboBox x:Name="cmbB" SelectionChanged="OnSelectionChanged"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource PanelBrush}" CornerRadius="6" Padding="4">
            <ListView x:Name="lvDiff" BorderThickness="0" Background="Transparent"
                      Foreground="{DynamicResource TextBrush}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Mod" Width="260" DisplayMemberBinding="{Binding ModName}"/>
                        <GridViewColumn Header="In A" Width="100" DisplayMemberBinding="{Binding StateA}"/>
                        <GridViewColumn Header="In B" Width="100" DisplayMemberBinding="{Binding StateB}"/>
                        <GridViewColumn Header="Change" Width="280" DisplayMemberBinding="{Binding Change}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <TextBlock x:Name="txtSummary" VerticalAlignment="Center"
                       Foreground="{DynamicResource SubTextBrush}" FontSize="12"/>
            <Button Content="Close" Click="BtnClose_Click" HorizontalAlignment="Right"
                    Padding="22,6" Background="{DynamicResource ControlBgBrush}"
                    Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</local:TmmWindow>
