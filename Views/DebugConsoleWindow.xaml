<Window x:Class="TGTAMM.DebugConsoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Developer Diagnostics" Height="420" Width="520"
        Background="{DynamicResource BgBrush}" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True">
    <Border BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2"
            CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#1A000000">
                <TextBlock Text="Developer Diagnostics" Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="45" VerticalAlignment="Stretch" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,10,0,0">
                                <TextBlock Text="✕" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Controls -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="14,10,14,8">
                <ComboBox x:Name="cmbGame" Width="130" Margin="0,0,10,0"
                          BorderThickness="0" Background="{DynamicResource ControlBgBrush}"
                          Foreground="{DynamicResource TextBrush}">
                    <ComboBoxItem Content="GTA III" Tag="III"/>
                    <ComboBoxItem Content="GTA VC" Tag="VC"/>
                    <ComboBoxItem Content="GTA SA" Tag="SA"/>
                </ComboBox>
                <Button Content="Force Steam Verify" Click="BtnVerify_Click" Padding="10,0" Height="26"
                        Background="{DynamicResource PanelBrush}" Foreground="{DynamicResource TextBrush}"
                        BorderThickness="0" Cursor="Hand" Margin="0,0,8,0"/>
                <Button Content="MD5 Check" Click="BtnMd5_Click" Padding="10,0" Height="26"
                        Background="{DynamicResource PanelBrush}" Foreground="{DynamicResource AccentBrush}"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <!-- Log -->
            <TextBox x:Name="txtLog" Grid.Row="2" Background="#0D1117" Foreground="#39D353"
                     FontFamily="Consolas" FontSize="12" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Margin="14,0,14,0"/>

            <!-- Bottom close -->
            <Border Grid.Row="3" Padding="14,10" Background="#0A000000">
                <Button Content="Close Console" Click="BtnClose_Click" Height="28"
                        Background="{DynamicResource AccentBrush}" Foreground="Black"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </Border>
        </Grid>
    </Border>
</Window>
