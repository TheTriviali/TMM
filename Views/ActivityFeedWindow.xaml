<local:TmmWindow x:Class="TMM.ActivityFeedWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:local="clr-namespace:TMM"
                 Title="Recent Activity" Width="620" Height="520"
                 Background="{DynamicResource BgBrush}"
                 WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Recent activity (last 20)"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" CornerRadius="6" Padding="4">
            <ListView x:Name="lvFeed" BorderThickness="0" Background="Transparent"
                      Foreground="{DynamicResource TextBrush}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Time" Width="140" DisplayMemberBinding="{Binding TimeDisplay}"/>
                        <GridViewColumn Header="Kind" Width="110" DisplayMemberBinding="{Binding KindDisplay}"/>
                        <GridViewColumn Header="Game" Width="120" DisplayMemberBinding="{Binding GameName}"/>
                        <GridViewColumn Header="Detail" Width="220" DisplayMemberBinding="{Binding Detail}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Button Content="Clear History" Click="BtnClear_Click" HorizontalAlignment="Left"
                    Padding="14,6" Background="{DynamicResource ControlBgBrush}"
                    Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"/>
            <Button Content="Close" Click="BtnClose_Click" HorizontalAlignment="Right"
                    Padding="22,6" Background="{DynamicResource ControlBgBrush}"
                    Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"/>
        </Grid>
    </Grid>
</local:TmmWindow>
