<local:TmmWindow x:Class="TMM.ArchiveExtractionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        Title="Mod Installation Wizard" Height="310" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}" WindowStyle="None" AllowsTransparency="True">
    <Border BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            CornerRadius="10" Background="{DynamicResource BgBrush}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#18000000" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="Mod Installation Wizard" Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="40" VerticalAlignment="Stretch" Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,8,0,0">
                                <TextBlock Text="x" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="18,12,18,0">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Archive:" Foreground="{DynamicResource SubTextBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="txtArchiveName" Grid.Column="1" Text="mod.zip"
                               Foreground="{DynamicResource AccentBrush}" FontSize="13"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </Grid>

                <TextBlock Text="Select Target Games:" Foreground="{DynamicResource AccentBrush}"
                           FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                <CheckBox x:Name="chkAll" Content="All Games (Global Mod)"
                          Foreground="{DynamicResource TextBrush}" FontSize="12"
                          Margin="0,0,0,8" Checked="ChkAll_Changed" Unchecked="ChkAll_Changed"/>

                <UniformGrid Columns="3" Margin="16,0,0,0">
                    <CheckBox x:Name="chkIII" Content="GTA III"       Foreground="{DynamicResource TextBrush}" FontSize="12"/>
                    <CheckBox x:Name="chkVC"  Content="GTA Vice City"  Foreground="{DynamicResource TextBrush}" FontSize="12"/>
                    <CheckBox x:Name="chkSA"  Content="GTA San Andreas" Foreground="{DynamicResource TextBrush}" FontSize="12"/>
                </UniformGrid>
            </StackPanel>

            <!-- Bottom -->
            <Border Grid.Row="2" Padding="18,10" Background="#0A000000">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="txtStatus" Foreground="{DynamicResource SubTextBrush}"
                               VerticalAlignment="Center" FontSize="11"/>
                    <Button Grid.Column="2" x:Name="btnYesToAll" Content="Yes to All"
                            Height="30" Width="90"
                            Background="#2A7A2A" Foreground="White"
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnYesToAll_Click"/>
                    <Button Grid.Column="4" x:Name="btnInstall" Content="Extract &amp; Install"
                            Height="30" Width="130"
                            Background="{DynamicResource AccentBrush}" Foreground="Black"
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnInstall_Click"/>
                    <Button Grid.Column="6" Content="Cancel" Height="30" Width="70"
                            Background="{DynamicResource PanelBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
