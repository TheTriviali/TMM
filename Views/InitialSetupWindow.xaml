<local:TmmWindow x:Class="TMM.InitialSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        xmlns:helpers="clr-namespace:TMM.Helpers"
        Title="TMM — Welcome" Width="820" Height="500"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Loaded="Window_Loaded">

    <Border x:Name="RootBorder" CornerRadius="12" Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            MouseLeftButtonDown="TitleBar_MouseDown">
        <Border.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="White" CornerRadius="10"
                            Width="{Binding ActualWidth, ElementName=RootBorder}"
                            Height="{Binding ActualHeight, ElementName=RootBorder}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.OpacityMask>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Branding panel ─────────────────────────────────── -->
            <Border Grid.Column="0" Background="{DynamicResource AccentGradientBrush}">
                <Grid>
                    <Border Background="#1A000000"/>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="28,0">
                        <Border Width="64" Height="64" CornerRadius="16" Background="#25000000"
                                Margin="0,0,0,20" HorizontalAlignment="Center">
                            <TextBlock Text="T" FontSize="36" FontWeight="Black" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="6" ShadowDepth="1"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="TMM" FontSize="30" FontWeight="Black"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="6" ShadowDepth="1"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Mod Management Made Simple"
                                   FontSize="11" Foreground="White" Opacity="0.78"
                                   HorizontalAlignment="Center" Margin="0,0,0,36" TextAlignment="Center"/>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="✓" Foreground="White" Opacity="0.85"
                                           FontWeight="Bold" Margin="0,0,10,0" FontSize="12"/>
                                <TextBlock Text="Direct-deploy, no VFS"
                                           Foreground="White" Opacity="0.72" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="✓" Foreground="White" Opacity="0.85"
                                           FontWeight="Bold" Margin="0,0,10,0" FontSize="12"/>
                                <TextBlock Text="GTA III series built-in"
                                           Foreground="White" Opacity="0.72" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✓" Foreground="White" Opacity="0.85"
                                           FontWeight="Bold" Margin="0,0,10,0" FontSize="12"/>
                                <TextBlock Text="Custom game profiles"
                                           Foreground="White" Opacity="0.72" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="txtBrandVersion" Text="" VerticalAlignment="Bottom"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" Foreground="White" Opacity="0.4" FontSize="11"/>
                </Grid>
            </Border>

            <!-- ── RIGHT: Setup panel ───────────────────────────────────── -->
            <Grid Grid.Column="1" Background="{DynamicResource BgBrush}">
                <Border HorizontalAlignment="Left" Width="1"
                        Background="{DynamicResource AccentBrush}" Opacity="0.3"/>

                <StackPanel VerticalAlignment="Center" Margin="44,0,44,0">

                    <!-- Heading — live binding updates instantly on language switch -->
                    <TextBlock Text="{helpers:Localization Setup_Welcome}"
                               FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6"/>
                    <TextBlock Text="{helpers:Localization Setup_Subtitle}"
                               Foreground="{DynamicResource SubTextBrush}" FontSize="13"
                               Margin="0,0,0,28"/>

                    <!-- Quick-pick buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                        <!-- English button — always English regardless of active language -->
                        <Button x:Name="btnLangEn" Tag="en-US" Click="BtnQuickLang_Click"
                                Margin="0,0,10,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="7" BorderThickness="1.5"
                                            Padding="14,10"
                                            BorderBrush="{DynamicResource SubTextBrush}"
                                            Background="{DynamicResource PanelBrush}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <!-- Explicit letter-badge instead of tiny emoji -->
                                            <Border Width="26" Height="26" CornerRadius="4"
                                                    Background="#22FFFFFF" Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="EN" FontSize="11" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="English" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                                <TextBlock Text="International" FontSize="10"
                                                           Foreground="{DynamicResource SubTextBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush"
                                                    Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Spanish button — always Español -->
                        <Button x:Name="btnLangEs" Tag="es-MX" Click="BtnQuickLang_Click"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="7" BorderThickness="1.5"
                                            Padding="14,10"
                                            BorderBrush="{DynamicResource SubTextBrush}"
                                            Background="{DynamicResource PanelBrush}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="26" Height="26" CornerRadius="4"
                                                    Background="#22FFFFFF" Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="ES" FontSize="11" FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Español" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextBrush}"/>
                                                <TextBlock Text="Internacional" FontSize="10"
                                                           Foreground="{DynamicResource SubTextBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="BorderBrush"
                                                    Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                    <!-- "or choose from full list" ruled separator -->
                    <Grid Margin="0,4,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Height="1" Background="{DynamicResource ControlBgBrush}"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{helpers:Localization Setup_OrMore}"
                                   Foreground="{DynamicResource SubTextBrush}" FontSize="10"
                                   Opacity="0.6" Margin="10,0" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Height="1" Background="{DynamicResource ControlBgBrush}"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Full language dropdown -->
                    <ComboBox x:Name="cmbLanguage" Height="36" FontSize="13" Margin="0,0,0,28"
                              Background="{DynamicResource PanelBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource SubTextBrush}"
                              BorderThickness="1"
                              SelectionChanged="CmbLanguage_SelectionChanged"/>

                    <Border Height="1" Background="{DynamicResource ControlBgBrush}" Margin="0,0,0,24"/>

                    <!-- Game choice cards (merged from the former FirstGamePickerWindow) -->
                    <Border x:Name="opt1" CornerRadius="8" Padding="16,12" Margin="0,0,0,10"
                            MouseLeftButtonUp="Option1_Click" Cursor="Hand"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{DynamicResource AccentSoftBrush}"
                                    Margin="0,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{helpers:Localization Picker_BuiltinTitle}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3"/>
                                <TextBlock Text="{helpers:Localization Picker_BuiltinDesc}"
                                           FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="opt2" CornerRadius="8" Padding="16,12"
                            MouseLeftButtonUp="Option2_Click" Cursor="Hand"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{DynamicResource AccentSoftBrush}"
                                    Margin="0,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{helpers:Localization Picker_CustomTitle}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3"/>
                                <TextBlock Text="{helpers:Localization Picker_CustomDesc}"
                                           FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Skip button — text updates live -->
                    <Button Click="BtnClose_Click" Margin="0,12,0,0"
                            Height="40" HorizontalAlignment="Stretch"
                            BorderThickness="1" Cursor="Hand"
                            Background="Transparent"
                            BorderBrush="{DynamicResource SubTextBrush}"
                            Foreground="{DynamicResource SubTextBrush}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="7"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="12,0">
                                    <TextBlock Text="{helpers:Localization Setup_Skip}"
                                               Foreground="{TemplateBinding Foreground}"
                                               FontSize="12" FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background"
                                                Value="{DynamicResource ControlBgBrush}"/>
                                        <Setter TargetName="bd" Property="BorderBrush"
                                                Value="{DynamicResource TextBrush}"/>
                                        <Setter Property="Foreground"
                                                Value="{DynamicResource TextBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>

            <!-- ── X close overlay ──────────────────────────────────────── -->
            <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="34" Height="34" Margin="0,6,6,0"
                    Click="BtnClose_Click" Panel.ZIndex="99"
                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#C42B1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Grid>
    </Border>
</local:TmmWindow>
