<local:TmmWindow x:Class="TMM.InitialSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        xmlns:helpers="clr-namespace:TMM.Helpers"
        Title="TMM — Welcome" Width="820" Height="500"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Loaded="Window_Loaded">

    <Border x:Name="RootBorder" CornerRadius="12" Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            MouseLeftButtonDown="TitleBar_MouseDown">
        <Border.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="White" CornerRadius="10"
                            Width="{Binding ActualWidth, ElementName=RootBorder}"
                            Height="{Binding ActualHeight, ElementName=RootBorder}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.OpacityMask>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Branding panel ─────────────────────────────────── -->
            <Border Grid.Column="0" Background="{DynamicResource AccentGradientBrush}">
                <Grid>
                    <Border Background="#1A000000"/>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="28,0">
                        <Border Width="64" Height="64" CornerRadius="16" Background="#25000000"
                                Margin="0,0,0,20" HorizontalAlignment="Center">
                            <TextBlock Text="T" FontSize="36" FontWeight="Black" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="6" ShadowDepth="1"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="TMM" FontSize="30" FontWeight="Black"
                                   Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="6" ShadowDepth="1"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="{helpers:Localization Setup_Tagline}"
                                   FontSize="11" Foreground="White" Opacity="0.78"
                                   HorizontalAlignment="Center" Margin="0,0,0,36" TextAlignment="Center"/>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="✓" Foreground="White" Opacity="0.85"
                                           FontWeight="Bold" Margin="0,0,10,0" FontSize="12"/>
                                <TextBlock Text="{helpers:Localization Setup_Feature_DirectDeploy}"
                                           Foreground="White" Opacity="0.72" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="✓" Foreground="White" Opacity="0.85"
                                           FontWeight="Bold" Margin="0,0,10,0" FontSize="12"/>
                                <TextBlock Text="{helpers:Localization Setup_Feature_BuiltinGames}"
                                           Foreground="White" Opacity="0.72" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✓" Foreground="White" Opacity="0.85"
                                           FontWeight="Bold" Margin="0,0,10,0" FontSize="12"/>
                                <TextBlock Text="{helpers:Localization Setup_Feature_CustomProfiles}"
                                           Foreground="White" Opacity="0.72" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="txtBrandVersion" Text="" VerticalAlignment="Bottom"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14" Foreground="White" Opacity="0.4" FontSize="11"/>
                </Grid>
            </Border>

            <!-- ── RIGHT: Setup panel ───────────────────────────────────── -->
            <Grid Grid.Column="1" Background="{DynamicResource BgBrush}">
                <Border HorizontalAlignment="Left" Width="1"
                        Background="{DynamicResource AccentBrush}" Opacity="0.3"/>

                <!-- Language picker — corner control, not the focus -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right"
                            Margin="0,14,14,0">
                    <TextBlock Text="&#xF49A;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource SubTextBrush}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="cmbLanguage" Width="130" Height="24" FontSize="11"
                              Background="{DynamicResource PanelBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource SubTextBrush}"
                              BorderThickness="1"
                              SelectionChanged="CmbLanguage_SelectionChanged"/>
                </StackPanel>

                <StackPanel VerticalAlignment="Center" Margin="44,0,44,0">

                    <!-- Primary heading -->
                    <TextBlock Text="{helpers:Localization Setup_Welcome}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{helpers:Localization Setup_Subtitle}"
                               Foreground="{DynamicResource SubTextBrush}" FontSize="13"
                               Margin="0,0,0,28" TextWrapping="Wrap"/>

                    <!-- Step 1: Profile picker -->
                    <TextBlock Text="Step 1 — Select a game" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentLabelBrush}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="cmbProfile" Height="36" FontSize="13" Margin="0,0,0,14"
                              Background="{DynamicResource PanelBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1"
                              SelectionChanged="CmbProfile_SelectionChanged"/>

                    <!-- Step 2: Game directory (shown after profile selected) -->
                    <StackPanel x:Name="dirStep" Visibility="Collapsed" Margin="0,0,0,20">
                        <TextBlock Text="Step 2 — Set the game folder" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentLabelBrush}" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="10,8">
                                <TextBlock x:Name="txtDirDisplay" Text="Click Browse to select folder"
                                           Foreground="{DynamicResource SubTextBrush}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <Button Grid.Column="1" Content="Browse…" Click="BtnBrowseDir_Click"
                                    Margin="8,0,0,0" Height="36" Padding="12,0"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderThickness="0" FontSize="12" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>

                    <!-- Primary CTA: start with selected game -->
                    <Button x:Name="btnStartWithGame" Click="BtnStartWithGame_Click" Cursor="Hand"
                            IsEnabled="False" Margin="0,0,0,12">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="9"
                                        Background="{DynamicResource AccentBrush}"
                                        Padding="0,13" Opacity="{TemplateBinding Opacity}">
                                    <TextBlock Text="{helpers:Localization Setup_StartWithGame}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Secondary: skip to library -->
                    <Button Click="BtnGoToLibrary_Click" Cursor="Hand" Margin="0,0,0,16"
                            Background="Transparent" BorderThickness="0" Padding="0,8">
                        <TextBlock Text="{helpers:Localization Setup_GoToLibrary}"
                                   FontSize="12" Foreground="{DynamicResource SubTextBrush}"
                                   HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Separator -->
                    <Border Height="1" Background="{DynamicResource ControlBgBrush}" Margin="0,0,0,12"/>

                    <!-- Tertiary: custom game -->
                    <Border x:Name="opt2" CornerRadius="8" Padding="14,10"
                            MouseLeftButtonDown="Card_MouseDown"
                            MouseLeftButtonUp="Option2_Click" Cursor="Hand"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="6"
                                    Background="{DynamicResource AccentSoftBrush}"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{helpers:Localization Picker_CustomTitle}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2"/>
                                <TextBlock Text="{helpers:Localization Picker_CustomDesc}"
                                           FontSize="10" Foreground="{DynamicResource SubTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

            <!-- ── X close overlay ──────────────────────────────────────── -->
            <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="34" Height="34" Margin="0,6,6,0"
                    Click="BtnClose_Click" Panel.ZIndex="99"
                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#C42B1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Grid>
    </Border>
</local:TmmWindow>
