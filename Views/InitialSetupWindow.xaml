<local:TmmWindow x:Class="TMM.InitialSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        Title="TMM — Game Setup" Width="900" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Loaded="Window_Loaded">

    <Border CornerRadius="12" Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#18000000" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="TMM — Game Setup" Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="45" VerticalAlignment="Stretch" Click="BtnClose_Click"
                        ToolTip="Close (at least one game must be mapped first)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,10,0,0">
                                <TextBlock Text="x" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18,22,10">
                    <TextBlock Text="Welcome to TMM" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Locate your game executables. TMM will deploy mods directly to those directories."
                               Foreground="{DynamicResource SubTextBrush}" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,5,0,18"/>

                    <!-- GTA III Series -->
                    <TextBlock Text="GTA III Series" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentLabelBrush}" Margin="0,0,0,6"/>
                    <local:GameSetupRow x:Name="rowIII"/>
                    <local:GameSetupRow x:Name="rowVC"/>
                    <local:GameSetupRow x:Name="rowSA"/>

                    <!-- GTA IV Series -->
                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.15" Margin="0,16,0,14"/>
                    <TextBlock Text="GTA IV — Complete Edition" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentLabelBrush}" Margin="0,0,0,2"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"
                               TextWrapping="Wrap"
                               Text="Browse for GTAIV.exe and TMM will auto-detect The Lost and Damned (TLAD\) and The Ballad of Gay Tony (EFLC\) from the same folder. You can also browse for them individually if your layout differs."/>
                    <local:GameSetupRow x:Name="rowIV"/>
                    <local:GameSetupRow x:Name="rowTLaD"/>
                    <local:GameSetupRow x:Name="rowTBoGT"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom -->
            <Border Grid.Row="2" Padding="22,12" Background="#0A000000">
                <Button x:Name="BtnFinish" Content="Save &amp; Close" Click="BtnFinish_Click"
                        Height="38" FontSize="14" FontWeight="Bold"
                        Background="{DynamicResource AccentBrush}" Foreground="Black"
                        BorderThickness="0" Cursor="Hand"/>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
