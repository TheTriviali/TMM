<UserControl x:Class="TMM.WorkspaceHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             xmlns:helpers="clr-namespace:TMM.Helpers">
    <UserControl.Resources>
        <!-- Accent action button (Deploy) -->
        <Style x:Key="WsAccentBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,8"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost action button (Play) -->
        <Style x:Key="WsGhostBtn" TargetType="Button" BasedOn="{StaticResource WsAccentBtn}">
            <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>

        <!-- Round icon button (back, overflow) -->
        <Style x:Key="WsIconBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="38"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontFamily"      Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- identity + actions -->
            <RowDefinition Height="Auto"/>  <!-- pending banner -->
        </Grid.RowDefinitions>

        <!-- ── Identity row ── -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}">
            <Grid Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- back -->
                    <ColumnDefinition Width="Auto"/> <!-- cover -->
                    <ColumnDefinition Width="*"/>    <!-- title/meta -->
                    <ColumnDefinition Width="Auto"/> <!-- actions -->
                </Grid.ColumnDefinitions>

                <!-- Back to library -->
                <Button Grid.Column="0" x:Name="btnBack" Style="{StaticResource WsIconBtn}"
                        Content="&#xE72B;" ToolTip="{helpers:Localization Workspace_BackToLibrary}"
                        VerticalAlignment="Center" Margin="0,0,12,0"
                        Click="BtnBack_Click"/>

                <!-- Cover tile -->
                <Border Grid.Column="1" x:Name="coverTile" Width="56" Height="56" CornerRadius="10"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="coverText" FontWeight="Black" FontSize="20"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Title + meta -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="14,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="txtTitle" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <!-- Readiness badge -->
                        <Border x:Name="readyBadge" CornerRadius="9" Padding="8,2" Margin="12,1,0,0"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AccentSoftBrush}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="readyDot" Width="7" Height="7"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock x:Name="readyText" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="txtMeta" FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SubTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Actions: Install · Deploy · Play · overflow -->
                <StackPanel Grid.Column="3" x:Name="actionsPanel"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnInstall" Style="{StaticResource WsGhostBtn}" Margin="0,0,10,0"
                            Click="BtnInstall_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,7,0"/>
                            <TextBlock Text="{helpers:Localization ModManager_Install}"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnDeploy" Style="{StaticResource WsAccentBtn}" Margin="0,0,10,0"
                            Click="BtnDeploy_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,7,0"/>
                            <TextBlock Text="{helpers:Localization ModManager_Deploy}"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnPlay" Style="{StaticResource WsGhostBtn}" Margin="0,0,8,0"
                            Click="BtnPlay_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,7,0"/>
                            <TextBlock Text="{helpers:Localization ModManager_Play}"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnOverflow" Style="{StaticResource WsIconBtn}"
                            Content="&#xE712;" ToolTip="{helpers:Localization Workspace_More}"
                            Click="BtnOverflow_Click">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="overflowMenu">
                                <MenuItem Header="{helpers:Localization ModManager_EditConfig}"     Click="Overflow_Click" Tag="config"/>
                                <Separator/>
                                <MenuItem Header="{helpers:Localization ModManager_Refresh}"         Click="Overflow_Click" Tag="refresh"/>
                                <MenuItem Header="{helpers:Localization ModManager_Empty_Import}"    Click="Overflow_Click" Tag="import"/>
                                <MenuItem Header="{helpers:Localization ModManager_CtxOpenModsFolder}" Click="Overflow_Click" Tag="openmods"/>
                                <Separator/>
                                <MenuItem Header="{helpers:Localization ModManager_Rollback}"        Click="Overflow_Click" Tag="rollback"/>
                                <Separator/>
                                <MenuItem Header="{helpers:Localization ModManager_Help}"            Click="Overflow_Click" Tag="help"/>
                                <MenuItem Header="{helpers:Localization ModManager_About}"           Click="Overflow_Click" Tag="about"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Pending-changes banner ── -->
        <Border Grid.Row="1" x:Name="pendingBanner" Padding="20,8" Visibility="Collapsed"
                Background="#22E0A020">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="#E0A020" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="pendingText" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextBrush}"/>
                <Button x:Name="btnReviewDeploy" Content="{helpers:Localization Workspace_ReviewDeploy}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="#E0A020" Padding="10,3" Margin="12,0,0,0" FontSize="12"
                        Click="BtnReviewDeploy_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
