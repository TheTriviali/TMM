<UserControl x:Class="TMM.GameCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             Width="240" Height="160"
             Cursor="Hand">
    <Border x:Name="cardBorder" CornerRadius="10" ClipToBounds="True"
            BorderThickness="1.5" BorderBrush="#22FFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.35" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <!-- ── Shared background layers ─────────────────────────────── -->
            <Border x:Name="gradientBg" CornerRadius="10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop x:Name="gradStart" Color="#1B3A1B" Offset="0"/>
                        <GradientStop x:Name="gradEnd"   Color="#0C1E0C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border x:Name="noiseOverlay" CornerRadius="10" Opacity="0.04"
                    Background="{DynamicResource TextBrush}"/>
            <Border x:Name="archivedOverlay" CornerRadius="10"
                    Background="#80000000" Visibility="Collapsed"/>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- CARD MODE (grid / large) — default                         -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid x:Name="cardModeRoot">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>       <!-- art + actions area -->
                    <RowDefinition Height="22"/>      <!-- info strip -->
                </Grid.RowDefinitions>

                <!-- Art / title area -->
                <Grid Grid.Row="0">
                    <!-- Big title text — centred, clears action row -->
                    <TextBlock x:Name="txtArtTitle"
                               Text="GAME TITLE"
                               Foreground="#E8FFFFFF"
                               FontSize="22" FontWeight="Black"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="14,8,14,36"
                               LineHeight="26"/>

                    <!-- Always-visible action buttons (bottom-right, above info strip) -->
                    <StackPanel x:Name="actionRow"
                                Orientation="Horizontal"
                                VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                Margin="0,0,8,6">
                        <!-- Play / Launch (primary accent) -->
                        <Button x:Name="btnPlay" Width="24" Height="24" Margin="0,0,3,0"
                                ToolTip="Launch game" Click="BtnPlay_Click" Focusable="True"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="{DynamicResource AccentBrush}" CornerRadius="5"
                                            Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="▶" FontSize="9" Foreground="#06222E"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#80000000"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Manage mods -->
                        <Button x:Name="btnManage" Width="24" Height="24" Margin="0,0,3,0"
                                ToolTip="Manage mods" Click="BtnManage_Click" Focusable="True"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="#66000000" BorderBrush="#44FFFFFF"
                                            BorderThickness="1" CornerRadius="5"
                                            Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="☰" FontSize="10" Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#BB000000"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Edit (hidden; use Mod Manager → Edit Config) -->
                        <Button x:Name="btnEdit" Width="24" Height="24" Margin="0,0,3,0"
                                ToolTip="Edit game" Click="BtnEdit_Click" Focusable="True"
                                Visibility="Collapsed"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="#66000000" BorderBrush="#44FFFFFF"
                                            BorderThickness="1" CornerRadius="5"
                                            Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="⚙" FontSize="10" Foreground="#CCFFFFFF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#BB000000"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Export (custom games only, hidden otherwise) -->
                        <Button x:Name="btnExport" Width="24" Height="24" Margin="0,0,3,0"
                                ToolTip="Export game profile (.tmmgame)"
                                Click="BtnExport_Click" Visibility="Collapsed" Focusable="True"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" Background="#66000000" BorderBrush="#44FFFFFF"
                                            BorderThickness="1" CornerRadius="5"
                                            Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="↑" FontSize="11" Foreground="#CCFFFFFF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#BB000000"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="b" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Archive / Unarchive / Delete -->
                        <Button x:Name="btnArchiveOrDelete" Width="24" Height="24"
                                ToolTip="Archive game" Click="BtnArchiveOrDelete_Click" Focusable="True"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="archiveBorder" Background="#66000000"
                                            BorderBrush="#44FFFFFF" BorderThickness="1" CornerRadius="5"
                                            Padding="{TemplateBinding Padding}">
                                        <TextBlock x:Name="archiveIcon" Text="⊟" FontSize="10"
                                                   Foreground="#CCFFFFFF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="archiveBorder" Property="Background" Value="#BB000000"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="archiveBorder" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Ready dot (bottom-left, above info strip) -->
                    <Ellipse x:Name="readyDot"
                             Width="8" Height="8"
                             VerticalAlignment="Bottom" HorizontalAlignment="Left"
                             Margin="12,0,0,7"
                             Panel.ZIndex="5">
                        <Ellipse.Effect>
                            <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>

                <!-- Info strip (row 1) -->
                <Border Grid.Row="1" CornerRadius="0,0,10,10"
                        Background="#AA000000" Padding="8,0">
                    <Grid VerticalAlignment="Center">
                        <TextBlock x:Name="txtSubtitle"
                                   Foreground="#CCFFFFFF" FontSize="10"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,40,0"/>
                        <TextBlock x:Name="txtModCount"
                                   Foreground="#88FFFFFF" FontSize="9"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── Status chip (top-right, over everything) ─────────────── -->
            <Border x:Name="statusChip"
                    CornerRadius="3" Padding="6,2"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="0,8,8,0" Visibility="Collapsed">
                <TextBlock x:Name="txtStatus" FontSize="9" FontWeight="Bold"
                           Foreground="White"/>
            </Border>

            <!-- ── Default-game checkbox (top-left, over everything) ──────── -->
            <Border x:Name="defaultCheckbox"
                    Width="18" Height="18" CornerRadius="4"
                    VerticalAlignment="Top" HorizontalAlignment="Left"
                    Margin="8,8,0,0"
                    BorderThickness="1.5" BorderBrush="#66FFFFFF"
                    Background="Transparent" Cursor="Hand"
                    ToolTip="Set as default game"
                    MouseLeftButtonUp="DefaultCheckbox_Click">
                <TextBlock x:Name="defaultCheckmark"
                           Text="✓" FontSize="9" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- LIST MODE — full-width × 72px row                          -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid x:Name="listModeRoot" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>   <!-- drag grip -->
                    <ColumnDefinition Width="36"/>   <!-- default checkbox -->
                    <ColumnDefinition Width="*"/>    <!-- title + subtitle (with inline pills) -->
                    <ColumnDefinition Width="22"/>   <!-- ready dot -->
                    <ColumnDefinition Width="Auto"/> <!-- action buttons -->
                    <ColumnDefinition Width="10"/>   <!-- right padding -->
                </Grid.ColumnDefinitions>

                <!-- Drag grip -->
                <Border Grid.Column="0" x:Name="listDragHandle"
                        Background="Transparent" Cursor="SizeAll"
                        ToolTip="Drag to reorder"
                        VerticalAlignment="Stretch" Margin="4,0,0,0">
                    <TextBlock Text="⠿" FontSize="14" Foreground="#88FFFFFF"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <!-- Default checkbox (list mode) -->
                <Border Grid.Column="1" x:Name="listDefaultCheckbox"
                        Width="18" Height="18" CornerRadius="4"
                        BorderThickness="1.5" BorderBrush="#66FFFFFF"
                        Background="Transparent" Cursor="Hand"
                        ToolTip="Set as default game"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        MouseLeftButtonUp="DefaultCheckbox_Click">
                    <TextBlock x:Name="listDefaultCheckmark"
                               Text="✓" FontSize="9" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Border>

                <!-- Title + Subtitle with inline pills -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0,8,0">
                    <TextBlock x:Name="listTxtTitle"
                               Foreground="#F4FFFFFF" FontSize="15" FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               TextOptions.TextRenderingMode="ClearType"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0" VerticalAlignment="Center">
                        <!-- Archived badge -->
                        <Border x:Name="listArchivedTag"
                                CornerRadius="2" Padding="4,1" Margin="0,0,5,0"
                                Background="#1FFFFFFF" Visibility="Collapsed">
                            <TextBlock Text="ARCHIVED" FontSize="8" FontWeight="Bold"
                                       Foreground="#A0FFFFFF" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Status pill (inline, colored) -->
                        <Border x:Name="listStatusPill"
                                CornerRadius="2" Padding="5,1" Margin="0,0,6,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="listTxtStatus"
                                       FontSize="8" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Subtitle text -->
                        <TextBlock x:Name="listTxtSubtitle"
                                   Foreground="#C0FFFFFF" FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <!-- Mod count -->
                        <TextBlock x:Name="listTxtModCount"
                                   Foreground="#66FFFFFF" FontSize="11" Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Ready dot -->
                <Ellipse Grid.Column="3" x:Name="listReadyDot"
                         Width="8" Height="8" VerticalAlignment="Center"
                         HorizontalAlignment="Center">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#000000" Opacity="0.5"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- Action buttons (list mode) -->
                <StackPanel Grid.Column="4" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="4,0,0,0">
                    <Button x:Name="listBtnPlay" Width="26" Height="26" Margin="0,0,3,0"
                            ToolTip="Launch game" Click="BtnPlay_Click" Focusable="True"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="{DynamicResource AccentBrush}" CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="▶" FontSize="9" Foreground="#06222E"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#80000000"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="listBtnManage" Width="26" Height="26" Margin="0,0,3,0"
                            ToolTip="Manage mods" Click="BtnManage_Click" Focusable="True"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="#55000000" BorderBrush="#44FFFFFF"
                                        BorderThickness="1" CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="☰" FontSize="10" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#AA000000"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="listBtnEdit" Width="26" Height="26" Margin="0,0,3,0"
                            ToolTip="Edit game" Click="BtnEdit_Click" Focusable="True"
                            Visibility="Collapsed"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="#55000000" BorderBrush="#44FFFFFF"
                                        BorderThickness="1" CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="⚙" FontSize="10" Foreground="#CCFFFFFF"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#AA000000"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="b" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="listBtnArchiveOrDelete" Width="26" Height="26"
                            ToolTip="Archive game" Click="BtnArchiveOrDelete_Click" Focusable="True"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ab" Background="#55000000" BorderBrush="#44FFFFFF"
                                        BorderThickness="1" CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <TextBlock x:Name="listArchiveIcon" Text="⊟" FontSize="10"
                                               Foreground="#CCFFFFFF"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ab" Property="Background" Value="#AA000000"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ab" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Hover overlay (topmost, both modes) -->
            <Border x:Name="hoverOverlay" CornerRadius="10"
                    Background="Transparent" Opacity="0"/>
        </Grid>
    </Border>
</UserControl>
