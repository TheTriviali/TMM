<UserControl x:Class="TMM.GameCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             xmlns:helpers="clr-namespace:TMM.Helpers"
             Width="240" Height="160"
             Cursor="Hand">

    <!-- Context menu — right-click OR ⋯ button (both modes) -->
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem x:Name="menuEdit"
                      Header="{helpers:Localization Card_Edit}"
                      Click="BtnEdit_Click" Visibility="Collapsed"/>
            <MenuItem x:Name="menuExport"
                      Header="{helpers:Localization Card_ExportProfile}"
                      Click="BtnExport_Click" Visibility="Collapsed"/>
            <Separator x:Name="menuSepCustom" Visibility="Collapsed"/>
            <MenuItem x:Name="menuArchive"
                      Header="{helpers:Localization Card_Archive}"
                      Click="BtnArchiveOrDelete_Click"/>
            <Separator/>
            <MenuItem Header="{helpers:Localization Card_Appearance}" Click="MenuAppearance_Click"/>
        </ContextMenu>
    </UserControl.ContextMenu>

    <UserControl.ToolTip>
        <ToolTip Content="{helpers:Localization Card_RightClickHint}"/>
    </UserControl.ToolTip>

    <Border x:Name="cardBorder" CornerRadius="10" ClipToBounds="True"
            BorderThickness="1.5" BorderBrush="#22FFFFFF">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.35" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <!-- ── Shared background layers ─────────────────────────────── -->
            <Border x:Name="gradientBg" CornerRadius="10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop x:Name="gradStart" Color="#1B3A1B" Offset="0"/>
                        <GradientStop x:Name="gradEnd"   Color="#0C1E0C" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border x:Name="noiseOverlay" CornerRadius="10" Opacity="0.04"
                    Background="{DynamicResource TextBrush}"/>
            <Border x:Name="archivedOverlay" CornerRadius="10"
                    Background="#80000000" Visibility="Collapsed"/>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- CARD MODE (grid / large) — default                         -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid x:Name="cardModeRoot">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- art zone: title + mod count -->
                    <RowDefinition Height="Auto"/> <!-- unified footer control bar -->
                </Grid.RowDefinitions>

                <!-- ── Art zone (row 0): centred title + quiet mod count ── -->
                <Grid Grid.Row="0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="12,10,12,4">
                        <TextBlock x:Name="txtArtTitle"
                                   Text="GAME TITLE"
                                   Foreground="#E8FFFFFF"
                                   FontSize="19" FontWeight="Black"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   LineHeight="23"/>
                        <TextBlock x:Name="txtModCount"
                                   Foreground="#80FFFFFF" FontSize="10"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock x:Name="txtTmmGameFile"
                                   Foreground="#50FFFFFF" FontSize="8.5"
                                   HorizontalAlignment="Center" Margin="0,3,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- Drag grip (top-left, faint → solid on hover; locked for active card) -->
                    <Border x:Name="cardDragHandle"
                            VerticalAlignment="Top" HorizontalAlignment="Left"
                            Margin="5,4,0,0" Padding="4,3"
                            Background="Transparent" Cursor="SizeAll"
                            ToolTip="Drag to reorder (active card is locked to first)">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0.25"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="⠿" FontSize="14" Foreground="#AAFFFFFF"/>
                    </Border>
                </Grid>

                <!-- ── Unified footer bar (row 1): Play · Manage · ★ · ⋯ ── -->
                <Border Grid.Row="1" CornerRadius="0,0,10,10"
                        Background="#9E000000" Padding="7,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>      <!-- Play -->
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>      <!-- Manage -->
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="Auto"/>   <!-- ★ default -->
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>   <!-- ⋯ overflow -->
                        </Grid.ColumnDefinitions>

                        <!-- ▶ Play (primary, accent) -->
                        <Button x:Name="btnPlayCard" Grid.Column="0" Height="28"
                                Click="BtnPlay_Click" Focusable="True"
                                ToolTip="{helpers:Localization Library_LaunchGame}"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="playCardBg"
                                            Background="{DynamicResource AccentBrush}"
                                            CornerRadius="6">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="▶" FontSize="8" Foreground="#06222E" Margin="0,0,5,0"/>
                                            <TextBlock Text="{helpers:Localization Card_Play}" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#06222E"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="playCardBg" Property="Opacity" Value="0.82"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="playCardBg" Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- ☰ Manage (secondary, ghost) -->
                        <Button x:Name="btnManageCard" Grid.Column="2" Height="28"
                                Click="BtnManage_Click" Focusable="True"
                                ToolTip="{helpers:Localization Library_ManageMods}"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="manageCardBg"
                                            Background="#3CFFFFFF" BorderBrush="#2EFFFFFF"
                                            BorderThickness="1" CornerRadius="6">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="☰" FontSize="10" Foreground="#E0FFFFFF" Margin="0,0,5,0"/>
                                            <TextBlock Text="{helpers:Localization Card_Manage}" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#E0FFFFFF"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="manageCardBg" Property="Background" Value="#5AFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="manageCardBg" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- ★ Active toggle -->
                        <Button x:Name="btnDefaultCard"
                                Grid.Column="4" Width="28" Height="28" Cursor="Hand"
                                Click="BtnDefault_Click" Focusable="True"
                                ToolTip="Set as active game (auto-opens in Mod Manager on relaunch)"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="defaultCardPillBg"
                                            CornerRadius="6"
                                            Background="#22FFFFFF"
                                            BorderThickness="1" BorderBrush="#40FFFFFF">
                                        <TextBlock x:Name="defaultCardStar"
                                                   Text="☆" FontSize="13" Foreground="#C0FFFFFF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="defaultCardPillBg" Property="Background" Value="#44FFFFFF"/>
                                            <Setter TargetName="defaultCardPillBg" Property="BorderBrush" Value="#66FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="defaultCardPillBg" Property="Background" Value="#20FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- ⋯ Overflow (quiet icon) -->
                        <Button x:Name="btnOverflowCard"
                                Grid.Column="6" Width="28" Height="28" Cursor="Hand"
                                Click="BtnOverflow_Click" Focusable="True"
                                ToolTip="More options"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="overflowCardBg"
                                            Background="#19FFFFFF" BorderBrush="#26FFFFFF"
                                            BorderThickness="1" CornerRadius="6">
                                        <TextBlock Text="⋯" FontSize="13" Foreground="#D8FFFFFF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="overflowCardBg" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="overflowCardBg" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── Readiness badge (top-right overlay, card mode) ───────── -->
            <!-- IsHitTestVisible=True only for Needs-folder state; set in code-behind -->
            <Button x:Name="readinessBadge"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="0,8,8,0"
                    Background="Transparent" BorderThickness="0" Padding="0"
                    Cursor="Hand" Click="ReadinessBadge_Click"
                    IsHitTestVisible="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="readinessBadgeBg"
                                CornerRadius="4" Padding="6,3">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse x:Name="readinessDot"
                                         Width="5" Height="5"
                                         Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="readinessTxt"
                                           FontSize="9" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="readinessBadgeBg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- LIST MODE — full-width × 72px row                          -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Grid x:Name="listModeRoot" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34"/>   <!-- drag grip -->
                    <ColumnDefinition Width="Auto"/> <!-- default pill -->
                    <ColumnDefinition Width="*"/>    <!-- title + subtitle -->
                    <ColumnDefinition Width="Auto"/> <!-- readiness badge -->
                    <ColumnDefinition Width="Auto"/> <!-- action buttons -->
                    <ColumnDefinition Width="10"/>   <!-- right padding -->
                </Grid.ColumnDefinitions>

                <!-- Drag grip -->
                <Border Grid.Column="0" x:Name="listDragHandle"
                        Background="Transparent" Cursor="SizeAll"
                        ToolTip="Drag to reorder"
                        VerticalAlignment="Stretch" Margin="4,0,0,0">
                    <TextBlock Text="⠿" FontSize="14" Foreground="#88FFFFFF"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <!-- ★ Default pill toggle (list mode) -->
                <Button x:Name="listBtnDefault"
                        Grid.Column="1" Height="26" Cursor="Hand"
                        Margin="4,0,6,0" Padding="0"
                        Click="BtnDefault_Click" Focusable="True"
                        ToolTip="Toggle as active game"
                        Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="defaultListPillBg"
                                    CornerRadius="13" Padding="9,2"
                                    Background="#22FFFFFF"
                                    BorderThickness="1" BorderBrush="#40FFFFFF">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="defaultListStar"
                                               Text="☆" FontSize="9" Foreground="#C0FFFFFF"
                                               Margin="0,0,3,0"/>
                                    <TextBlock x:Name="defaultListLabel"
                                               Text="{helpers:Localization Card_Active}"
                                               FontSize="9" FontWeight="SemiBold" Foreground="#C0FFFFFF"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="defaultListPillBg" Property="Background" Value="#40FFFFFF"/>
                                    <Setter TargetName="defaultListPillBg" Property="BorderBrush" Value="#66FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="defaultListPillBg" Property="Background" Value="#20FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Title + Subtitle with inline pills -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="4,0,8,0">
                    <TextBlock x:Name="listTxtTitle"
                               Foreground="#F4FFFFFF" FontSize="15" FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               TextOptions.TextRenderingMode="ClearType"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0" VerticalAlignment="Center">
                        <!-- Archived badge -->
                        <Border x:Name="listArchivedTag"
                                CornerRadius="2" Padding="4,1" Margin="0,0,5,0"
                                Background="#1FFFFFFF" Visibility="Collapsed">
                            <TextBlock Text="Archived" FontSize="8" FontWeight="Bold"
                                       Foreground="#A0FFFFFF" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Subtitle text -->
                        <TextBlock x:Name="listTxtSubtitle"
                                   Foreground="#C0FFFFFF" FontSize="11"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <!-- Mod count -->
                        <TextBlock x:Name="listTxtModCount"
                                   Foreground="#66FFFFFF" FontSize="11" Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                        <!-- .tmmgame filename -->
                        <TextBlock x:Name="listTxtTmmGameFile"
                                   Foreground="#44FFFFFF" FontSize="9.5" Margin="10,0,0,0"
                                   VerticalAlignment="Center" Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>

                <!-- Readiness badge (list mode) -->
                <Button x:Name="listReadinessBadge"
                        Grid.Column="3" Margin="6,0,6,0"
                        Background="Transparent" BorderThickness="0" Padding="0"
                        Cursor="Hand" Click="ReadinessBadge_Click"
                        VerticalAlignment="Center" IsHitTestVisible="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="listReadinessBadgeBg"
                                    CornerRadius="4" Padding="6,3">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse x:Name="listReadinessDot"
                                             Width="5" Height="5"
                                             Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="listReadinessTxt"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="listReadinessBadgeBg" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Action buttons: ▶ Play · ☰ Manage · ⋯ -->
                <StackPanel Grid.Column="4" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="4,0,0,0">
                    <!-- ▶ Play -->
                    <Button x:Name="listBtnPlay" Height="32" Margin="0,0,4,0"
                            ToolTip="{helpers:Localization Library_LaunchGame}"
                            Click="BtnPlay_Click" Focusable="True"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="listPlayBg"
                                        Background="{DynamicResource AccentBrush}"
                                        CornerRadius="5" Padding="10,0">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="▶" FontSize="8" Foreground="#06222E" Margin="0,0,5,0"/>
                                        <TextBlock Text="{helpers:Localization Card_Play}" FontSize="10"
                                                   FontWeight="SemiBold" Foreground="#06222E"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="listPlayBg" Property="Opacity" Value="0.82"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="listPlayBg" Property="Opacity" Value="0.6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- ☰ Manage -->
                    <Button x:Name="listBtnManage" Height="32" Margin="0,0,4,0"
                            ToolTip="{helpers:Localization Library_ManageMods}"
                            Click="BtnManage_Click" Focusable="True"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="listManageBg"
                                        Background="#55000000" BorderBrush="#44FFFFFF"
                                        BorderThickness="1" CornerRadius="5" Padding="10,0">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="☰" FontSize="10" Foreground="White" Margin="0,0,5,0"/>
                                        <TextBlock Text="{helpers:Localization Card_Manage}" FontSize="10"
                                                   FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="listManageBg" Property="Background" Value="#AA000000"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="listManageBg" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- ⋯ Overflow -->
                    <Button x:Name="listBtnOverflow" Width="34" Height="32"
                            ToolTip="More options"
                            Click="BtnOverflow_Click" Focusable="True"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="listOverflowBg"
                                        Background="#44000000" BorderBrush="#33FFFFFF"
                                        BorderThickness="1" CornerRadius="5">
                                    <TextBlock Text="⋯" FontSize="12" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="listOverflowBg" Property="Background" Value="#88000000"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="listOverflowBg" Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Hover overlay (topmost, both modes).
                 IsHitTestVisible=False is REQUIRED: a Transparent background is still
                 hit-testable in WPF, so without this the overlay sits on top of every
                 button and swallows their clicks (the whole card behaves as one button). -->
            <Border x:Name="hoverOverlay" CornerRadius="10"
                    Background="Transparent" Opacity="0"
                    IsHitTestVisible="False"/>
        </Grid>
    </Border>
</UserControl>
