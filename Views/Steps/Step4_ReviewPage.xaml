<UserControl x:Class="TMM.Step4_ReviewPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             xmlns:helpers="clr-namespace:TMM.Helpers"
             Background="{DynamicResource BgBrush}">

    <UserControl.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin"     Value="0,14,0,6"/>
        </Style>
        <Style x:Key="ReviewRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ReviewKey" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Width"      Value="100"/>
        </Style>
        <Style x:Key="ReviewVal" TargetType="TextBlock">
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="Foreground"    Value="{DynamicResource TextBrush}"/>
            <Setter Property="TextWrapping"  Value="Wrap"/>
        </Style>
        <Style x:Key="RobustBtn" TargetType="RadioButton">
            <Setter Property="Margin"       Value="0,0,8,0"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Cursor"       Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,16,28,24" MaxWidth="660">

            <TextBlock Text="{helpers:Localization Step4_Intro}"
                       FontSize="12" Foreground="{DynamicResource SubTextBrush}"
                       Margin="0,0,0,8" TextWrapping="Wrap"/>

            <!-- ── Game Details ── -->
            <Border BorderBrush="{DynamicResource ControlBgBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,0"/>
            <TextBlock Text="{helpers:Localization Step4_GameDetails_Header}" Style="{StaticResource SectionTitle}"/>

            <Grid Style="{StaticResource ReviewRow}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{helpers:Localization Step4_Name_Label}" Style="{StaticResource ReviewKey}"/>
                <TextBlock x:Name="lblName" Grid.Column="1" Style="{StaticResource ReviewVal}"/>
            </Grid>
            <Grid Style="{StaticResource ReviewRow}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{helpers:Localization Step4_Directory_Label}" Style="{StaticResource ReviewKey}"/>
                <TextBlock x:Name="lblDir" Grid.Column="1" Style="{StaticResource ReviewVal}"/>
            </Grid>
            <Grid Style="{StaticResource ReviewRow}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{helpers:Localization Step4_Executable_Label}" Style="{StaticResource ReviewKey}"/>
                <TextBlock x:Name="lblExe" Grid.Column="1" Style="{StaticResource ReviewVal}"/>
            </Grid>
            <Grid Style="{StaticResource ReviewRow}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{helpers:Localization Step4_SteamID_Label}" Style="{StaticResource ReviewKey}"/>
                <TextBlock x:Name="lblSteam" Grid.Column="1" Style="{StaticResource ReviewVal}"/>
            </Grid>
            <Grid Style="{StaticResource ReviewRow}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{helpers:Localization Step4_Integrity_Label}" Style="{StaticResource ReviewKey}"/>
                <TextBlock x:Name="lblIntegrity" Grid.Column="1" Style="{StaticResource ReviewVal}"/>
            </Grid>
            <Grid Style="{StaticResource ReviewRow}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{helpers:Localization Step4_NexusSlug_Label}" Style="{StaticResource ReviewKey}"/>
                <TextBlock x:Name="lblNexusSlug" Grid.Column="1" Style="{StaticResource ReviewVal}"/>
            </Grid>

            <!-- ── Mod Types ── -->
            <Border BorderBrush="{DynamicResource ControlBgBrush}" BorderThickness="0,0,0,1" Margin="0,8,0,0"/>
            <TextBlock Text="{helpers:Localization Step4_ModTypes_Header}" Style="{StaticResource SectionTitle}"/>
            <ItemsControl x:Name="icModTypeSummary">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextBrush}"
                                   Text="{Binding}" Margin="0,0,0,3"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock x:Name="lblNoModTypes" Text="{helpers:Localization Step4_ModTypes_None}"
                       FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                       Opacity="0.6" Visibility="Collapsed"/>

            <!-- ── Profile Settings ── -->
            <Border BorderBrush="{DynamicResource ControlBgBrush}" BorderThickness="0,0,0,1" Margin="0,8,0,0"/>
            <TextBlock Text="{helpers:Localization Step4_ProfileSettings_Header}" Style="{StaticResource SectionTitle}"/>

            <TextBlock Text="{helpers:Localization Step4_Robustness_Label}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <RadioButton x:Name="rbExperimental" Content="{helpers:Localization Step4_Robustness_Experimental}"
                             Style="{StaticResource RobustBtn}"/>
                <RadioButton x:Name="rbStable" Content="{helpers:Localization Step4_Robustness_Stable}" IsChecked="True"
                             Style="{StaticResource RobustBtn}"/>
                <RadioButton x:Name="rbMature" Content="{helpers:Localization Step4_Robustness_Mature}"
                             Style="{StaticResource RobustBtn}"/>
            </StackPanel>

            <TextBlock Text="{helpers:Localization Step4_CustomTag_Label}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
            <TextBlock Text="{helpers:Localization Step4_CustomTag_Hint}"
                       FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                       Opacity="0.6" Margin="0,0,0,6"/>
            <TextBox x:Name="txtCustomTag"
                     Background="{DynamicResource ControlBgBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource SubTextBrush}"
                     BorderThickness="1" Padding="8,5" FontSize="12"
                     Width="260" HorizontalAlignment="Left" Margin="0,0,0,12"/>

            <CheckBox x:Name="chkNative" Margin="0,0,0,0"
                      Foreground="{DynamicResource TextBrush}">
                <TextBlock>
                    <Run Text="{helpers:Localization Step4_NativeProfile_Label}" FontWeight="SemiBold"/>
                    <Run Text="{helpers:Localization Step4_NativeProfile_Hint}"
                         Foreground="{DynamicResource SubTextBrush}" FontSize="10"/>
                </TextBlock>
            </CheckBox>

        </StackPanel>
    </ScrollViewer>
</UserControl>
