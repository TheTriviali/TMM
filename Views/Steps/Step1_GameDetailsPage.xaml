<UserControl x:Class="TMM.Step1_GameDetailsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             xmlns:helpers="clr-namespace:TMM.Helpers"
             Background="{DynamicResource BgBrush}">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Opacity"    Value="0.55"/>
            <Setter Property="Margin"     Value="0,-2,0,6"/>
            <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24" MaxWidth="620">

            <TextBlock Text="{helpers:Localization Step1_Intro}" FontSize="13"
                       Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,24"/>

            <!-- Game Name -->
            <TextBlock Text="{helpers:Localization Step1_GameName_Label}" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtGameName" Style="{StaticResource FieldBox}"
                     Margin="0,0,0,16"
                     TextChanged="ValidateInputs"/>

            <!-- Install Directory -->
            <TextBlock Text="{helpers:Localization Step1_InstallDir_Label}" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{helpers:Localization Step1_InstallDir_Hint}"
                       Style="{StaticResource FieldHint}"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtInstallDir" Style="{StaticResource FieldBox}"
                         Margin="0"
                         TextChanged="ValidateInputs"/>
                <Button Grid.Column="2" Content="{helpers:Localization Button_BrowseDir}" Style="{StaticResource BrowseBtn}"
                        Click="BtnBrowseDir_Click"/>
            </Grid>

            <!-- Path status -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock x:Name="txtDirStatus" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Executable Path -->
            <TextBlock Text="{helpers:Localization Step1_ExePath_Label}" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{helpers:Localization Step1_ExePath_Hint}"
                       Style="{StaticResource FieldHint}"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtExePath" Style="{StaticResource FieldBox}"
                         Margin="0"/>
                <Button Grid.Column="2" Content="{helpers:Localization Button_BrowseDir}" Style="{StaticResource BrowseBtn}"
                        Click="BtnBrowseExe_Click"/>
            </Grid>

            <!-- Steam App ID -->
            <TextBlock Text="{helpers:Localization Step1_SteamAppId_Label}" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="{helpers:Localization Step1_SteamAppId_Hint}"
                       Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="txtSteamAppId" Style="{StaticResource FieldBox}"
                     Margin="0,0,0,0" Width="160" HorizontalAlignment="Left"
                     TextChanged="ValidateInputs"/>
            <TextBlock x:Name="txtSteamIdError" Text="{helpers:Localization Step1_SteamAppId_Error}"
                       FontSize="10" Foreground="#E07070" Margin="0,4,0,0"
                       Visibility="Collapsed"/>

            <!-- NexusMods Slug -->
            <TextBlock Text="{helpers:Localization Step1_NexusSlug_Label}" Style="{StaticResource FieldLabel}"
                       Margin="0,20,0,4"/>
            <TextBlock Text="{helpers:Localization Step1_NexusSlug_Hint}" Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="txtNexusSlug" Style="{StaticResource FieldBox}"
                     Margin="0,0,0,0" Width="260" HorizontalAlignment="Left"/>

            <!-- Overlay / companion metadata -->
            <Expander Header="Advanced layout metadata"
                      Margin="0,20,0,0" Foreground="{DynamicResource TextBrush}"
                      FontSize="12">
                <StackPanel Margin="0,12,0,0">
                    <TextBlock Text="Overlay folders"
                               Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="Comma-separated top-level folders that should preserve their relative path."
                               Style="{StaticResource FieldHint}"/>
                    <TextBox x:Name="txtOverlayFolders" Style="{StaticResource FieldBox}"
                             AcceptsReturn="False" Margin="0,0,0,14"/>

                    <TextBlock Text="Companion sibling folders"
                               Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="One mapping per line: folder = sibling1, sibling2"
                               Style="{StaticResource FieldHint}"/>
                    <TextBox x:Name="txtCompanionSiblings" Style="{StaticResource FieldBox}"
                             AcceptsReturn="True" Height="88" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Margin="0,0,0,14"/>

                    <TextBlock Text="Search hints (auto-detect locations)"
                               Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="One install path per line, relative to a drive root (e.g. Steam/steamapps/common/My Game). Lets a shared profile auto-locate the game on another PC during Quick Scan."
                               Style="{StaticResource FieldHint}"/>
                    <TextBox x:Name="txtSearchHints" Style="{StaticResource FieldBox}"
                             AcceptsReturn="True" Height="72" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </Expander>

            <!-- Integrity Verification (optional, advanced) -->
            <Expander Header="{helpers:Localization Step1_Integrity_Header}"
                      Margin="0,24,0,0" Foreground="{DynamicResource TextBrush}"
                      FontSize="12">
                <StackPanel Margin="0,12,0,0">
                    <TextBlock Text="{helpers:Localization Step1_Integrity_Intro}"
                               Style="{StaticResource FieldHint}" Margin="0,0,0,12"/>

                    <!-- Auto-detect button -->
                    <Button x:Name="btnAutoDetect" Content="{helpers:Localization Step1_Integrity_AutoDetect}"
                            Click="BtnAutoDetect_Click" Style="{StaticResource BrowseBtn}"
                            HorizontalAlignment="Left" Margin="0,0,0,16"/>

                    <!-- Expected size -->
                    <TextBlock Text="{helpers:Localization Step1_Integrity_SizeLabel}"
                               Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{helpers:Localization Step1_Integrity_SizeHint}"
                               Style="{StaticResource FieldHint}"/>
                    <TextBox x:Name="txtExpectedBytes" Style="{StaticResource FieldBox}"
                             Margin="0,0,0,16" Width="200" HorizontalAlignment="Left"/>

                    <!-- Accepted MD5 hashes -->
                    <TextBlock Text="{helpers:Localization Step1_Integrity_HashesLabel}"
                               Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{helpers:Localization Step1_Integrity_HashesHint}"
                               Style="{StaticResource FieldHint}"/>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtNewMd5" Style="{StaticResource FieldBox}"
                                 KeyDown="TxtNewMd5_KeyDown"/>
                        <Button Grid.Column="2" Content="{helpers:Localization Step2_Extension_Add}"
                                Click="BtnAddMd5_Click" Style="{StaticResource BrowseBtn}"/>
                    </Grid>

                    <!-- Hash chip list -->
                    <ItemsControl x:Name="icMd5List" Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlBgBrush}"
                                        CornerRadius="4" Padding="8,4" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas"
                                                   FontSize="11" Foreground="{DynamicResource TextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="✕" Tag="{Binding}"
                                                Click="BtnRemoveMd5_Click"
                                                Width="20" Height="20" Padding="0"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SubTextBrush}"
                                                FontSize="10" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>
