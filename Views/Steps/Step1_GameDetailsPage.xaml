<UserControl x:Class="TMM.Step1_GameDetailsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             Background="{DynamicResource BgBrush}">

    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Opacity"    Value="0.55"/>
            <Setter Property="Margin"     Value="0,-2,0,6"/>
            <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BrowseBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24" MaxWidth="620">

            <TextBlock Text="Let's start with the basics." FontSize="13"
                       Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,24"/>

            <!-- Game Name -->
            <TextBlock Text="Game Name *" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="txtGameName" Style="{StaticResource FieldBox}"
                     Margin="0,0,0,16"

                     TextChanged="ValidateInputs"/>

            <!-- Install Directory -->
            <TextBlock Text="Install Directory *" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="The folder where the game is installed (contains the game executable)."
                       Style="{StaticResource FieldHint}"/>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtInstallDir" Style="{StaticResource FieldBox}"
                         Margin="0"

                         TextChanged="ValidateInputs"/>
                <Button Grid.Column="2" Content="Browse…" Style="{StaticResource BrowseBtn}"
                        Click="BtnBrowseDir_Click"/>
            </Grid>

            <!-- Path status -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock x:Name="txtDirStatus" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Executable Path -->
            <TextBlock Text="Executable Path" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="Optional. Used for the launch button. Can be relative to the install directory."
                       Style="{StaticResource FieldHint}"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtExePath" Style="{StaticResource FieldBox}"
                         Margin="0"
/>
                <Button Grid.Column="2" Content="Browse…" Style="{StaticResource BrowseBtn}"
                        Click="BtnBrowseExe_Click"/>
            </Grid>

            <!-- Steam App ID -->
            <TextBlock Text="Steam App ID" Style="{StaticResource FieldLabel}"/>
            <TextBlock Text="Optional. Enables Steam launch integration. Find it in the store URL."
                       Style="{StaticResource FieldHint}"/>
            <TextBox x:Name="txtSteamAppId" Style="{StaticResource FieldBox}"
                     Margin="0,0,0,0" Width="160" HorizontalAlignment="Left"

                     TextChanged="ValidateInputs"/>
            <TextBlock x:Name="txtSteamIdError" Text="Must be a positive number."
                       FontSize="10" Foreground="#E07070" Margin="0,4,0,0"
                       Visibility="Collapsed"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
