<UserControl x:Class="TMM.Step2_ModTypesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TMM"
             Background="{DynamicResource BgBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisConverter x:Key="InvBoolToVis"/>
        <Style x:Key="ModTypeCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource PanelBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Margin"          Value="0,0,0,6"/>
            <Setter Property="Padding"         Value="12,10"/>
        </Style>
        <Style x:Key="ChipBtn" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
        <Style x:Key="ExtTag" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="3"/>
            <Setter Property="Padding"         Value="5,2"/>
            <Setter Property="Margin"          Value="0,0,4,4"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="20,14,20,10"
                BorderBrush="{DynamicResource ControlBgBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Define what mod types this game supports."
                               FontSize="12" Foreground="{DynamicResource SubTextBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Presets:" FontSize="10"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="ASI Plugin" Style="{StaticResource ChipBtn}"
                                Tag="asi" Click="BtnAddPreset_Click"/>
                        <Button Content="CLEO Script" Style="{StaticResource ChipBtn}"
                                Tag="cleo" Click="BtnAddPreset_Click"/>
                        <Button Content="DLL Plugin" Style="{StaticResource ChipBtn}"
                                Tag="dll" Click="BtnAddPreset_Click"/>
                        <Button Content="Texture Pack" Style="{StaticResource ChipBtn}"
                                Tag="texture" Click="BtnAddPreset_Click"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Content="+ New Mod Type"
                        Click="BtnAddModType_Click"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentTextBrush}"
                        BorderThickness="0" Padding="12,6"
                        FontWeight="SemiBold" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Mod type list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12">
            <StackPanel>

                <!-- Empty state -->
                <Border x:Name="pnlEmpty" Padding="0,24"
                        Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No mod types yet."
                                   Foreground="{DynamicResource SubTextBrush}"
                                   FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="Add mod types above or use a preset to get started."
                                   Foreground="{DynamicResource SubTextBrush}"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Opacity="0.6" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="icModTypes">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Collapsed card -->
                            <Border Style="{StaticResource ModTypeCard}">
                                <StackPanel>
                                    <!-- Header row (always visible) -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <WrapPanel Margin="0,4,0,0"
                                                       Visibility="{Binding IsExpanded, Converter={StaticResource InvBoolToVis}}">
                                                <ItemsControl ItemsSource="{Binding FileExtensions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource ExtTag}">
                                                                <TextBlock Text="{Binding}"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource AccentBrush}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="(no extensions)"
                                                           FontSize="10" Opacity="0.5"
                                                           Foreground="{DynamicResource SubTextBrush}"
                                                           Visibility="{Binding HasNoExtensions, Converter={StaticResource BoolToVis}}"/>
                                            </WrapPanel>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="{Binding EditButtonLabel}"
                                                Tag="{Binding}"
                                                Click="BtnToggleExpand_Click"
                                                Background="Transparent"
                                                Foreground="{DynamicResource AccentBrush}"
                                                BorderThickness="0" Padding="4" Cursor="Hand"
                                                FontSize="11"/>
                                        <Button Grid.Column="3" Content="Delete"
                                                Tag="{Binding}"
                                                Click="BtnDeleteModType_Click"
                                                Background="Transparent"
                                                Foreground="#E07070"
                                                BorderThickness="0" Padding="4" Cursor="Hand"
                                                FontSize="11"/>
                                    </Grid>

                                    <!-- Inline editor (expanded) -->
                                    <Border Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                                            Margin="0,10,0,0" Padding="0,10,0,0"
                                            BorderBrush="{DynamicResource ControlBgBrush}"
                                            BorderThickness="0,1,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Name" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SubTextBrush}"
                                                       Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource ControlBgBrush}"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     BorderBrush="{DynamicResource SubTextBrush}"
                                                     BorderThickness="1" Padding="6,4" FontSize="12"
                                                     Margin="0,0,0,10"/>

                                            <TextBlock Text="File Extensions" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SubTextBrush}"
                                                       Margin="0,0,0,4"/>
                                            <WrapPanel Margin="0,0,0,8">
                                                <ItemsControl ItemsSource="{Binding FileExtensions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource ExtTag}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding}"
                                                                               FontSize="10"
                                                                               Foreground="{DynamicResource AccentBrush}"
                                                                               VerticalAlignment="Center"/>
                                                                    <Button Content="×"
                                                                            Tag="{Binding}"
                                                                            Click="BtnRemoveExtension_Click"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            Foreground="{DynamicResource SubTextBrush}"
                                                                            Padding="2,0,0,0"
                                                                            FontSize="11" Cursor="Hand"
                                                                            Margin="4,0,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </WrapPanel>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txtNewExtension"
                                                         Background="{DynamicResource ControlBgBrush}"
                                                         Foreground="{DynamicResource TextBrush}"
                                                         BorderBrush="{DynamicResource SubTextBrush}"
                                                         BorderThickness="1" Padding="6,4" FontSize="11"

                                                         Tag="{Binding}"
                                                         KeyDown="TxtNewExtension_KeyDown"/>
                                                <Button Grid.Column="2" Content="+ Add"
                                                        Tag="{Binding}"
                                                        Click="BtnAddExtension_Click"
                                                        Background="{DynamicResource HeaderBrush}"
                                                        Foreground="{DynamicResource TextBrush}"
                                                        BorderThickness="0" Padding="8,4"
                                                        FontSize="11" Cursor="Hand"/>
                                            </Grid>

                                            <Button Content="Done"
                                                    Tag="{Binding}"
                                                    Click="BtnToggleExpand_Click"
                                                    HorizontalAlignment="Left"
                                                    Background="{DynamicResource AccentBrush}"
                                                    Foreground="{DynamicResource AccentTextBrush}"
                                                    BorderThickness="0" Padding="12,5"
                                                    FontSize="11" Cursor="Hand"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="0,12,0,0" FontSize="11" Opacity="0.6"
                           Foreground="{DynamicResource SubTextBrush}"
                           TextWrapping="Wrap"
                           Text="Tip: Mod types without routing rules will fall back to game-wide rules. You can assign routing rules in Step 3."/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
