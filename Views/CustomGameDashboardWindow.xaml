<Window x:Class="TMM.CustomGameDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        Title="TMM &#x2014; Custom Game"
        Height="620" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Loaded="Window_Loaded"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <ControlTemplate x:Key="ModListTemplate" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock x:Name="WatermarkText" Text="Drop Mods Here"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bottom overrides Top  (0 loads first)" Foreground="{DynamicResource TextBrush}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>

        <Style x:Key="ModListStyle" TargetType="ListView">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="AllowDrop"     Value="True"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="Template"      Value="{StaticResource ModListTemplate}"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListViewItem">
                        <Setter Property="ContextMenu" Value="{StaticResource ModContextMenu}"/>
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="{DynamicResource CheckeredRowBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3D3D3D"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <ContextMenu x:Key="ModContextMenu">
            <MenuItem Header="Rename (F2)"          Click="MenuRename_Click"/>
            <MenuItem Header="Set Load Order..."    Click="MenuSetLoadOrder_Click" FontWeight="Bold"/>
            <MenuItem Header="Toggle Disable (Space)" Click="MenuToggle_Click"/>
            <Separator/>
            <MenuItem Header="Open Mod Folder"      Click="MenuOpenFolder_Click"/>
            <MenuItem Header="Open Game Folder"     Click="MenuOpenGameFolder_Click"/>
            <Separator/>
            <MenuItem Header="Move Up (Ctrl+Up)"    Click="MenuMoveUp_Click"/>
            <MenuItem Header="Move Down (Ctrl+Down)" Click="MenuMoveDown_Click"/>
            <Separator/>
            <MenuItem Header="Properties..."        Click="MenuProperties_Click" Foreground="{DynamicResource AccentBrush}"/>
            <MenuItem Header="Delete Mod(s) (Del)"  Click="MenuDelete_Click" Foreground="#FF5555"/>
        </ContextMenu>

        <ContextMenu x:Key="EmptyListContextMenu">
            <MenuItem Header="+ Install Mod(s) Here..." Click="BtnInstallMod_Click"/>
            <MenuItem Header="Refresh List"             Click="BtnRefresh_Click"/>
            <Separator/>
            <MenuItem Header="Open Game Folder"     Click="MenuOpenGameFolder_Click"/>
            <MenuItem Header="Open Mods Folder"     Click="MenuOpenModsFolder_Click"/>
        </ContextMenu>

        <Style TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Background"   Value="{DynamicResource HeaderBrush}"/>
            <Setter Property="Foreground"   Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Padding"      Value="10,5"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush"  Value="#22FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer border -->
    <Border x:Name="OuterBorder" CornerRadius="10" BorderThickness="1"
            BorderBrush="{DynamicResource WindowBorderBrush}">
        <Border.Background>
            <SolidColorBrush x:Name="WindowBg" Color="#1C1C1E"/>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TitleBarRow" Height="36"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Border x:Name="TitleBarBorder" Grid.Row="0" Background="{DynamicResource HeaderBrush}"
                    CornerRadius="9,9,0,0" MouseDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <TextBlock Text="TMM" Foreground="{DynamicResource AccentBrush}"
                                   FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtGameTitle" Text=" &#x2014; Custom Game"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="btnMinimize" Content="&#xE921;"
                                Width="40" Height="36" BorderThickness="0" Background="Transparent"
                                Foreground="{DynamicResource SubTextBrush}"
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                Click="BtnMinimize_Click"/>
                        <Button x:Name="btnClose" Content="&#xE8BB;"
                                Width="40" Height="36" BorderThickness="0" Background="Transparent"
                                Foreground="{DynamicResource SubTextBrush}"
                                FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toolbar -->
            <Border Grid.Row="1" Background="{DynamicResource HeaderBrush}" Padding="8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <Button x:Name="btnBack" ToolTip="Back to Game Launcher"
                            Background="Transparent" BorderThickness="0"
                            Padding="8,4" Cursor="Hand" Click="BtnBack_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="12" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SubTextBrush}"/>
                            <TextBlock Text=" Back" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SubTextBrush}" Margin="2,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Height="20" Background="#33FFFFFF" Margin="4,0"/>

                    <!-- Edit game config -->
                    <Button Content="&#xE70F;" ToolTip="Edit game configuration"
                            Style="{DynamicResource IconButtonStyle}" Padding="7,4" Margin="2,0"
                            Click="BtnEditConfig_Click"/>

                    <Separator Width="1" Height="20" Background="#33FFFFFF" Margin="4,0"/>

                    <Button x:Name="btnInstallMod" Content="&#xE8F4;" ToolTip="Install Mod (Ctrl+O)"
                            Style="{DynamicResource IconButtonStyle}" Padding="7,4" Margin="2,0"
                            Click="BtnInstallMod_Click"/>

                    <Button x:Name="btnRefresh" Content="&#xE72C;" ToolTip="Rebuild mod list from folders"
                            Style="{DynamicResource IconButtonStyle}" Padding="7,4" Margin="2,0"
                            Click="BtnRefresh_Click"/>

                    <Separator Width="1" Height="20" Background="#33FFFFFF" Margin="4,0"/>

                    <Button x:Name="btnDeploy" Content="&#xE896;" ToolTip="Deploy Mods to Game Directory (F5)"
                            Style="{DynamicResource IconButtonStyle}" Padding="7,4" Margin="2,0"
                            Click="BtnDeploy_Click"/>

                    <Button x:Name="btnRollback" Content="&#xE777;" ToolTip="Rollback Last Deploy"
                            Style="{DynamicResource IconButtonStyle}" Padding="7,4" Margin="2,0"
                            Click="BtnRollback_Click"/>

                    <Button x:Name="btnLaunch" Content="&#xE7B5;" ToolTip="Launch Game"
                            Style="{DynamicResource IconButtonStyle}" Padding="7,4" Margin="2,0"
                            Click="BtnLaunch_Click" Visibility="Collapsed"/>

                    <Separator Width="1" Height="20" Background="#33FFFFFF" Margin="4,0"/>

                    <Button x:Name="btnSettings" Content="&#xE713;" ToolTip="Settings"
                            Style="{DynamicResource IconButtonStyle}" Padding="7,4" Margin="2,0"
                            Click="BtnSettings_Click"/>

                    <!-- Theme Manager -->
                    <Button Content="&#xE790;" ToolTip="Themes"
                            Style="{DynamicResource IconButtonStyle}" Padding="7,4" Margin="2,0"
                            Click="BtnTheme_Click"/>

                    <!-- Random Theme (dice) -->
                    <Button Content="&#xE89A;" ToolTip="Random theme"
                            Style="{DynamicResource IconButtonStyle}" Padding="7,4" Margin="2,0"
                            Click="BtnRollTheme_Click"/>

                    <!-- Right-side info -->
                    <TextBlock x:Name="txtDiskSpace" HorizontalAlignment="Right"
                               Foreground="{DynamicResource SubTextBrush}" FontSize="10"
                               VerticalAlignment="Center" Margin="8,0,4,0"
                               TextAlignment="Right"/>
                </StackPanel>
            </Border>

            <!-- Mod list -->
            <Grid Grid.Row="2" Margin="8,8,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSearch" Grid.Column="0"
                             Background="{DynamicResource ControlBgBrush}"
                             Foreground="{DynamicResource TextBrush}"
                             BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1"
                             Padding="8,4" FontSize="12"
                             TextChanged="TxtSearch_TextChanged"/>
                    <Button Grid.Column="1" Content="&#x2715;" Margin="4,0,0,0"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource SubTextBrush}"
                            Cursor="Hand" Padding="6,4"
                            Click="BtnClearSearch_Click"/>
                </Grid>

                <!-- Mod ListView -->
                <ListView x:Name="ModList" Grid.Row="1"
                          Style="{StaticResource ModListStyle}"
                          ContextMenu="{StaticResource EmptyListContextMenu}"
                          Drop="List_Drop" DragOver="List_DragOver" DragLeave="List_DragLeave"
                          PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                          MouseMove="List_MouseMove"
                          KeyDown="List_KeyDown"
                          SelectionChanged="ModList_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Order" Width="50"
                                            DisplayMemberBinding="{Binding LoadOrder}"/>
                            <GridViewColumn Header="" Width="28">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                  Click="ModCheckBox_Click"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Mod Name" Width="340"
                                            DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Size" Width="80"
                                            DisplayMemberBinding="{Binding SizeDisplay}"/>
                            <GridViewColumn Header="Status" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{Binding StatusColor}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Drop indicator line -->
                <Canvas Grid.Row="1" IsHitTestVisible="False">
                    <Rectangle x:Name="DropLine" Height="2" Fill="{DynamicResource AccentBrush}"
                                Visibility="Collapsed" Width="400"/>
                </Canvas>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="3" Background="{DynamicResource HeaderBrush}" Padding="10,5" Margin="8,6,8,8">
                <Grid>
                    <TextBlock x:Name="txtStatus" Foreground="{DynamicResource SubTextBrush}"
                               FontSize="11" Text="Ready"/>
                    <TextBlock x:Name="txtModCount" HorizontalAlignment="Right"
                               Foreground="{DynamicResource SubTextBrush}" FontSize="11"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
