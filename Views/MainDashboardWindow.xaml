<local:DashboardWindowBase x:Class="TMM.MainDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        Title="TMM — GTA III Series"
        MinHeight="700" MinWidth="1050" Height="672" Width="1280"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Loaded="Window_Loaded"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <!-- Force native scrollbars to use dark colors. -->
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#2D2D30"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#3E3E42"/>

        <!-- ========================================================== -->
        <!-- General styles & templates                                 -->
        <!-- ========================================================== -->
        <Style x:Key="OverlayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#CC1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E62A2A2A"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================================================== -->
        <!-- Context menus                                              -->
        <!-- ========================================================== -->
        <ContextMenu x:Key="ModContextMenu">
            <MenuItem Header="Rename (F2)" Click="MenuRename_Click"/>
            <MenuItem Header="Set Load Order..." Click="MenuSetLoadOrder_Click" FontWeight="Bold"/>
            <MenuItem Header="Toggle Disable (Space)" Click="MenuToggle_Click"/>
            <Separator/>
            <MenuItem Header="Install Mod to All Games" Click="MenuInstallToAll_Click"/>
            <MenuItem Header="Open Mod Folder" Click="MenuOpenFolder_Click"/>
            <MenuItem Header="Open Game Folder" Click="MenuOpenBaseFolder_Click"/>
            <MenuItem Header="Open Backup Folder" Click="MenuOpenVirtualFolder_Click"/>
            <Separator/>
            <MenuItem Header="Move Up (Ctrl+Up)" Click="MenuMoveUp_Click"/>
            <MenuItem Header="Move Down (Ctrl+Down)" Click="MenuMoveDown_Click"/>
            <Separator/>
            <MenuItem Header="Toggle Force Deploy Override" Click="MenuToggleOverrideList_Click"/>
            <Separator/>
            <MenuItem Header="Properties..." Click="MenuProperties_Click" Foreground="{DynamicResource AccentBrush}"/>
            <MenuItem Header="Delete Mod(s) (Del)" Click="MenuDelete_Click" Foreground="#FF5555"/>
        </ContextMenu>

        <ContextMenu x:Key="EmptyListContextMenu">
            <MenuItem Header="Install Mod(s) Here..." Click="BtnInstallMod_Click"/>
            <MenuItem Header="Refresh List" Click="BtnRefresh_Click"/>
            <Separator/>
            <MenuItem Header="Open Game Folder"      Click="MenuOpenBaseFolder_Click"/>
            <MenuItem Header="Open Backup Folder"   Click="MenuOpenVirtualFolder_Click"/>
            <MenuItem Header="Open Mods Folder"      Click="MenuOpenModsFolder_Click"/>
            <Separator/>
            <MenuItem Header="Toggle Force Deploy Override" Click="MenuToggleOverrideList_Click"/>
        </ContextMenu>

        <!-- ========================================================== -->
        <!-- ListView templates & styles                                -->
        <!-- ========================================================== -->
        <!-- Per-game watermark templates -->
        <ControlTemplate x:Key="WatermarkIII" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="Drop III Mods Here" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bottom overrides Top  (0 loads first)" Foreground="{DynamicResource TextBrush}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>
        <ControlTemplate x:Key="WatermarkVC" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="Drop VC Mods Here" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bottom overrides Top  (0 loads first)" Foreground="{DynamicResource TextBrush}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>
        <ControlTemplate x:Key="WatermarkSA" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.18">
                        <TextBlock Text="Drop SA Mods Here" Foreground="{DynamicResource TextBrush}"
                                   FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Bottom overrides Top  (0 loads first)" Foreground="{DynamicResource TextBrush}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                        <ItemsPresenter/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </ControlTemplate>
        <!-- Fallback (unused but satisfies any old StaticResource ref) -->
        <ControlTemplate x:Key="WatermarkTemplate" TargetType="ListView">
            <Border Background="{DynamicResource PanelBrush}" BorderThickness="0" CornerRadius="5" Opacity="0.95">
                <ScrollViewer Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                    <ItemsPresenter/>
                </ScrollViewer>
            </Border>
        </ControlTemplate>

        <Style x:Key="ModListStyle" TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="Template" Value="{StaticResource WatermarkTemplate}"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DashboardListItemStyle}">
                        <Setter Property="ContextMenu" Value="{StaticResource ModContextMenu}"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========================================================== -->
        <!-- Window-control button styles                               -->
        <!-- ========================================================== -->
        <Style x:Key="MacButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="Black" FontSize="9"
                                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0" x:Name="txt"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinCloseButtonStyle" BasedOn="{StaticResource WinButtonStyle}" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="vanillaCloseBorder" Background="{TemplateBinding Background}"
                                CornerRadius="0,12,0,0">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Win7ButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="#30FFFFFF" BorderThickness="1,0,1,1" CornerRadius="2">
                            <TextBlock Text="{TemplateBinding Content}" FontFamily="Marlett" FontSize="12"
                                       Foreground="{DynamicResource TextBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#25FFFFFF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#55FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Win 9x classic beveled button -->
        <Style x:Key="Win9xButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="outer" Background="#C0C0C0" BorderThickness="1" BorderBrush="#808080">
                            <Border BorderBrush="White" BorderThickness="1,1,0,0">
                                <Border x:Name="inner" BorderBrush="#808080" BorderThickness="0,0,1,1">
                                    <TextBlock Text="{TemplateBinding Content}" FontFamily="Marlett" FontSize="9"
                                               Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="outer" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="inner" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="outer" Property="Background" Value="#A8A8A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Windows XP Luna button style -->
        <Style x:Key="WinXPButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="#ECE9D8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="outerXP" Background="#ECE9D8" BorderThickness="1" BorderBrush="#ACA899">
                            <Border BorderBrush="#FFFFFF" BorderThickness="1,1,0,0">
                                <Border x:Name="innerXP" BorderBrush="#ACA899" BorderThickness="0,0,1,1">
                                    <TextBlock Text="{TemplateBinding Content}" FontFamily="Tahoma" FontSize="11"
                                               Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outerXP" Property="Background" Value="#F5F5EE"/>
                                <Setter TargetName="outerXP" Property="BorderBrush" Value="#0A246A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="outerXP" Property="Background" Value="#D4C4AC"/>
                                <Setter TargetName="innerXP" Property="BorderBrush" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Windows 3.1 classic button style -->
        <Style x:Key="Win31ButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="#C0C0C0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="outer31" Background="#C0C0C0" BorderThickness="2">
                            <Border x:Name="top31" BorderBrush="White" BorderThickness="1,1,0,0">
                                <Border x:Name="bottom31" BorderBrush="#808080" BorderThickness="0,0,1,1">
                                    <TextBlock Text="{TemplateBinding Content}" FontFamily="MS Sans Serif" FontSize="11"
                                               Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="outer31" Property="Background" Value="#DFDFDF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="top31" Property="BorderBrush" Value="#808080"/>
                                <Setter TargetName="bottom31" Property="BorderBrush" Value="White"/>
                                <Setter TargetName="outer31" Property="Background" Value="#A8A8A8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Master border with gradient accent - updated by ThemeEngine -->
    <Border x:Name="MainWindowBorder" Background="{DynamicResource BgBrush}" CornerRadius="10"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="1"
            MouseLeftButtonDown="TitleBar_MouseDown">

        <!-- Opacity-mask trick to clip children to the rounded corners -->
        <Border>
            <Border.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Border Background="White" CornerRadius="6"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.OpacityMask>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ====================================================== -->
                <!-- Custom modular title bar                               -->
                <!-- ====================================================== -->
                <Border x:Name="TitleBarBorder" Grid.Row="0" Height="30" CornerRadius="10,10,0,0" ClipToBounds="True">
                    <Grid x:Name="TitleBarGrid">
                        <TextBlock Text="TMM - GTA III Series"
                                   Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.25" Color="Black"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- macOS controls -->
                        <StackPanel x:Name="MacControls" Orientation="Horizontal" VerticalAlignment="Center"
                                    HorizontalAlignment="Left" Margin="20,0,0,0" Visibility="Collapsed">
                            <Button Content="x" Width="12" Height="12" Margin="0,0,8,0"
                                    Style="{StaticResource MacButtonStyle}" Background="#ED6158"
                                    Click="BtnCloseApp_Click" Tag="Close"/>
                            <Button Content="âˆ’" Width="12" Height="12" Margin="0,0,8,0"
                                    Style="{StaticResource MacButtonStyle}" Background="#FCC42D"
                                    Click="BtnMinimize_Click"/>
                            <Button Content="â¤¢" Width="12" Height="12" Margin="0"
                                    Style="{StaticResource MacButtonStyle}" Background="#5FC038"
                                    Click="BtnMaximize_Click"/>
                        </StackPanel>

                        <!-- Vanilla controls -->
                        <StackPanel x:Name="VanillaControls" Orientation="Horizontal" Visibility="Visible">
                            <Button Content="&#xE921;" Width="45" Height="30"
                                    Style="{StaticResource WinButtonStyle}" Click="BtnMinimize_Click"/>
                            <Button Content="&#xE922;" Width="45" Height="30"
                                    Style="{StaticResource WinButtonStyle}" Click="BtnMaximize_Click"/>
                            <Button Content="&#xE8BB;" Width="45" Height="30"
                                    Style="{StaticResource WinCloseButtonStyle}"
                                    Click="BtnCloseApp_Click" Tag="Close"/>
                        </StackPanel>

                        <!-- Windows 8/10 inspired -->
                        <StackPanel x:Name="Win8Controls" Orientation="Horizontal" Visibility="Collapsed" Margin="0,4,8,0">
                            <Button Content="0" Style="{StaticResource Win7ButtonStyle}" Click="BtnMinimize_Click"/>
                            <Button Content="1" Style="{StaticResource Win7ButtonStyle}" Click="BtnMaximize_Click"/>
                            <Button x:Name="btnWin8Close" Click="BtnCloseApp_Click" Width="46" Height="22"
                                    Tag="Close" Margin="3,0,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" CornerRadius="3" Background="Transparent">
                                            <TextBlock Text="&#xE8BB;"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="9" Foreground="#CCFFFFFF"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#C0121212"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Windows 7 Aero inspired -->
                        <StackPanel x:Name="Win7Controls" Orientation="Horizontal" Visibility="Collapsed" Margin="0,4,8,0">
                            <Button Content="0" Style="{StaticResource Win7ButtonStyle}" Click="BtnMinimize_Click"/>
                            <Button Content="1" Style="{StaticResource Win7ButtonStyle}" Click="BtnMaximize_Click"/>
                            <Button x:Name="btnWin7Close" Click="BtnCloseApp_Click" Width="50" Height="22"
                                    Tag="Close" Margin="4,0,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" CornerRadius="3" Background="Transparent">
                                            <TextBlock x:Name="closeGlyph"
                                                       Text="&#xE8BB;"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="8" Foreground="#E8FFFFFF"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#C0121212"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- Win 9x / Classic controls -->
                        <StackPanel x:Name="Win9xControls" Orientation="Horizontal" Visibility="Collapsed" Margin="0,4,8,0">
                            <Button Content="0" Style="{StaticResource Win9xButtonStyle}" Click="BtnMinimize_Click"/>
                            <Button Content="1" Style="{StaticResource Win9xButtonStyle}" Click="BtnMaximize_Click"/>
                            <Button x:Name="btnWin9xClose" Click="BtnCloseApp_Click" Tag="Close"
                                    Width="18" Height="16" Margin="2,0,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="outer9x" Background="#C0C0C0" BorderThickness="1" BorderBrush="#808080">
                                            <Border BorderBrush="White" BorderThickness="1,1,0,0">
                                                <Border x:Name="inner9x" BorderBrush="#808080" BorderThickness="0,0,1,1">
                                                    <TextBlock Text="r" FontFamily="Marlett" FontSize="9"
                                                               Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Border>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="outer9x" Property="BorderBrush" Value="White"/>
                                                <Setter TargetName="inner9x" Property="BorderBrush" Value="White"/>
                                                <Setter TargetName="outer9x" Property="Background" Value="#A8A8A8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>

                        <!-- macOS Light controls -->
                        <StackPanel x:Name="MacLightControls" Orientation="Horizontal" VerticalAlignment="Center"
                                    HorizontalAlignment="Left" Margin="20,0,0,0" Visibility="Collapsed">
                            <Button Content="x" Width="12" Height="12" Margin="0,0,8,0"
                                    Style="{StaticResource MacButtonStyle}" Background="#EE5A52"
                                    Click="BtnCloseApp_Click" Tag="Close"/>
                            <Button Content="âˆ’" Width="12" Height="12" Margin="0,0,8,0"
                                    Style="{StaticResource MacButtonStyle}" Background="#FDC82F"
                                    Click="BtnMinimize_Click"/>
                            <Button Content="â¤¢" Width="12" Height="12" Margin="0"
                                    Style="{StaticResource MacButtonStyle}" Background="#62C554"
                                    Click="BtnMaximize_Click"/>
                        </StackPanel>

                    </Grid>
                </Border>

                <!-- ====================================================== -->
                <!-- Main content area                                      -->
                <!-- ====================================================== -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ====================================================== -->
                    <!-- Toolbar - full window width, always on top             -->
                    <!-- ====================================================== -->
                    <Border x:Name="ToolbarBorder" Grid.Row="0"
                            Background="{DynamicResource HeaderBrush}" Opacity="0.98" Padding="8,6">
                        <DockPanel LastChildFill="True">

                            <!-- Compact window controls - right-docked, hidden unless Compact mode -->
                            <StackPanel x:Name="CompactControls" Orientation="Horizontal"
                                        VerticalAlignment="Center" Visibility="Collapsed"
                                        DockPanel.Dock="Right" Margin="0,0,8,0">
                                <Button Content="âˆ’" Width="12" Height="12" Margin="0,0,8,0"
                                        Style="{StaticResource MacButtonStyle}" Background="#FCC42D"
                                        Click="BtnMinimize_Click"/>
                                <Button Content="â¤¢" Width="12" Height="12" Margin="0,0,8,0"
                                        Style="{StaticResource MacButtonStyle}" Background="#5FC038"
                                        Click="BtnMaximize_Click"/>
                                <Button Content="x" Width="12" Height="12" Margin="0"
                                        Style="{StaticResource MacButtonStyle}" Background="#ED6158"
                                        Click="BtnCloseApp_Click" Tag="Close"/>
                            </StackPanel>

                            <!-- Right-pinned group: Deploy . | . III . VC . SA . | . Help . About -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

                                <!-- Deploy -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button x:Name="btnDeploy" Click="BtnDeploy_Click"
                                            ToolTip="Deploy Mods (F5)" ToolTipService.ShowOnDisabled="True"
                                            Width="42" Height="42" Background="{DynamicResource AccentBrush}"
                                            BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="&#xE74B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="20" Foreground="{DynamicResource AccentTextBrush}"/>
                                    </Button>
                                    <TextBlock x:Name="lblDeploy" Text="Deploy" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>

                                <!-- Rollback -->
                                <StackPanel Margin="4,0,0,0" VerticalAlignment="Center">
                                    <Button x:Name="btnRollback" Click="BtnRollback_Click"
                                            ToolTip="Rollback Last Deploy" Width="38" Height="38"
                                            Style="{StaticResource IconButtonStyle}" FontSize="16"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                            Content="&#xE777;"/>
                                    <TextBlock x:Name="lblRollback" Text="Rollback" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>

                                <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="6,6,6,6" Opacity="0.3"/>

                                <!-- Play III -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button x:Name="btnPlayIII" Click="BtnLaunchModded_Click" Tag="III"
                                            Width="42" Height="42" Cursor="Hand" BorderThickness="0"
                                            ToolTip="Play GTA III (right-click for override options)"
                                            Background="{DynamicResource AccentBrush}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem x:Name="menuOverrideIII" Header="Force Deploy Override (Ignore Vanilla EXE)"
                                                          Click="MenuToggleOverride_Click" Tag="III"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="III" Foreground="{DynamicResource AccentTextBrush}"
                                                   FontSize="16" FontWeight="Bold" FontFamily="Times New Roman">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Button>
                                    <TextBlock x:Name="lblPlayIII" Text="Play III" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>

                                <!-- Play VC -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button x:Name="btnPlayVC" Click="BtnLaunchModded_Click" Tag="VC"
                                            Width="42" Height="42" Cursor="Hand" BorderThickness="0"
                                            ToolTip="Play GTA Vice City (right-click for override options)"
                                            Background="{DynamicResource AccentBrush}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem x:Name="menuOverrideVC" Header="Force Deploy Override (Ignore Vanilla EXE)"
                                                          Click="MenuToggleOverride_Click" Tag="VC"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="VC" Foreground="{DynamicResource AccentTextBrush}"
                                                   FontSize="17" FontWeight="Bold" FontFamily="Arial">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Button>
                                    <TextBlock x:Name="lblPlayVC" Text="Play VC" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>

                                <!-- Play SA -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button x:Name="btnPlaySA" Click="BtnLaunchModded_Click" Tag="SA"
                                            Width="42" Height="42" Cursor="Hand" BorderThickness="0"
                                            ToolTip="Play GTA San Andreas (right-click for override options)"
                                            Background="{DynamicResource AccentBrush}">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem x:Name="menuOverrideSA" Header="Force Deploy Override (Ignore Vanilla EXE)"
                                                          Click="MenuToggleOverride_Click" Tag="SA"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock Text="SA" Foreground="{DynamicResource AccentTextBrush}"
                                                   FontSize="17" FontWeight="Bold" FontFamily="Old English Text MT, Impact">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.5" Color="Black"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </Button>
                                    <TextBlock x:Name="lblPlaySA" Text="Play SA" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>

                            </StackPanel>

                            <!-- Left-pinned: back | sidebar toggle | label toggle -->
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Back to Launcher -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button Content="&#xE72B;" Click="BtnBackToLauncher_Click" ToolTip="Back to Game Launcher"
                                            Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                            FontSize="16" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                                    <TextBlock x:Name="lblBack" Text="Back" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>
                                <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="0,6,8,6" Opacity="0.3"/>
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button Content="&#xE700;" Click="BtnToggleSidebar_Click" ToolTip="Toggle Sidebar"
                                            Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                            FontSize="20" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                                    <TextBlock x:Name="lblSidebar" Text="Sidebar" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>
                                <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="0,6,8,6" Opacity="0.3"/>
                                <!-- Italic T toggles toolbar text labels -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button x:Name="btnToggleLabels" Click="BtnToggleLabels_Click"
                                            ToolTip="Toggle Toolbar Labels" Width="38" Height="38"
                                            Style="{StaticResource IconButtonStyle}" Cursor="Hand" BorderThickness="0"
                                            FontSize="16" FontFamily="Arial" FontStyle="Italic" FontWeight="Bold">T</Button>
                                    <TextBlock x:Name="lblToggleLabels" Text="Labels" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>
                                <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="4,6,8,6" Opacity="0.3"/>

                                <!-- Help -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Grid Width="38" Height="38" ToolTip="Help &amp; Troubleshooting">
                                        <Button Click="BtnHelp_Click" Width="38" Height="38" Cursor="Hand"
                                                BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bd" Background="{DynamicResource ControlBgBrush}" CornerRadius="5">
                                                        <TextBlock x:Name="helpGlyph" Text="?" FontSize="18" FontWeight="Bold"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter TargetName="helpGlyph" Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Ellipse x:Name="HelpNotificationDot" Width="10" Height="10"
                                                 Fill="#FF5555" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                 Margin="0,3,3,0" Visibility="Collapsed" Panel.ZIndex="1">
                                            <Ellipse.Effect>
                                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#FF5555" Opacity="0.85"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </Grid>
                                    <TextBlock x:Name="lblHelp" Text="Help" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>

                                <!-- About -->
                                <StackPanel VerticalAlignment="Center" Margin="0,0,4,0">
                                    <Button Content="&#xE946;" Click="BtnAbout_Click" ToolTip="About TMM"
                                            Style="{StaticResource IconButtonStyle}" Width="38" Height="38"
                                            FontSize="18" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                                    <TextBlock x:Name="lblAbout" Text="About" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>

                            </StackPanel>

                            <!-- Centered tool group - Install . | . Settings . Themes . Refresh . Files . DXVK -->
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Install Mod -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button x:Name="btnInstallMod" Content="&#xE710;" Click="BtnInstallMod_Click"
                                            ToolTip="Install Mod" Style="{StaticResource IconButtonStyle}"
                                            Width="38" Height="38" FontSize="18"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                                    <TextBlock x:Name="lblInstallMod" Text="Install" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>
                                <Border Width="1" Background="{DynamicResource SubTextBrush}" Margin="4,6,4,6" Opacity="0.3"/>
                                <!-- Settings -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button Content="&#xE713;" Click="BtnSettings_Click"
                                            ToolTip="Settings" Style="{StaticResource IconButtonStyle}"
                                            Width="38" Height="38" FontSize="18"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                                    <TextBlock x:Name="lblSettings" Text="Settings" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>
                                <!-- Look & Feel -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button Content="&#xE790;" Click="BtnTheme_Click" ToolTip="Look &amp; Feel"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="38" Height="38" FontSize="18"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                                    <TextBlock x:Name="lblTheme" Text="Themes" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>
                                <!-- Random Theme -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button x:Name="btnRollTheme" Click="BtnRollTheme_Click" ToolTip="Random Theme"
                                            Width="38" Height="38" Cursor="Hand" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{DynamicResource ControlBgBrush}" CornerRadius="5"
                                                        Padding="6">
                                                    <TextBlock Text="&#xE89A;" FontSize="16" FontWeight="Bold"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               Foreground="{DynamicResource AccentLabelBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <TextBlock x:Name="lblRollTheme" Text="Random" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>
                                <!-- Refresh -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button Content="&#xE72C;" Click="BtnRefresh_Click" ToolTip="Refresh Mod List"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="38" Height="38" FontSize="18"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                                    <TextBlock x:Name="lblRefresh" Text="Refresh" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>
                                <!-- Files -->
                                <StackPanel Margin="0,0,4,0" VerticalAlignment="Center">
                                    <Button Content="&#xE8B7;" Click="BtnOpenAppData_Click" ToolTip="Open Mod Directory"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="38" Height="38" FontSize="18"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                                    <TextBlock x:Name="lblAppData" Text="Files" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>
                                <!-- DXVK -->
                                <StackPanel VerticalAlignment="Center">
                                    <Button Content="&#xE7AC;" Click="BtnDxvk_Click" ToolTip="DXVK Config"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="38" Height="38" FontSize="18"
                                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                                    <TextBlock x:Name="lblDxvk" Text="DXVK" FontSize="10"
                                               Foreground="{DynamicResource SubTextBrush}" HorizontalAlignment="Center"
                                               Margin="0,2,0,0" Visibility="Visible"/>
                                </StackPanel>
                            </StackPanel>

                        </DockPanel>
                    </Border>

                    <!-- Content row: sidebar + modlists -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid x:Name="DialogOverlay" Grid.ColumnSpan="2"
                          Background="Black" Opacity="0.6" Visibility="Collapsed" Panel.ZIndex="100"/>

                        <!-- Deploy progress card - shown on top of the dark overlay -->
                        <Grid x:Name="DeployProgressPanel" Grid.ColumnSpan="2"
                          Visibility="Collapsed" Panel.ZIndex="101"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Background="{DynamicResource PanelBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2"
                                Padding="36,28" MinWidth="360">
                                <StackPanel>
                                    <TextBlock Text="Deploying Mods" FontSize="17" FontWeight="Bold"
                                           Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,14"/>
                                    <TextBlock x:Name="txtDeployStage" Text="Preparing..." FontSize="13"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,10" TextWrapping="Wrap"/>
                                    <ProgressBar x:Name="pbDeploy" Height="9" Minimum="0" Maximum="100"
                                             IsIndeterminate="True" Margin="0,0,0,10"
                                             Foreground="{DynamicResource AccentBrush}" BorderThickness="0"/>
                                    <TextBlock x:Name="txtDeployCount" Text="" FontSize="11"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Notification toasts - bottom-right corner -->
                        <StackPanel Grid.ColumnSpan="2" Orientation="Vertical" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                Margin="0,0,16,16" Width="360" Panel.ZIndex="99" IsHitTestVisible="False">
                            <ItemsControl ItemsSource="{Binding Source={x:Static local:NotificationService.Queue}}"
                                      IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="6"
                                            BorderThickness="1" BorderBrush="{DynamicResource AccentBrush}"
                                            Padding="12,10" Margin="0,0,0,8" MinHeight="40"
                                            IsHitTestVisible="True" MouseLeftButtonUp="Toast_Close">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Icon -->
                                                <TextBlock Grid.Column="0"
                                                       Text="{Binding Type, Converter={StaticResource NotificationTypeIconConverter}}"
                                                       FontSize="14" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AccentLabelBrush}"/>

                                                <!-- Message -->
                                                <TextBlock Grid.Column="1" Text="{Binding Message}"
                                                       Foreground="{DynamicResource TextBrush}" FontSize="12"
                                                       TextWrapping="Wrap" VerticalAlignment="Center" Margin="10,0,0,0"/>

                                                <!-- Close Button -->
                                                <Button Grid.Column="2" Content="x" Width="20" Height="20"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{DynamicResource SubTextBrush}" FontSize="10"
                                                    Click="CloseButton_Click" Cursor="Hand"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Sidebar -->
                        <Border x:Name="SidebarBorder" Grid.Column="0"
                            Background="{DynamicResource PanelBrush}" Width="220" Visibility="Visible">
                            <DockPanel Margin="10">

                                <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center">
                                    <TextBlock Text="ESSENTIALS" Foreground="{DynamicResource AccentLabelBrush}"
                                           FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,10"/>

                                    <!-- Downgrader links -->
                                    <Button Content="III 1.0 Downgrader" Click="BtnLink_Click"
                                        Tag="https://www.moddb.com/downloads/grand-theft-auto-3-original-10-exe-for-steam"
                                        ToolTip="GTA III 1.0 Exe (ModDB)"
                                        Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                        HorizontalAlignment="Stretch" Margin="0,2"/>
                                    <Button Content="VC 1.0 Downgrader" Click="BtnLink_Click"
                                        Tag="https://www.moddb.com/downloads/grand-theft-auto-vice-city-original-10-exe"
                                        ToolTip="GTA Vice City 1.0 Exe (ModDB)"
                                        Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                        HorizontalAlignment="Stretch" Margin="0,2"/>
                                    <Button Content="SA Downgrader" Click="BtnLink_Click"
                                        Tag="https://services.rockstarnexus.com/sadowngrade/latest.exe"
                                        ToolTip="GTA San Andreas Downgrader (RockstarNexus)"
                                        Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                        HorizontalAlignment="Stretch" Margin="0,2"/>

                                    <Border Height="1" Background="{DynamicResource SubTextBrush}"
                                        Opacity="0.3" Margin="10,10"/>

                                    <!-- Auto-installers -->
                                    <Button Content="Modloader" Click="BtnInstallModloader_Click"
                                        ToolTip="Download and Install Modloader"
                                        Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                        HorizontalAlignment="Stretch" Margin="0,2"/>
                                    <Button Content="Widescreen Fix" Click="BtnWidescreenFix_Click"
                                        ToolTip="Auto-Install Widescreen Fixes Pack"
                                        Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                        HorizontalAlignment="Stretch" Margin="0,2"/>
                                    <Button Content="SilentPatch" Click="BtnSilentPatch_Click"
                                        ToolTip="Auto-Install SilentPatch"
                                        Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                        HorizontalAlignment="Stretch" Margin="0,2"/>
                                    <Button Content="DXVK" Click="BtnInstallDxvk_Click"
                                        ToolTip="Download and Install DXVK"
                                        Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                        HorizontalAlignment="Stretch" Margin="0,2"/>
                                    <Button Content="2DFX" Click="BtnProject2DFX_Click"
                                        ToolTip="Auto-Install Project2DFX"
                                        Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                        HorizontalAlignment="Stretch" Margin="0,2"/>
                                    <Button Content="ASI Loader" Click="BtnASILoader_Click"
                                        ToolTip="Auto-Install Ultimate ASI Loader"
                                        Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                        HorizontalAlignment="Stretch" Margin="0,2"/>
                                    <Button Content="CLEO" Click="BtnCleo_Click"
                                        ToolTip="Auto-Install CLEO Library (III/VC/SA)"
                                        Style="{StaticResource SidebarLinkBtnStyle}" FontSize="12"
                                        HorizontalAlignment="Stretch" Margin="0,2"/>

                                    <Border Height="1" Background="{DynamicResource SubTextBrush}"
                                        Opacity="0.3" Margin="10,15"/>
                                </StackPanel>

                                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                                    <!-- Reworded: only shown when one or more games still need a path. -->
                                    <TextBlock x:Name="txtInstallWarning"
                                           Text="One or more games are unmapped. Open Settings to locate them."
                                           Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="SemiBold"
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           Visibility="Collapsed" Margin="0,0,0,10"/>

                                    <TextBlock x:Name="txtDiskSpace" Text="Calculating space..."
                                           Foreground="{DynamicResource SubTextBrush}" FontSize="11"
                                           TextAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Workspace (modlists only) -->
                        <Grid Grid.Column="1">
                            <!-- Triple-column mod lists -->
                            <Grid Margin="10">
                                <UniformGrid x:Name="PowerViewGrid" Columns="3" Visibility="Visible" Margin="10">

                                    <Border BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="1"
                                        Margin="5" Background="{DynamicResource PanelBrush}"
                                        CornerRadius="5" Opacity="0.95">
                                        <DockPanel Margin="5">
                                            <TextBlock DockPanel.Dock="Top" Text="GTA III"
                                                   Foreground="{DynamicResource AccentLabelBrush}"
                                                   FontSize="16" FontWeight="Bold"
                                                   HorizontalAlignment="Center" Margin="0,5"/>
                                            <TextBox DockPanel.Dock="Top" x:Name="txtSearchIII"
                                                 Height="25" Margin="5,0,5,5" Padding="5,3"
                                                 Background="{DynamicResource ControlBgBrush}"
                                                 Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                                 TextChanged="TxtSearchIII_TextChanged" Opacity="0.9"/>
                                            <Grid>
                                                <ListView x:Name="PListIII"
                                                      ContextMenu="{StaticResource EmptyListContextMenu}"
                                                      Style="{StaticResource ModListStyle}"
                                                      Template="{StaticResource WatermarkIII}"
                                                      SelectionMode="Extended" Drop="List_Drop" Tag="III"
                                                      PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                                                      MouseMove="List_MouseMove"
                                                      DragOver="List_DragOver" DragLeave="List_DragLeave"
                                                      GridViewColumnHeader.Click="GridViewColumnHeaderClicked">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="#" Width="35"
                                                                        DisplayMemberBinding="{Binding LoadOrder}"/>
                                                            <GridViewColumn Header="On" Width="35">
                                                                <GridViewColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <CheckBox IsChecked="{Binding IsEnabled}"
                                                                              Checked="ModCheckBox_Changed"
                                                                              Unchecked="ModCheckBox_Changed"/>
                                                                    </DataTemplate>
                                                                </GridViewColumn.CellTemplate>
                                                            </GridViewColumn>
                                                            <GridViewColumn Header="Name" Width="180"
                                                                        DisplayMemberBinding="{Binding Name}"/>
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                                <Button x:Name="OverlayColIII" Content="Setup Required"
                                                    Click="BtnOpenWizardOverlay_Click" Tag="III"
                                                    Style="{StaticResource OverlayButtonStyle}"
                                                    Visibility="Collapsed"/>
                                                <Canvas x:Name="DropCanvasIII" IsHitTestVisible="False" Panel.ZIndex="5">
                                                    <Rectangle x:Name="DropLineIII" Height="2"
                                                           Fill="{DynamicResource AccentBrush}"
                                                           Visibility="Collapsed"/>
                                                </Canvas>
                                            </Grid>
                                        </DockPanel>
                                    </Border>

                                    <Border BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="1"
                                        Margin="5" Background="{DynamicResource PanelBrush}"
                                        CornerRadius="5" Opacity="0.95">
                                        <DockPanel Margin="5">
                                            <TextBlock DockPanel.Dock="Top" Text="GTA Vice City"
                                                   Foreground="{DynamicResource AccentLabelBrush}"
                                                   FontSize="16" FontWeight="Bold"
                                                   HorizontalAlignment="Center" Margin="0,5"/>
                                            <TextBox DockPanel.Dock="Top" x:Name="txtSearchVC"
                                                 Height="25" Margin="5,0,5,5" Padding="5,3"
                                                 Background="{DynamicResource ControlBgBrush}"
                                                 Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                                 TextChanged="TxtSearchVC_TextChanged" Opacity="0.9"/>
                                            <Grid>
                                                <ListView x:Name="PListVC"
                                                      Style="{StaticResource ModListStyle}"
                                                      Template="{StaticResource WatermarkVC}"
                                                      ContextMenu="{StaticResource EmptyListContextMenu}"
                                                      SelectionMode="Extended" Drop="List_Drop" Tag="VC"
                                                      PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                                                      MouseMove="List_MouseMove"
                                                      DragOver="List_DragOver" DragLeave="List_DragLeave"
                                                      GridViewColumnHeader.Click="GridViewColumnHeaderClicked">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="#" Width="35"
                                                                        DisplayMemberBinding="{Binding LoadOrder}"/>
                                                            <GridViewColumn Header="On" Width="35">
                                                                <GridViewColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <CheckBox IsChecked="{Binding IsEnabled}"
                                                                              Checked="ModCheckBox_Changed"
                                                                              Unchecked="ModCheckBox_Changed"/>
                                                                    </DataTemplate>
                                                                </GridViewColumn.CellTemplate>
                                                            </GridViewColumn>
                                                            <GridViewColumn Header="Name" Width="180"
                                                                        DisplayMemberBinding="{Binding Name}"/>
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                                <Button x:Name="OverlayColVC" Content="Setup Required"
                                                    Click="BtnOpenWizardOverlay_Click" Tag="VC"
                                                    Style="{StaticResource OverlayButtonStyle}"
                                                    Visibility="Collapsed"/>
                                                <Canvas x:Name="DropCanvasVC" IsHitTestVisible="False" Panel.ZIndex="5">
                                                    <Rectangle x:Name="DropLineVC" Height="2"
                                                           Fill="{DynamicResource AccentBrush}"
                                                           Visibility="Collapsed"/>
                                                </Canvas>
                                            </Grid>
                                        </DockPanel>
                                    </Border>

                                    <Border BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="1"
                                        Margin="5" Background="{DynamicResource PanelBrush}"
                                        CornerRadius="5" Opacity="0.95">
                                        <DockPanel Margin="5">
                                            <TextBlock DockPanel.Dock="Top" Text="GTA San Andreas"
                                                   Foreground="{DynamicResource AccentLabelBrush}"
                                                   FontSize="16" FontWeight="Bold"
                                                   HorizontalAlignment="Center" Margin="0,5"/>
                                            <TextBox DockPanel.Dock="Top" x:Name="txtSearchSA"
                                                 Height="25" Margin="5,0,5,5" Padding="5,3"
                                                 Background="{DynamicResource ControlBgBrush}"
                                                 Foreground="{DynamicResource TextBrush}" BorderThickness="0"
                                                 TextChanged="TxtSearchSA_TextChanged" Opacity="0.9"/>
                                            <Grid>
                                                <ListView x:Name="PListSA"
                                                      Style="{StaticResource ModListStyle}"
                                                      Template="{StaticResource WatermarkSA}"
                                                      ContextMenu="{StaticResource EmptyListContextMenu}"
                                                      SelectionMode="Extended" Drop="List_Drop" Tag="SA"
                                                      PreviewMouseLeftButtonDown="List_PreviewMouseLeftButtonDown"
                                                      MouseMove="List_MouseMove"
                                                      DragOver="List_DragOver" DragLeave="List_DragLeave"
                                                      GridViewColumnHeader.Click="GridViewColumnHeaderClicked">
                                                    <ListView.View>
                                                        <GridView>
                                                            <GridViewColumn Header="#" Width="35"
                                                                        DisplayMemberBinding="{Binding LoadOrder}"/>
                                                            <GridViewColumn Header="On" Width="35">
                                                                <GridViewColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <CheckBox IsChecked="{Binding IsEnabled}"
                                                                              Checked="ModCheckBox_Changed"
                                                                              Unchecked="ModCheckBox_Changed"/>
                                                                    </DataTemplate>
                                                                </GridViewColumn.CellTemplate>
                                                            </GridViewColumn>
                                                            <GridViewColumn Header="Name" Width="180"
                                                                        DisplayMemberBinding="{Binding Name}"/>
                                                        </GridView>
                                                    </ListView.View>
                                                </ListView>
                                                <Button x:Name="OverlayColSA" Content="Setup Required"
                                                    Click="BtnOpenWizardOverlay_Click" Tag="SA"
                                                    Style="{StaticResource OverlayButtonStyle}"
                                                    Visibility="Collapsed"/>
                                                <Canvas x:Name="DropCanvasSA" IsHitTestVisible="False" Panel.ZIndex="5">
                                                    <Rectangle x:Name="DropLineSA" Height="2"
                                                           Fill="{DynamicResource AccentBrush}"
                                                           Visibility="Collapsed"/>
                                                </Canvas>
                                            </Grid>
                                        </DockPanel>
                                    </Border>

                                </UniformGrid>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- (Cursor FX Canvas removed: was tied to UseCursorFx, which was -->
                <!--  saved to disk but never read; the related setting has been -->
                <!--  removed in this refactor.)                                  -->

            </Grid>
        </Border>
    </Border>
</local:DashboardWindowBase>
