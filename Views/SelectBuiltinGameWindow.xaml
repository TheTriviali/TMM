<local:TmmWindow x:Class="TMM.SelectBuiltinGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        xmlns:helpers="clr-namespace:TMM.Helpers"
        Title="Select a Built-in Game" Width="800" Height="600"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Loaded="Window_Loaded">

    <Border CornerRadius="12" Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#18000000" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="{helpers:Localization SelectGame_WindowTitle}" Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="45" VerticalAlignment="Stretch" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,10,0,0">
                                <TextBlock Text="x" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Content: Game rows -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,18,22,10">
                    <!-- GTA III Series -->
                    <TextBlock Text="{helpers:Localization SelectGame_GTAIIISeries}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentLabelBrush}" Margin="0,0,0,6"/>
                    <local:GameSetupRow x:Name="rowIII"/>
                    <local:GameSetupRow x:Name="rowVC"/>
                    <local:GameSetupRow x:Name="rowSA"/>

                    <!-- GTA IV Series -->
                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.15" Margin="0,16,0,14"/>
                    <TextBlock Text="{helpers:Localization SelectGame_GTAIVSeries}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentLabelBrush}" Margin="0,0,0,2"/>
                    <TextBlock FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"
                               TextWrapping="Wrap"
                               Text="{helpers:Localization SelectGame_GTAIVDesc}"/>
                    <local:GameSetupRow x:Name="rowIV"/>
                    <local:GameSetupRow x:Name="rowTLaD"/>
                    <local:GameSetupRow x:Name="rowTBoGT"/>

                    <!-- Rename hint for non-Latin language users -->
                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.1" Margin="0,12,0,8"/>
                    <TextBlock Text="{helpers:Localization SelectGame_RenameHint}"
                               FontSize="10" Foreground="{DynamicResource SubTextBrush}" Opacity="0.6"
                               TextWrapping="Wrap" Margin="0,0,0,4"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="22,12" Background="#0A000000">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{helpers:Localization Button_Cancel}" Click="BtnCancel_Click" Margin="0,0,10,0"
                            Height="36" Width="100" FontSize="12"
                            Background="{DynamicResource ControlBgBrush}" Foreground="{DynamicResource TextBrush}"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button x:Name="BtnDone" Content="{helpers:Localization Button_Done}" Click="BtnDone_Click"
                            Height="36" Width="100" FontSize="12" FontWeight="Bold"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource AccentTextBrush}"
                            BorderThickness="0" Cursor="Hand" IsEnabled="False"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
