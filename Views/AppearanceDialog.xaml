<local:TmmWindow x:Class="TMM.AppearanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        xmlns:helpers="clr-namespace:TMM.Helpers"
        Title="Appearance" SizeToContent="Height" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border CornerRadius="10" Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#18000000">
                <TextBlock Text="{helpers:Localization Card_Appearance}"
                           Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="40" VerticalAlignment="Stretch"
                        Click="BtnCancel_Click" ToolTip="Cancel">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,8,0,0">
                                <TextBlock Text="x" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="16,14,16,4">

                <!-- ── Live preview ─────────────────────────────────────── -->
                <Border x:Name="previewBorder" Height="80" CornerRadius="8"
                        ClipToBounds="True"
                        BorderBrush="#22FFFFFF" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop x:Name="previewStart" Color="#1B3A1B" Offset="0"/>
                            <GradientStop x:Name="previewEnd"   Color="#0C1E0C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <!-- Artwork overlay (shown when art is selected) -->
                        <Border x:Name="previewArtOverlay" CornerRadius="8" ClipToBounds="True"
                                Visibility="Collapsed"/>
                        <!-- Game name overlay -->
                        <TextBlock x:Name="previewName" Text="Preview"
                                   Foreground="#E8FFFFFF" FontWeight="Black" FontSize="15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.7" Color="#000000"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- ── Color section ────────────────────────────────────── -->
                <TextBlock Text="{helpers:Localization Appearance_Color}"
                           Foreground="{DynamicResource SubTextBrush}"
                           FontSize="11" FontWeight="Bold" Margin="0,14,0,6"/>

                <TextBlock Text="{helpers:Localization Appearance_Presets}"
                           Foreground="{DynamicResource SubTextBrush}"
                           FontSize="10" Margin="0,0,0,5"/>
                <WrapPanel x:Name="presetPanel"/>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{helpers:Localization Appearance_StartHex}"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   FontSize="10" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtStart" Height="28"
                                 Background="{DynamicResource ControlBgBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderThickness="0" Padding="6,4" FontSize="13"
                                 TextChanged="Hex_TextChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{helpers:Localization Appearance_EndHex}"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   FontSize="10" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtEnd" Height="28"
                                 Background="{DynamicResource ControlBgBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderThickness="0" Padding="6,4" FontSize="13"
                                 TextChanged="Hex_TextChanged"/>
                    </StackPanel>
                </Grid>

                <!-- ── Artwork section ──────────────────────────────────── -->
                <TextBlock Text="{helpers:Localization Appearance_Artwork}"
                           Foreground="{DynamicResource SubTextBrush}"
                           FontSize="11" FontWeight="Bold" Margin="0,14,0,6"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnChooseArt" Grid.Column="0" Height="28" Cursor="Hand"
                            Content="{helpers:Localization Appearance_ChooseImage}"
                            Click="BtnChooseArt_Click"
                            Background="{DynamicResource ControlBgBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            FontSize="12" BorderThickness="0"/>
                    <Button x:Name="btnRemoveArt" Grid.Column="2" Height="28" Width="70" Cursor="Hand"
                            Content="{helpers:Localization Appearance_RemoveArt}"
                            Click="BtnRemoveArt_Click"
                            Visibility="Collapsed"
                            Background="{DynamicResource ControlBgBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            FontSize="12" BorderThickness="0"/>
                </Grid>

                <TextBlock Text="{helpers:Localization Appearance_ArtOverridesColor}"
                           Foreground="{DynamicResource SubTextBrush}"
                           FontSize="10" TextWrapping="Wrap"
                           Opacity="0.7" Margin="0,6,0,4"/>

            </StackPanel>

            <!-- Bottom buttons -->
            <Border Grid.Row="2" Padding="16,10" Background="#0A000000">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Height="30" Padding="10,0" Cursor="Hand"
                            Content="{helpers:Localization Appearance_Reset}"
                            Click="BtnReset_Click"
                            Background="{DynamicResource PanelBrush}"
                            Foreground="{DynamicResource SubTextBrush}"
                            FontSize="11" BorderThickness="0"/>
                    <!-- spacer via * column -->
                    <Button Grid.Column="3" Height="30" Width="70" Cursor="Hand"
                            Content="{helpers:Localization Appearance_Cancel}"
                            Click="BtnCancel_Click"
                            Background="{DynamicResource PanelBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            FontSize="12" BorderThickness="0"/>
                    <Button Grid.Column="5" Height="30" Padding="14,0" Cursor="Hand"
                            Content="{helpers:Localization Appearance_Apply}"
                            Click="BtnApply_Click"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="Black" FontWeight="Bold"
                            FontSize="12" BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
