<local:TmmWindow x:Class="TMM.FirstGamePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        xmlns:helpers="clr-namespace:TMM.Helpers"
        Title="TMM" Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent"
        Loaded="Window_Loaded">

    <Border x:Name="RootBorder" CornerRadius="10" Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="1.5">
        <Border.OpacityMask>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Border Background="White" CornerRadius="9"
                            Width="{Binding ActualWidth, ElementName=RootBorder}"
                            Height="{Binding ActualHeight, ElementName=RootBorder}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.OpacityMask>

        <Grid>
            <!-- Thin accent top bar for drag -->
            <Border Height="3" VerticalAlignment="Top" Background="{DynamicResource AccentGradientBrush}"
                    MouseLeftButtonDown="TitleBar_MouseDown"/>

            <!-- X button -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="32" Height="32" Margin="0,4,4,0"
                    Click="BtnClose_Click" Panel.ZIndex="99"
                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="5">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#C42B1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Content -->
            <StackPanel Margin="28,28,28,24" MouseLeftButtonDown="TitleBar_MouseDown">

                <TextBlock Text="{helpers:Localization Picker_Heading}"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

                <!-- Option 1: Built-in game -->
                <Border x:Name="opt1" CornerRadius="8" Padding="18,14" Margin="0,0,0,10"
                        MouseLeftButtonUp="Option1_Click" Cursor="Hand"
                        BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{DynamicResource AccentSoftBrush}"
                                Margin="0,0,14,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{helpers:Localization Picker_BuiltinTitle}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3"/>
                            <TextBlock Text="{helpers:Localization Picker_BuiltinDesc}"
                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Option 2: Custom game -->
                <Border x:Name="opt2" CornerRadius="8" Padding="18,14"
                        MouseLeftButtonUp="Option2_Click" Cursor="Hand"
                        BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{DynamicResource AccentSoftBrush}"
                                Margin="0,0,14,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{helpers:Localization Picker_CustomTitle}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3"/>
                            <TextBlock Text="{helpers:Localization Picker_CustomDesc}"
                                       FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </Border>
</local:TmmWindow>
