<local:TmmWindow x:Class="TMM.UnifiedShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        xmlns:helpers="clr-namespace:TMM.Helpers"
        Title="TMM — Mod Manager"
        MinWidth="800" MinHeight="500" Width="1100" Height="720"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        StateChanged="Window_StateChanged">

    <Window.Resources>
        <!-- Nav strip button style -->
        <Style x:Key="NavBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="46"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="8"
                                Margin="4,3,4,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active nav button (selected page highlight) -->
        <Style x:Key="NavBtnActiveStyle" BasedOn="{StaticResource NavBtnStyle}" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <!-- Titlebar window control buttons -->
        <Style x:Key="WinBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#0DFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinCloseBtnStyle" BasedOn="{StaticResource WinBtnStyle}" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C42B1C"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#9E1D12"/>
                                <Setter Property="Foreground" Value="#CCFFFFff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- View-mode toggle button -->
        <Style x:Key="ViewModeBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource SubTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="32"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active view mode button style -->
        <Style x:Key="ViewModeBtnActiveStyle" BasedOn="{StaticResource ViewModeBtnStyle}" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
        </Style>
    </Window.Resources>

    <!-- Master border -->
    <Border x:Name="MainWindowBorder" Background="{DynamicResource BgBrush}" CornerRadius="10"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            MouseLeftButtonDown="TitleBar_MouseDown">
        <Border>
            <Border.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Border Background="White" CornerRadius="8"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.OpacityMask>

            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Nav strip -->
                    <ColumnDefinition Width="50"/>
                    <!-- Content -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ══════════════════════════════════════════════ -->
                <!-- LEFT NAV STRIP                                 -->
                <!-- ══════════════════════════════════════════════ -->
                <Border Grid.Column="0" Background="{DynamicResource PanelBrush}">
                    <DockPanel>
                        <!-- App logo / branding at top -->
                        <TextBlock DockPanel.Dock="Top"
                                   Text="T" FontSize="18" FontWeight="Black"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,14,0,10"/>

                        <!-- Bottom: Settings + Quit -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                            <!-- Settings (global) -->
                            <Button x:Name="navBtnSettings" Style="{StaticResource NavBtnStyle}"
                                    ToolTip="Settings" Click="NavBtn_Click" Tag="Settings">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtnStyle}" ToolTip="Quit TMM"
                                    Click="BtnQuit_Click">
                                <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>
                        </StackPanel>

                        <!-- Nav buttons -->
                        <StackPanel VerticalAlignment="Top" Margin="0,4,0,0">

                            <!-- Library -->
                            <Button x:Name="navBtnLibrary" Style="{StaticResource NavBtnStyle}"
                                    ToolTip="Library" Click="NavBtn_Click" Tag="Library">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>

                            <!-- Mod Manager -->
                            <Button x:Name="navBtnModMgr" Style="{StaticResource NavBtnStyle}"
                                    ToolTip="Mod Manager" Click="NavBtn_Click" Tag="ModManager">
                                <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>

                            <!-- Downloads -->
                            <Button x:Name="navBtnDownloads" Style="{StaticResource NavBtnStyle}"
                                    ToolTip="Downloads" Click="NavBtn_Click" Tag="Downloads">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>

                            <!-- Backups -->
                            <Button x:Name="navBtnBackups" Style="{StaticResource NavBtnStyle}"
                                    ToolTip="Backups" Click="NavBtn_Click" Tag="Backups">
                                <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>

                            <!-- Notifications -->
                            <Button x:Name="navBtnNotifications" Style="{StaticResource NavBtnStyle}"
                                    ToolTip="Notifications" Click="NavBtn_Click" Tag="Notifications">
                                <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>

                            <!-- Troubleshooting / Error Guide -->
                            <Button x:Name="navBtnTroubleshooting" Style="{StaticResource NavBtnStyle}"
                                    ToolTip="Troubleshooting" Click="NavBtn_Click" Tag="Troubleshooting">
                                <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>

                            <Border Height="1" Background="{DynamicResource SubTextBrush}"
                                    Opacity="0.2" Margin="6,8"/>

                            <!-- Paths -->
                            <Button x:Name="navBtnPaths" Style="{StaticResource NavBtnStyle}"
                                    ToolTip="File Locations" Click="NavBtn_Click" Tag="Paths">
                                <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>

                            <!-- Add / Edit Game -->
                            <Button x:Name="navBtnAddGame" Style="{StaticResource NavBtnStyle}"
                                    ToolTip="Add / Edit Game" Click="NavBtn_Click" Tag="AddGame">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </Button>

                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ══════════════════════════════════════════════ -->
                <!-- RIGHT: TITLEBAR + CONTENT + STATUSBAR          -->
                <!-- ══════════════════════════════════════════════ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                    </Grid.RowDefinitions>

                    <!-- Titlebar -->
                    <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}"
                            MouseLeftButtonDown="TitleBar_MouseDown">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- title text -->
                                <ColumnDefinition Width="*"/>     <!-- center toolbar -->
                                <ColumnDefinition Width="Auto"/>  <!-- view modes + window controls -->
                            </Grid.ColumnDefinitions>

                            <!-- Title -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="12,0,8,0">
                                <TextBlock Text="TMM" Foreground="{DynamicResource AccentBrush}"
                                           FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock x:Name="titleSubtext" Text=" — Library"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Center: Library search (centered) -->
                            <Border x:Name="searchContainer" Grid.Column="1"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="Visible"
                                    Background="{DynamicResource ControlBgBrush}" CornerRadius="5"
                                    Padding="8,0" Height="28" MinWidth="320" MaxWidth="500">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE71E;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                               Foreground="{DynamicResource SubTextBrush}"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox x:Name="txtSearch" MinWidth="260" Height="22"
                                             Background="Transparent" BorderThickness="0"
                                             Foreground="{DynamicResource TextBrush}" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             TextChanged="TxtSearch_TextChanged"/>
                                    <Button x:Name="btnClearSearch" Content="&#x2715;" Width="18" Height="18"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{DynamicResource SubTextBrush}" FontSize="10"
                                            Cursor="Hand" Click="BtnClearSearch_Click"
                                            Visibility="Collapsed"/>
                                </StackPanel>
                            </Border>

                            <!-- Center: Downloads browser nav (fills center column) -->
                            <Grid x:Name="downloadsNavBar" Grid.Column="1"
                                  VerticalAlignment="Center" Margin="6,0" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Browser nav buttons -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,4,0">
                                    <Button x:Name="btnBrowserBack" Content="&#xE72B;" Width="30" Height="28"
                                            ToolTip="Back" Click="BtnBrowserBack_Click"
                                            Style="{StaticResource ViewModeBtnStyle}"/>
                                    <Button x:Name="btnBrowserForward" Content="&#xE72A;" Width="30" Height="28"
                                            ToolTip="Forward" Click="BtnBrowserForward_Click"
                                            Style="{StaticResource ViewModeBtnStyle}"/>
                                    <Button x:Name="btnBrowserRefresh" Content="&#xE72C;" Width="30" Height="28"
                                            ToolTip="Refresh" Click="BtnBrowserRefresh_Click"
                                            Style="{StaticResource ViewModeBtnStyle}"/>
                                </StackPanel>

                                <!-- URL bar -->
                                <Border Grid.Column="1" Background="{DynamicResource ControlBgBrush}"
                                        CornerRadius="5" Padding="8,0" Height="26">
                                    <TextBox x:Name="txtBrowserUrl" Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource TextBrush}" FontSize="12"
                                             VerticalContentAlignment="Center"
                                             KeyDown="TxtBrowserUrl_KeyDown"/>
                                </Border>
                            </Grid>

                            <!-- Right: view-mode buttons + window controls -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                                <!-- View-mode switcher (library only) -->
                                <StackPanel x:Name="viewModePanel"
                                            Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                                    <Button x:Name="btnViewGrid" Style="{StaticResource ViewModeBtnStyle}"
                                            Content="&#xE8A9;" ToolTip="Grid view"
                                            Click="BtnViewMode_Click" Tag="grid"/>
                                    <Button x:Name="btnViewList" Style="{StaticResource ViewModeBtnStyle}"
                                            Content="&#xE9D5;" ToolTip="List view"
                                            Click="BtnViewMode_Click" Tag="list"/>
                                </StackPanel>

                                <!-- Window controls -->
                                <Button Content="&#xE921;" Style="{StaticResource WinBtnStyle}"
                                        Click="BtnMinimize_Click"/>
                                <Button Content="&#xE922;" Style="{StaticResource WinBtnStyle}"
                                        Click="BtnMaximize_Click"/>
                                <Button Content="&#xE8BB;" Style="{StaticResource WinCloseBtnStyle}"
                                        Click="BtnClose_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content area -->
                    <Grid Grid.Row="1" Background="{DynamicResource BgBrush}">

                        <!-- ═══ LIBRARY PAGE ═══ -->
                        <local:LibraryPage x:Name="pageLibrary"/>

                        <!-- ═══ MOD MANAGER PAGE ═══ -->
                        <local:ModManagerPage x:Name="pageModManager" Visibility="Collapsed"/>

                        <!-- ═══ DOWNLOADS PAGE ═══ -->
                        <local:DownloadsPage x:Name="pageDownloads" Visibility="Collapsed"/>

                        <!-- ═══ BACKUPS PAGE ═══ -->
                        <ContentPresenter x:Name="pageBackupsPlaceholder" Visibility="Collapsed"/>

                        <!-- Paths, Settings, AddGame, and Notifications are added dynamically
                             in code-behind because their constructors require BackendCore -->
                        <ContentPresenter x:Name="pagePathsPlaceholder"          Visibility="Collapsed"/>
                        <ContentPresenter x:Name="pageSettings"                        Visibility="Collapsed"/>
                        <ContentPresenter x:Name="pageAddGamePlaceholder"            Visibility="Collapsed"/>
                        <ContentPresenter x:Name="pageNotificationsPlaceholder"      Visibility="Collapsed"/>
                        <ContentPresenter x:Name="pageTroubleshootingPlaceholder"    Visibility="Collapsed"/>

                        <!-- ═══ CARD-CLICK MODAL OVERLAY ═══ -->
                        <Grid x:Name="cardModal" Visibility="Collapsed" Panel.ZIndex="90"
                              Background="#88000000">
                            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Background="{DynamicResource PanelBrush}" CornerRadius="12"
                                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2"
                                    Padding="32,24" MinWidth="320">
                                <StackPanel>
                                    <TextBlock x:Name="modalGameName" Text="Game Name"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock x:Name="modalGameSub" Text=""
                                               FontSize="12" Foreground="{DynamicResource SubTextBrush}"
                                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                                    <Button x:Name="modalBtnLaunch" Content="▶  Launch Game"
                                            Height="40" Margin="0,0,0,10"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="{DynamicResource AccentTextBrush}"
                                            BorderThickness="0" FontSize="14" Cursor="Hand"
                                            Click="ModalBtnLaunch_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Content="⚙  Manage Mods" Height="40" Margin="0,0,0,10"
                                            Background="{DynamicResource ControlBgBrush}"
                                            Foreground="{DynamicResource TextBrush}"
                                            BorderThickness="0" FontSize="14" Cursor="Hand"
                                            Click="ModalBtnManage_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Content="Cancel" Height="32"
                                            Background="Transparent"
                                            Foreground="{DynamicResource SubTextBrush}"
                                            BorderThickness="0" FontSize="12" Cursor="Hand"
                                            Click="ModalBtnCancel_Click"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>

                    <!-- Status Bar (Row 2) -->
                    <Border Grid.Row="2" Background="{DynamicResource HeaderBrush}"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="0,1,0,0"
                            Padding="12,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Language selector -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="&#xF49A;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="cmbLanguage" Width="140" Height="22"
                                          Background="{DynamicResource ControlBgBrush}"
                                          Foreground="{DynamicResource TextBrush}"
                                          BorderBrush="{DynamicResource SubTextBrush}"
                                          BorderThickness="1" FontSize="11"
                                          SelectionChanged="CmbLanguage_SelectionChanged"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════════════ -->
                <!-- APP-WIDE TOAST OVERLAY                         -->
                <!-- Spans both columns so toasts appear on every   -->
                <!-- page. Container is hit-test-invisible; each    -->
                <!-- toast re-enables hit-testing for its close btn -->
                <!-- ══════════════════════════════════════════════ -->
                <StackPanel Grid.ColumnSpan="2"
                            VerticalAlignment="Bottom" HorizontalAlignment="Right"
                            Margin="0,0,16,44" Width="360" Panel.ZIndex="200"
                            IsHitTestVisible="False">
                    <ItemsControl ItemsSource="{Binding Source={x:Static local:NotificationService.Queue}}"
                                  IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource PanelBrush}" CornerRadius="6"
                                        BorderThickness="1" BorderBrush="{DynamicResource AccentBrush}"
                                        Padding="12,10" Margin="0,0,0,8" MinHeight="40"
                                        IsHitTestVisible="True" MouseLeftButtonUp="Toast_Close">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Icon -->
                                        <TextBlock Grid.Column="0" Grid.Row="0"
                                                   Text="{Binding Type, Converter={StaticResource NotificationTypeIconConverter}}"
                                                   FontSize="14" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AccentLabelBrush}"/>
                                        <!-- Message -->
                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   Text="{Binding Message}"
                                                   Foreground="{DynamicResource TextBrush}" FontSize="12"
                                                   TextWrapping="Wrap" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <!-- Close button -->
                                        <Button Grid.Column="2" Grid.Row="0"
                                                Content="x" Width="20" Height="20"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource SubTextBrush}" FontSize="10"
                                                Click="Toast_CloseBtn" Cursor="Hand"
                                                VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <!-- "What does this mean?" deep-link (error codes only) -->
                                        <Button Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                                Content="{helpers:Localization Toast_WhatDoesThisMean}"
                                                Visibility="{Binding ErrorCode, Converter={StaticResource NullToVisibilityConverter}}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource AccentBrush}" FontSize="11"
                                                Cursor="Hand" HorizontalAlignment="Left" Margin="10,4,0,0"
                                                Click="Toast_ErrorLink"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </Grid>

        </Border>
    </Border>
</local:TmmWindow>
