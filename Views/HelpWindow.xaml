<Window x:Class="TMM.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Troubleshooting &amp; Links" Height="480" Width="460"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource BgBrush}"
        WindowStyle="None" AllowsTransparency="True">
    <Border BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2"
            CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#1A000000">
                <TextBlock Text="Help &amp; Troubleshooting" Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="45" VerticalAlignment="Stretch" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,10,0,0">
                                <TextBlock Text="x" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20,16,20,0">
                <TextBlock Text="Application Load Error 5:0000065434" Foreground="#FF5555"
                           FontWeight="Bold" FontSize="13" Margin="0,0,0,5"/>
                <TextBlock Text="Original Steam executables contain DRM that prevents them from running with mods. You must use a 1.0 Downgraded executable."
                           Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,14"/>

                <TextBlock Text="External Downgrade Links:" Foreground="{DynamicResource AccentBrush}"
                           FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                <Button Content="* GTA San Andreas (RockstarNexus)" Click="BtnLink_Click"
                        Tag="https://services.rockstarnexus.com/sadowngrade/latest.exe"
                        Style="{StaticResource IconButtonStyle}" FontSize="12" HorizontalAlignment="Left"/>
                <Button Content="* GTA III 1.0 (ModDB)" Click="BtnLink_Click"
                        Tag="https://www.moddb.com/downloads/grand-theft-auto-3-original-10-exe-for-steam"
                        Style="{StaticResource IconButtonStyle}" FontSize="12" HorizontalAlignment="Left" Margin="0,5"/>
                <Button Content="* GTA VC 1.0 (ModDB)" Click="BtnLink_Click"
                        Tag="https://www.moddb.com/downloads/grand-theft-auto-vice-city-original-10-exe"
                        Style="{StaticResource IconButtonStyle}" FontSize="12" HorizontalAlignment="Left" Margin="0,5"/>

                <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.3" Margin="0,14"/>

                <TextBlock Text="Note: TMM does not host these files. These are community-standard tools to enable modding compatibility."
                           Foreground="{DynamicResource SubTextBrush}" FontSize="11"
                           TextWrapping="Wrap" FontStyle="Italic"/>
            </StackPanel>

            <!-- Bottom close -->
            <Border Grid.Row="2" Padding="20,10" Background="#0A000000">
                <Button Content="Close" Click="BtnClose_Click" Height="30" FontSize="13"
                        Background="{DynamicResource AccentBrush}" Foreground="Black"
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </Border>
        </Grid>
    </Border>
</Window>
