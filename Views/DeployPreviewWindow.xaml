<local:TmmWindow x:Class="TMM.DeployPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        Title="Deploy Preview"
        Icon="{StaticResource AppIcon}"
        Height="400" Width="550"
        MinHeight="300" MinWidth="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Topmost="False">

    <!-- Outer chrome border -->
    <Border CornerRadius="10" BorderThickness="1"
            BorderBrush="{DynamicResource WindowBorderBrush}"
            Background="{DynamicResource BgBrush}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Grid Grid.Row="0" Background="{DynamicResource HeaderBrush}"
                  MouseDown="TitleBar_MouseDown">
                <TextBlock Text="Deploy Preview"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="12,0"/>
            </Grid>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="16,12" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Summary header -->
                    <TextBlock x:Name="txtSummary" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Deployment groups -->
                    <ItemsControl x:Name="icDeployGroups" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="0,0,0,1"
                                        Padding="8,12" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Margin="0,0,0,4">
                                            <Run Text="{Binding FileCount, Mode=OneWay}"/> <Run Text="file(s)"/>
                                            <Run Text="→"/> <Run Text="{Binding Destination, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="10" Opacity="0.7"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   Text="{Binding Extensions, Mode=OneWay}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Border Grid.Row="2" Background="{DynamicResource HeaderBrush}"
                    CornerRadius="0,0,8,8" Padding="16,10" BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource SubTextBrush}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCancel" Content="Cancel" Width="80" Margin="0,0,8,0"
                            Click="BtnCancel_Click"
                            Style="{StaticResource CancelBtnStyle}"/>
                    <Button x:Name="btnDeploy" Content="Deploy" Width="80"
                            Click="BtnDeploy_Click"
                            Style="{StaticResource ConfirmBtnStyle}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
