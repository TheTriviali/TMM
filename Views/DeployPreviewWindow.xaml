<Window x:Class="TMM.DeployPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Deploy Preview"
        Width="900" Height="580"
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel>
                <TextBlock Text="Deploy Preview"
                           FontSize="17" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock x:Name="txtSummary" FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SubTextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Warnings panel (hidden when no warnings) -->
        <Border Grid.Row="1" x:Name="pnlWarnings" Visibility="Collapsed"
                Background="#33FF6B6B"
                BorderBrush="#66FF6B6B" BorderThickness="0,0,0,1"
                Padding="20,10">
            <StackPanel>
                <TextBlock Text="Warnings" FontWeight="SemiBold"
                           Foreground="#FFCC88" FontSize="12" Margin="0,0,0,5"/>
                <ItemsControl x:Name="icWarnings">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="12"
                                       Foreground="#FFCC88" Margin="0,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- File list -->
        <ListView Grid.Row="2" x:Name="lvFiles"
                  Background="Transparent"
                  BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="36">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Skip" FontSize="11"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Skip, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          ToolTip="Skip this file during deployment"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="130">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Mod" FontSize="11"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ModName}" FontSize="12"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="170">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="File" FontSize="11"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileName}" FontSize="12"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="300">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Destination" FontSize="11"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayDestination}" FontSize="11"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding DestinationPath}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="150">
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Rule" FontSize="11"
                                           Foreground="{DynamicResource SubTextBrush}"/>
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RuleName}" FontSize="11"
                                           Foreground="{DynamicResource SubTextBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="2,3"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBlocking}" Value="True">
                            <Setter Property="Background" Value="#44FF4444"/>
                            <Setter Property="ToolTip" Value="Blocking conflict — file will be skipped."/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- Footer -->
        <Border Grid.Row="3" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource HeaderBrush}" BorderThickness="0,1,0,0"
                Padding="20,12">
            <Grid>
                <TextBlock x:Name="txtBlockingNote" Visibility="Collapsed"
                           Foreground="#FFCC88" FontSize="12" VerticalAlignment="Center"
                           Text="Blocking conflicts are highlighted — those files will be skipped."/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="82" Height="30"
                            Margin="0,0,8,0"
                            Click="BtnCancel_Click"/>
                    <Button x:Name="btnDeploy" Content="Deploy" Width="100" Height="30"
                            Click="BtnDeploy_Click"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource AccentTextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
