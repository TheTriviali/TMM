<Window x:Class="TMM.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About TMM" Height="640" Width="430"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource BgBrush}"
        WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="TagStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
        </Style>
        <Style x:Key="LinkBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="t" Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   Padding="{TemplateBinding Padding}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="t" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            CornerRadius="12" Background="{DynamicResource BgBrush}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#1A000000" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock Text="About TMM" Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="15,0,0,0" FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="45" VerticalAlignment="Stretch" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,10,0,0">
                                <TextBlock Text="x" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="26,18,26,0">

                    <!-- Identity -->
                    <TextBlock Text="TMM" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource AccentLabelBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,3"/>
                    <TextBlock Text="Triviali's GTA Mod Manager" FontSize="13"
                               Foreground="{DynamicResource SubTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock x:Name="txtVersion" Text="Beta" FontSize="11"
                               Foreground="{DynamicResource SubTextBrush}" Opacity="0.6"
                               HorizontalAlignment="Center" Margin="0,0,0,18"/>

                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.15" Margin="0,0,0,15"/>

                    <!-- Description -->
                    <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,12"
                               Text="A modern, themeable mod manager for the GTA III Series (III, Vice City, San Andreas) and GTA IV Complete Edition (IV, The Lost and Damned, The Ballad of Gay Tony). Install mods, manage load order, deploy directly to your game directory with automatic backup and rollback."/>

                    <!-- Disclaimer -->
                    <Border Background="#0AFFFFFF" CornerRadius="6" Padding="10,7" Margin="0,0,0,16">
                        <TextBlock TextWrapping="Wrap" FontSize="10.5" LineHeight="17"
                                   Foreground="{DynamicResource SubTextBrush}" Opacity="0.75"
                                   Text="Not affiliated with, endorsed by, or in any way associated with Rockstar Games, Take-Two Interactive, or any of their subsidiaries. GTA, Grand Theft Auto, and related marks are trademarks of Take-Two Interactive Software, Inc."/>
                    </Border>

                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.15" Margin="0,0,0,15"/>

                    <!-- Built with -->
                    <TextBlock Text="Built with" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,14">
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text=".NET 10" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text="WPF" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text="C# 13" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text="VS Code" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text="SharpCompress" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                    </WrapPanel>

                    <!-- AI-assisted -->
                    <TextBlock Text="AI-assisted development" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,16">
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text="Claude Haiku 4.5" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text="Claude Sonnet 4.6" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text="Claude Opus 4.7" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text="Gemini 3.1 Pro Paid" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text="Gemini 3 Flash Paid" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                        <Border Style="{StaticResource TagStyle}">
                            <TextBlock Text="Gemini 3 Flash Paid Thinking" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
                        </Border>
                    </WrapPanel>

                    <Border Height="1" Background="{DynamicResource SubTextBrush}" Opacity="0.15" Margin="0,0,0,14"/>


            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="24,12" Background="#0D000000">
                <Grid>
                    <TextBlock Text="Made with &#x2665; by Triviali" FontSize="11"
                               Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
                    <Button Content="Close" Click="BtnClose_Click" HorizontalAlignment="Right"
                            Height="28" Padding="20,0" BorderThickness="0" Cursor="Hand" FontSize="12"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource AccentTextBrush}"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
