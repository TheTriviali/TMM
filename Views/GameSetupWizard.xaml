<local:TmmWindow x:Class="TMM.GameSetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        xmlns:helpers="clr-namespace:TMM.Helpers"
        Title="Add Game"
        Height="680" Width="900"
        MinHeight="580" MinWidth="740"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">

    <Border CornerRadius="10" Background="{DynamicResource BgBrush}"
            BorderBrush="{DynamicResource WindowBorderBrush}" BorderThickness="2"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="#18000000" MouseLeftButtonDown="TitleBar_MouseDown">
                <TextBlock x:Name="txtWindowTitle" Text="{helpers:Localization Wizard_Title}"
                           Foreground="{DynamicResource SubTextBrush}"
                           VerticalAlignment="Center" Margin="14,0,0,0"
                           FontSize="12" FontWeight="SemiBold"/>
                <Button HorizontalAlignment="Right" Width="40" VerticalAlignment="Stretch"
                        Click="BtnClose_Click" ToolTip="{helpers:Localization Wizard_Cancel}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="Transparent" CornerRadius="0,8,0,0">
                                <TextBlock Text="✕" Foreground="{DynamicResource SubTextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Step header -->
            <Border Grid.Row="1" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource ControlBgBrush}" BorderThickness="0,0,0,1"
                    Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtStepLabel"
                                   Foreground="{DynamicResource SubTextBrush}"
                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="txtStepTitle"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="16" FontWeight="Bold"/>
                    </StackPanel>

                    <!-- Step dots -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="dot1" Width="10" Height="10" Margin="4,0"
                                 Fill="{DynamicResource AccentBrush}"/>
                        <Ellipse x:Name="dot2" Width="10" Height="10" Margin="4,0"
                                 Fill="{DynamicResource ControlBgBrush}"/>
                        <Ellipse x:Name="dot3" Width="10" Height="10" Margin="4,0"
                                 Fill="{DynamicResource ControlBgBrush}"/>
                        <Ellipse x:Name="dot4" Width="10" Height="10" Margin="4,0"
                                 Fill="{DynamicResource ControlBgBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Step content -->
            <ContentControl x:Name="stepContent" Grid.Row="2"/>

            <!-- Footer -->
            <Border Grid.Row="3" Background="#0A000000"
                    BorderBrush="{DynamicResource ControlBgBrush}" BorderThickness="0,1,0,0"
                    Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="txtFooterMsg"
                               Foreground="#E07070" FontSize="11"
                               VerticalAlignment="Center" TextWrapping="Wrap"/>

                    <Button Grid.Column="1" Content="{helpers:Localization Wizard_Cancel}" Click="BtnCancel_Click"
                            Width="80" Height="32"
                            Background="{DynamicResource PanelBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            BorderThickness="0" Cursor="Hand"/>

                    <Button Grid.Column="3" x:Name="btnBack" Content="{helpers:Localization Wizard_Back}"
                            Click="BtnBack_Click"
                            Width="80" Height="32"
                            Background="{DynamicResource HeaderBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            BorderThickness="0" Cursor="Hand"
                            Visibility="Collapsed"/>

                    <Button Grid.Column="5" x:Name="btnNext" Content="{helpers:Localization Wizard_Next}"
                            Click="BtnNext_Click"
                            Width="100" Height="32"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource AccentTextBrush}"
                            BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</local:TmmWindow>
