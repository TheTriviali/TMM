<UserControl x:Class="TMM.GameSetupRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,0,0,12">
    <UserControl.Resources>
        <ContextMenu x:Key="SteamMenu">
            <MenuItem Header="Verify Files"   Tag="validate"   Click="MenuSteamAction_Click"/>
            <MenuItem Header="Install Game"   Tag="install"    Click="MenuSteamAction_Click"/>
            <MenuItem Header="Uninstall Game" Tag="uninstall"  Click="MenuSteamAction_Click"/>
        </ContextMenu>

        <!-- Compact icon button style for Quick Scan / Browse -->
        <Style x:Key="IconActionButton" TargetType="Button">
            <Setter Property="Width"  Value="30"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock x:Name="lblTitle" Text="GAME" FontWeight="Bold" FontSize="13"
                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Path + status (status wraps so nothing is clipped) -->
            <StackPanel Grid.Column="0">
                <TextBox x:Name="txtPath" Height="26" VerticalContentAlignment="Center"
                         Background="{DynamicResource ControlBgBrush}"
                         Foreground="{DynamicResource TextBrush}"
                         BorderThickness="0" Padding="5,0" IsReadOnly="True" FontSize="12"/>
                <TextBlock x:Name="lblStatus" Text="Not Found" FontSize="10.5"
                           Foreground="Gray" TextWrapping="Wrap" Margin="2,2,0,0"/>
            </StackPanel>

            <!-- Action buttons: icon-only for compactness -->
            <Button x:Name="btnQuickScan" Grid.Column="1" Content="ðŸ”"
                    ToolTip="Quick Scan - auto-detect game path"
                    Style="{StaticResource IconActionButton}"
                    Margin="6,0,0,0" Click="BtnQuickScan_Click"/>

            <Button x:Name="btnBrowse" Grid.Column="2" Content="ðŸ“"
                    ToolTip="Browse - locate game executable manually"
                    Style="{StaticResource IconActionButton}"
                    Margin="4,0,0,0" Click="BtnBrowse_Click"/>

            <Button x:Name="btnSteam" Grid.Column="3" Content="âš™ â–¾"
                    ToolTip="Steam Actions"
                    Width="40" Height="26" Margin="4,0,0,0"
                    Background="#2A2A2A" Foreground="#FF88EE"
                    BorderThickness="0" Cursor="Hand" FontSize="11"
                    Click="BtnSteam_Click"/>
        </Grid>
    </StackPanel>
</UserControl>
