<Window x:Class="TMM.ImportReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import from Game Folder"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Width="980" Height="620"
        Background="{DynamicResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Review detected mod candidates" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Text="Select the folders and loose files you want TMM to move into ModsRaw and manage from now on."
                       FontSize="12" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Candidates}" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="False"
                  Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource SubTextBrush}"
                  HeadersVisibility="Column" RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, Mode=TwoWay}" Width="42"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                <DataGridTextColumn Header="Group" Binding="{Binding GroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="1.2*"/>
                <DataGridTextColumn Header="Files" Binding="{Binding FileCount}" IsReadOnly="True" Width="80"/>
                <DataGridTextColumn Header="Source" Binding="{Binding SourceSummary}" IsReadOnly="True" Width="2*"/>
                <DataGridTextColumn Header="Warning" Binding="{Binding Warning}" IsReadOnly="True" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="96" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Import" Width="112" Background="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource AccentTextBrush}" Click="Import_Click"/>
        </StackPanel>
    </Grid>
</Window>
