<Window x:Class="TMM.ImportReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TMM"
        xmlns:helpers="clr-namespace:TMM.Helpers"
        Title="Import from Game Folder"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Width="980" Height="620"
        Background="{DynamicResource BgBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="{helpers:Localization ImportReview_Title}" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Text="{helpers:Localization ImportReview_Subtitle}"
                       FontSize="12" Foreground="{DynamicResource SubTextBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Main content: left + right panes -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ LEFT PANE: candidates ═══ -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Section label -->
                    <Border Grid.Row="0" Background="{DynamicResource ControlBgBrush}"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="0,0,0,1"
                            Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{helpers:Localization ImportReview_CandidatesHeader}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="btnSelectAllCandidates" Content="Select all" Height="22" Padding="8,0" Margin="0,0,6,0"
                                        Click="BtnSelectAllCandidates_Click"
                                        Background="{DynamicResource ControlBgBrush}"
                                        Foreground="{DynamicResource TextBrush}"
                                        BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1" Cursor="Hand"/>
                                <Button x:Name="btnDeselectAllCandidates" Content="Deselect" Height="22" Padding="8,0"
                                        Click="BtnDeselectAllCandidates_Click"
                                        Background="{DynamicResource ControlBgBrush}"
                                        Foreground="{DynamicResource TextBrush}"
                                        BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1" Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Candidates list -->
                    <ListBox Grid.Row="1" x:Name="listCandidates"
                             SelectionMode="Extended"
                             Background="Transparent" BorderThickness="0"
                             SelectionChanged="ListCandidates_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"     Value="0"/>
                                <Setter Property="Margin"      Value="0"/>
                                <Setter Property="Background"  Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    BorderThickness="0,0,0,1"
                                                    BorderBrush="{DynamicResource SubTextBrush}"
                                                    Padding="10,6">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource PanelBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:ModImportCandidate}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Top" Margin="0,2,8,0" Cursor="Hand"/>
                                    <StackPanel Grid.Column="1">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="155"/>
                                            <TextBlock Text=" ⚠" Foreground="#FFAA00" FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasWarning}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding FileCountDisplay}" FontSize="10"
                                                   Foreground="{DynamicResource SubTextBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Merge footer -->
                    <Border Grid.Row="2" Background="{DynamicResource ControlBgBrush}"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="0,1,0,0"
                            Padding="10,8">
                        <StackPanel>
                            <Button x:Name="btnMergeSelected"
                                    Content="{helpers:Localization ImportReview_MergeSelected}"
                                    Height="26" Click="BtnMergeSelected_Click"
                                    Background="{DynamicResource ControlBgBrush}"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1"
                                    Cursor="Hand" IsEnabled="False"/>
                            <TextBlock Text="{helpers:Localization ImportReview_MultiSelectHint}"
                                       FontSize="9" Foreground="{DynamicResource SubTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Vertical divider -->
                <Border Grid.Column="1" Width="1"
                        Background="{DynamicResource SubTextBrush}" Opacity="0.3"/>

                <!-- ═══ RIGHT PANE: files in focused candidate ═══ -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Right header: "FILES IN …" + action buttons -->
                    <Border Grid.Row="0" Background="{DynamicResource ControlBgBrush}"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="0,0,0,1"
                            Padding="12,6">
                        <Grid>
                            <TextBlock x:Name="txtFilesHeader" Text="FILES IN …"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SubTextBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="btnSplitChecked"
                                        Content="{helpers:Localization ImportReview_NewModFromChecked}"
                                        Height="24" Padding="8,0" Margin="0,0,6,0"
                                        Click="BtnSplitChecked_Click"
                                        Background="{DynamicResource ControlBgBrush}"
                                        Foreground="{DynamicResource TextBrush}"
                                        BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1"
                                        Cursor="Hand" IsEnabled="False"/>
                                <Button x:Name="btnMoveChecked"
                                        Content="{helpers:Localization ImportReview_MoveChecked}"
                                        Height="24" Padding="8,0"
                                        Click="BtnMoveChecked_Click"
                                        Background="{DynamicResource ControlBgBrush}"
                                        Foreground="{DynamicResource TextBrush}"
                                        BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1"
                                        Cursor="Hand" IsEnabled="False"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- File list / empty state -->
                    <Grid Grid.Row="1">
                        <!-- Empty state when no candidate is focused -->
                        <TextBlock x:Name="emptyRightPane"
                                   Text="{helpers:Localization ImportReview_EmptyRightPane}"
                                   FontSize="12" Foreground="{DynamicResource SubTextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- File rows -->
                        <ScrollViewer x:Name="fileScrollViewer" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="fileList" Margin="12,6,12,6">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:ImportFileRow}">
                                        <StackPanel Orientation="Horizontal" Margin="0,3">
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      Margin="0,0,8,0" Cursor="Hand"
                                                      Click="FileRow_CheckChanged"/>
                                            <TextBlock Text="{Binding RelativePath}" FontSize="11"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                                <!-- Select/Deselect for file rows -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12,8,0,0">
                                    <Button x:Name="btnSelectAllFiles" Content="Select all" Height="24" Padding="8,0" Margin="0,0,6,0"
                                            Click="BtnSelectAllFiles_Click"
                                            Background="{DynamicResource ControlBgBrush}"
                                            Foreground="{DynamicResource TextBrush}"
                                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1" Cursor="Hand"/>
                                    <Button x:Name="btnDeselectAllFiles" Content="Deselect" Height="24" Padding="8,0"
                                            Click="BtnDeselectAllFiles_Click"
                                            Background="{DynamicResource ControlBgBrush}"
                                            Foreground="{DynamicResource TextBrush}"
                                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1" Cursor="Hand"/>
                                </StackPanel>
                    </Grid>

                    <!-- Name / Group editors + warning -->
                    <Border Grid.Row="2" Background="{DynamicResource ControlBgBrush}"
                            BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="0,1,0,0"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Name editor -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="{helpers:Localization ImportReview_NameLabel}"
                                           FontSize="10" Foreground="{DynamicResource SubTextBrush}"
                                           Margin="0,0,0,3"/>
                                <TextBox x:Name="txtCandidateName" Height="28" Padding="6,4"
                                         Background="{DynamicResource ControlBgBrush}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1"
                                         IsEnabled="False"
                                         TextChanged="TxtCandidateName_TextChanged"/>
                            </StackPanel>

                            <!-- Group editor + warning badge -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="{helpers:Localization ImportReview_GroupLabel}"
                                               FontSize="10" Foreground="{DynamicResource SubTextBrush}"/>
                                    <TextBlock x:Name="txtWarningBadge" Text="  ⚠"
                                               Foreground="#FFAA00" FontSize="10"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                                <TextBox x:Name="txtCandidateGroup" Height="28" Padding="6,4"
                                         Background="{DynamicResource ControlBgBrush}"
                                         Foreground="{DynamicResource TextBrush}"
                                         BorderBrush="{DynamicResource SubTextBrush}" BorderThickness="1"
                                         IsEnabled="False"
                                         TextChanged="TxtCandidateGroup_TextChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{helpers:Localization Button_Cancel}" Width="96" Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button x:Name="btnImport" Height="32" MinWidth="130" Padding="16,0"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="{DynamicResource AccentTextBrush}"
                    BorderThickness="0" Cursor="Hand"
                    IsEnabled="False" Click="Import_Click"/>
        </StackPanel>
    </Grid>
</Window>
